        "enabled": true,
        "category": "implants"
      },
      {
        "name": "Dental News — DrBicuspid",
        "url": "https://www.drbicuspid.com/feed/",
        "enabled": true,
        "category": "news"
      },
      {
        "name": "Dental Tribune Russia",
        "url": "https://www.dental-tribune.com/feed/",
        "enabled": true,
        "category": "news"
      },
      {
        "name": "ScienceDaily — Dentistry",
        "url": "https://www.sciencedaily.com/rss/health_medicine/dentistry.xml",
        "enabled": true,
        "category": "research"
      }
    ],
    "reddit": {
      "enabled": true,
      "fetch_comments": 3,
      "subreddits": [
        {
          "subreddit": "dentistry",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 20,
          "min_score": 10
        },
        {
          "subreddit": "dentures",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 5
        },
        {
          "subreddit": "Dentistry",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 15,
          "min_score": 10
        }
      ],
      "users": []
    },
    "hackernews": {
      "enabled": false
    },
    "github": [],
    "twitter": {
      "enabled": false
    },
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 72
  },
  "email": {
    "enabled": false
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "platform": "generic",
    "layout": "markdown",
    "request_body": {
      "text": "Horizon: #{important_items}/#{all_items} items passed\n\n#{summary?limit=4000}"
    },
    "headers": ""
  }
}
