{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-4",
    "api_key_env": "HORIZON_OPENAI_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1.5,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 1
  },
  "sources": {
