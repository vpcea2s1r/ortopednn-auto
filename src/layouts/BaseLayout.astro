---
import Analytics from '../components/Analytics.astro';
import SocialLinks from '../components/SocialLinks.astro';

const { title, description, region, doctor = {}, cfToken, socials = [] } = Astro.props;
const doctorName = doctor?.name || 'Никитина Марина Георгиевна';
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="geo.region" content="RU-NIZHNOV"/>
  <meta name="geo.placename" content={region || "Нижний Новгород"}/>
  <meta name="ICBM" content="56.3269,44.0060"/>
  <link rel="canonical" href={`https://ortopednn.ru${Astro.url.pathname}`}/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <Analytics ymId="YOUR_METRIKA_ID" gaId="YOUR_GA_ID" cfToken={cfToken}/>
</head>
<body>
  <a href="#main" class="skip-link">Перейти к контенту</a>
  <header>
    <slot name="header"/>
  </header>
  <main id="main">
    <slot/>
  </main>
  <footer class="site-footer">
    <div class="footer-content">
      <p class="copyright">© {new Date().getFullYear()} {doctorName}</p>
      <SocialLinks socials={socials}/>
    </div>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --primary: #0ea5e9;
    --primary-dark: #0284c7;
    --primary-light: #e0f2fe;
    --text: #1e293b;
    --text-muted: #64748b;
    --bg: #f8fafc;
    --white: #ffffff;
    --border: #e2e8f0;
    --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    --radius: 12px;
  }
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }
  
  .skip-link {
    position: absolute;
    top: -50px;
    left: 16px;
    background: var(--primary);
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 500;
    z-index: 1000;
    transition: top 0.2s;
  }
  .skip-link:focus {
    top: 16px;
  }
  
  header {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 16px 24px;
  }
  
  main {
    min-height: calc(100vh - 200px);
  }
  
  .site-footer {
    background: var(--text);
    color: rgba(255,255,255,0.7);
    padding: 32px 24px;
    margin-top: 64px;
  }
  
  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }
  
  .copyright {
    font-size: 14px;
  }
  
  h1, h2, h3 {
    color: var(--text);
    line-height: 1.3;
  }
  
  a {
    color: var(--primary);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  a:hover {
    color: var(--primary-dark);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }
</style>