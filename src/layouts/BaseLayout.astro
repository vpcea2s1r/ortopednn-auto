---
import '../styles/global.css';

const { title = '', description = '', region, doctor = {}, socials = [] } = Astro.props;
const truncatedTitle = title.length > 60 ? title.slice(0, 57) + '...' : title;
---

<!doctype html>
<html lang="ru" dir="ltr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta http-equiv="Content-Language" content="ru"/>
  <title>{truncatedTitle}</title>
  <meta name="description" content={description}/>
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"/>
  <meta name="googlebot" content="index, follow"/>
  <meta name="author" content="Никитина Марина Георгиевна"/>
  <meta name="language" content="Russian"/>
  <link rel="alternate" type="application/rss+xml" title="Sitemap" href="/sitemap-index.xml"/>
  
  <meta name="geo.region" content="RU-NIZHNOV"/>
  <meta name="geo.placename" content={region || "Нижний Новгород"}/>
  <meta name="ICBM" content="56.294,43.936"/>
  
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  
  <link rel="canonical" href={`https://ortopednn.ru${Astro.url.pathname}`}/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={Astro.url.href}/>
  <meta property="og:title" content={truncatedTitle}/>
  <meta property="og:description" content={description}/>
  <meta property="og:locale" content="ru_RU"/>
  
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dentist",
    "name": doctor.name || "Никитина Марина Георгиевна",
    "jobTitle": "Стоматолог-ортопед",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ул. Октябрьской Революции, д. 43, оф. 316",
      "addressLocality": "Нижний Новгород",
      "addressRegion": "Нижегородская область",
      "postalCode": "603000",
      "addressCountry": "RU"
    },
    "telephone": doctor.phone || "+79202537317",
    "priceRange": "₽₽",
    "openingHours": "Mo-Fr 09:00-19:00",
    "areaServed": "Нижний Новгород",
    "medicalSpecialty": "Prosthodontics"
  })}/>
</head>
<body>
  <slot/>
</body>
</html>