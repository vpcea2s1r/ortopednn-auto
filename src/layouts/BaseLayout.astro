---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

const { title = '', description = '', region, doctor = {}, socials = [], pageType = 'website', datePublished, dateModified, breadcrumbTitle, ogImage = '/og-image.svg', noindex = false, clientRouter = false } = Astro.props;
const titleWithCity = title.includes('Нижний Новгород') ? title : `${title} | Нижний Новгород`;
const truncatedTitle = titleWithCity.length > 60 ? titleWithCity.slice(0, 57) + '...' : titleWithCity;
const truncatedDesc = description.length > 160 ? description.slice(0, 157) + '...' : description;
const isHomepage = Astro.url.pathname === '/';
const siteOrigin = "2025-01-15T00:00:00+03:00";
const today = new Date().toISOString();
const published = datePublished || siteOrigin;
const modified = dateModified || today;

const segmentNames = {
  'services': 'Услуги',
  'blog': 'Блог',
  'about': 'О враче',
  'checkup': 'Самопроверка',
  'compare': 'Сравнение',
  'materials': 'Материалы',
  'stomatolog-ortoped-nizhnij-novgorod': 'Стоматолог-ортопед в Нижнем Новгороде',
};

const pathParts = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbItems = [{ name: 'Главная', url: 'https://ortopednn.ru/' }];
const pageNameFromTitle = breadcrumbTitle || truncatedTitle.split(/[—|–]/)[0].trim();

let currentUrl = 'https://ortopednn.ru';
for (let i = 0; i < pathParts.length; i++) {
  currentUrl += '/' + pathParts[i];
  const isLast = i === pathParts.length - 1;
  breadcrumbItems.push({
    name: isLast ? pageNameFromTitle : (segmentNames[pathParts[i]] || pathParts[i]),
    url: currentUrl + '/'
  });
}

const hasBreadcrumbs = breadcrumbItems.length > 1;
---

<!doctype html>
<html lang="ru" dir="ltr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta http-equiv="Content-Language" content="ru"/>
  <title>{truncatedTitle}</title>
  <meta name="description" content={truncatedDesc}/>
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'}/>
  <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'}/>
  <meta name="author" content="Никитина Марина Георгиевна"/>
  <meta name="language" content="Russian"/>
  <meta name="article:published_time" content={published}/>
  <meta name="article:modified_time" content={modified}/>
  <link rel="alternate" type="application/rss+xml" title="Sitemap" href="/sitemap-index.xml"/>
  <meta name="zen-verification" content="GG06PtAHU8BI5KPxbsNGDi4NV4mgleoKANTEXBv7ihSuq6L1BuWBWguS7JP9JXzS"/>
  
  <meta name="geo.region" content="RU-NIZHNOV"/>
  <meta name="geo.placename" content={region || "Нижний Новгород"}/>
  <meta name="ICBM" content="56.294,43.936"/>
  
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <link rel="apple-touch-icon" href="/favicon.svg"/>
  
  <Font cssVariable="--font-inter" preload/>
  {clientRouter && <ClientRouter/>}
  
  <link rel="canonical" href={`https://ortopednn.ru${Astro.url.pathname}`}/>
  <meta property="og:type" content={pageType}/>
  <meta property="og:url" content={Astro.url.href}/>
  <meta property="og:title" content={truncatedTitle}/>
  <meta property="og:description" content={truncatedDesc}/>
  <meta property="og:image" content={`https://ortopednn.ru${ogImage}`}/>
  <meta property="og:locale" content="ru_RU"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={truncatedTitle}/>
  <meta name="twitter:description" content={truncatedDesc}/>
  <meta name="twitter:image" content={`https://ortopednn.ru${ogImage}`}/>
  
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalBusiness",
    "name": "ОртопедНН — Никитина Марина Георгиевна",
    "description": "Стоматолог-ортопед с 1994 года. Специализируется на протезировании зубов: коронки, съёмные и бюгельные протезы.",
    "url": "https://ortopednn.ru",
    "image": "https://ortopednn.ru/og-image.svg",
    "telephone": "+79202537317",
    "priceRange": "По записи",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ул. Октябрьской Революции, д. 43",
      "addressLocality": "Нижний Новгород",
      "addressRegion": "Нижегородская область",
      "postalCode": "603000",
      "addressCountry": "RU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 56.294,
      "longitude": 43.936
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "19:00"
      }
    ],
    "medicalSpecialty": "Prosthodontics",
    "alumni": [
      {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "degree",
        "name": "Высшее медицинское образование",
        "educationalInstitution": {
          "@type": "CollegeOrUniversity",
          "name": "Нижегородский государственный медицинский институт"
        },
        "dateOfGraduation": "1995"
      },
      {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "certificate",
        "name": "Сертификат специалиста по специальности: стоматология ортопедическая",
        "validIn": {
          "@type": "Place",
          "name": "Россия"
        },
        "validThrough": "2025"
      }
    ],
    "sameAs": []
  })}/>

  {isHomepage && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Больно ли обтачивать зубы под коронку?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Работаем с анестезией — вы не почувствуете боли. После процедуры возможна чувствительность на 1-2 дня."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько времени занимает протезирование?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Коронки — 7-14 дней. Съёмные протезы — 2-3 недели. Зависит от сложности."
          }
        },
        {
          "@type": "Question",
          "name": "Какой протез лучше — съёмный или на имплантах?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Импланты комфортнее и долговечнее. Но съёмные подходят, когда имплантация невозможна."
          }
        },
        {
          "@type": "Question",
          "name": "Нужно ли обтачивать здоровые зубы?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Сохраняем здоровые зубы. Обточка нужна только для фиксации коронки."
          }
        },
        {
          "@type": "Question",
          "name": "Как ухаживать за съёмным протезом?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Промывайте после еды, чистите 2 раза в день, храните в воде. Раз в полгода — профчистка."
          }
        },
        {
          "@type": "Question",
          "name": "Сколько служит циркониевая коронка?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "15-20 лет при правильном уходе. Раз в год — осмотр."
          }
        },
        {
          "@type": "Question",
          "name": "Что делать, если протез натирает?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Запишитесь на коррекцию. Обычно 1-3 визита. Не подтачивайте сами."
          }
        },
        {
          "@type": "Question",
          "name": "Как понять, что пора менять коронку?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Боль, отёк, подвижность, изменение цвета десны, запах — повод обратиться."
          }
        }
      ]
    })}/>
  )}

  {hasBreadcrumbs && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": item.name,
        "item": item.url
      }))
    })}/>
  )}

</head>
<body>
  <slot/>
  <footer class="legal-disclaimer">
    <div class="container container--w1100">
