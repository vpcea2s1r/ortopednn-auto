---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import Specializations from '../components/Specializations.astro';
import PriceList from '../components/PriceList.astro';

import doctor from '../../data/doctor.json';
import socials from '../../data/socials.json';
---

<BaseLayout 
  title="Протезирование зубов в Нижнем Новгороде | Цены на коронки, виниры, протезы | Никитина М.Г."
  description="Протезирование зубов в Нижнем Новгороде. Стоматолог-ортопед Никитина Марина Георгиевна. Металлокерамика от 9000 ₽, цирконий, виниры E-MAX, съёмные и бюгельные протезы. Цены без скрытых платежей."
  region="Нижний Новгород"
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <nav class="breadcrumbs" aria-label="Хлебные крошки">
    <div class="container">
      <a href="/">Главная</a>
    </div>
  </nav>
  <main>
    <HeroSection doctor={doctor}/>
    <section class="about-doctor">
      <div class="container">
        <h2>О враче</h2>
        <div class="about-content">
          <div class="about-text">
            <p>Никитина Марина Георгиевна — стоматолог-ортопед с высшим медицинским образованием. Специализируется на протезировании зубов: коронки, виниры, съёмные и бюгельные протезы.</p>
            <p>Использует современные методики и материалы. Работаю с пациентами индивидуально, подбираю оптимальное решение для каждого случая.</p>
          </div>
          <div class="about-services">
            <h3>Основные направления:</h3>
            <ul>
              <li>Металлокерамические коронки</li>
              <li>Циркониевые коронки</li>
              <li>Виниры E-MAX</li>
              <li>Съёмные протезы (акрил, AcryFree, нейлон)</li>
              <li>Бюгельные протезы</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    <Specializations />
    <PriceList />
  </main>
  <footer class="footer">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="logo">врач-ортопед Никитина Марина Георгиевна</span>
        <p>Стоматолог-ортопед</p>
      </div>
      <div class="footer-info">
        <p class="visually-hidden">Нижний Новгород, ул. Октябрьской Революции, д. 43, оф. 316</p>
        <p class="copy">© {new Date().getFullYear()} Все права защищены</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.about-doctor {
  padding: 64px 0;
  background: white;
}

.about-doctor h2 {
  text-align: center;
  font-size: 2rem;
  font-weight: 800;
  color: #1e1b4b;
  margin-bottom: 32px;
}

.about-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
}

.about-text p {
  color: #4b5563;
  font-size: 1rem;
  line-height: 1.7;
  margin-bottom: 16px;
}

.about-services h3 {
  font-size: 1rem;
  font-weight: 600;
  color: #7c3aed;
  margin-bottom: 16px;
}

.about-services ul {
  list-style: none;
  padding: 0;
}

.about-services li {
  color: #374151;
  font-size: 0.95rem;
  padding: 8px 0;
  border-bottom: 1px solid #f3e8ff;
}

.breadcrumbs {
  padding: 12px 0;
  background: white;
  border-bottom: 1px solid #f3e8ff;
}

.breadcrumbs a {
  color: #7c3aed;
  font-size: 0.875rem;
  font-weight: 500;
}

.footer {
  background: #1e1b4b;
  padding: 48px 0;
}

.footer-content {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 24px;
}

.footer-brand .logo {
  font-weight: 800;
  color: white;
  font-size: 1.25rem;
}

.footer-brand p {
  color: rgba(255,255,255,0.6);
  font-size: 0.875rem;
  margin-top: 4px;
}

.footer-info p {
  color: rgba(255,255,255,0.8);
  font-size: 0.9rem;
  margin-bottom: 4px;
}

.footer-info .copy {
  color: rgba(255,255,255,0.4);
  font-size: 0.8rem;
}

@media (max-width: 768px) {
  .about-content {
    grid-template-columns: 1fr;
    gap: 32px;
  }
}

@media (max-width: 640px) {
  .about-doctor {
    padding: 48px 0;
  }
  .about-doctor h2 {
    font-size: 1.5rem;
  }
  .footer-content {
    flex-direction: column;
    text-align: center;
  }
}
</style>