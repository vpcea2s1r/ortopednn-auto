---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import Specializations from '../components/Specializations.astro';
import PriceList from '../components/PriceList.astro';

import doctor from '../../data/doctor.json';
import socials from '../../data/socials.json';
---

<BaseLayout 
  title="Никитина Марина Георгиевна | Стоматолог-ортопед в Нижнем Новгороде"
  description="Стоматолог-ортопед Никитина М.Г. Протезирование зубов: металлокерамика, цирконий, виниры E-MAX, съёмные и бюгельные протезы."
  region="Нижний Новгород"
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <HeroSection doctor={doctor}/>
  <Specializations />
  <PriceList />
  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Никитина Марина Георгиевна</p>
    <p class="address">Работаю в компании ООО Улыбка | Нижний Новгород, ул. Октябрьской Революции, д. 43, оф. 316</p>
  </footer>
</BaseLayout>

<style>
.site-footer {
  text-align: center;
  padding: 24px;
  color: #5a7a9a;
  font-size: 0.875rem;
  background: #1e3a5f;
  color: white;
}
.site-footer p {
  margin-bottom: 8px;
}
.site-footer .address {
  font-size: 0.8rem;
  opacity: 0.8;
}
</style>