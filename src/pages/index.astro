---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import Specializations from '../components/Specializations.astro';
import PriceList from '../components/PriceList.astro';

import doctor from '../../data/doctor.json';
import socials from '../../data/socials.json';
---

<BaseLayout 
  title="Никитина Марина Георгиевна | Стоматолог-ортопед в Нижнем Новгороде"
  description="Стоматолог-ортопед Никитина М.Г. в Нижнем Новгороде. Протезирование зубов: металлокерамика, цирконий, виниры E-MAX, съемные и бюгельные протезы."
  region="Нижний Новгород"
  doctor={doctor}
  cfToken="YOUR_CF_TOKEN"
  socials={socials}
>
  <Navbar />
  <HeroSection doctor={doctor}/>
  <Specializations />
  <PriceList />
  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Никитина Марина Георгиевна</p>
  </footer>
</BaseLayout>

<style>
.site-footer {
  text-align: center;
  padding: 24px;
  color: #5a7a9a;
  font-size: 0.875rem;
  background: #f8fafc;
}
</style>