---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import Specializations from '../components/Specializations.astro';
import PriceList from '../components/PriceList.astro';

import doctor from '../../data/doctor.json';
import socials from '../../data/socials.json';
---

<BaseLayout 
  title="Никитина Марина Георгиевна | Стоматолог-ортопед в Нижнем Новгороде"
  description="Стоматолог-ортопед Никитина М.Г. Протезирование зубов: металлокерамика, цирконий, виниры E-MAX, съёмные и бюгельные протезы."
  region="Нижний Новгород"
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main>
    <HeroSection doctor={doctor}/>
    <Specializations />
    <PriceList />
  </main>
  <footer class="footer">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="logo">Н. Марина</span>
        <p>Стоматолог-ортопед</p>
      </div>
      <div class="footer-info">
        <p>Нижний Новгород, ул. Октябрьской Революции, д. 43, оф. 316</p>
        <p class="copy">© {new Date().getFullYear()} Все права защищены</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
.footer {
  background: #1e1b4b;
  padding: 48px 24px;
}

.footer-content {
  max-width: 1000px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 24px;
}

.footer-brand .logo {
  font-weight: 800;
  color: white;
  font-size: 1.25rem;
}

.footer-brand p {
  color: rgba(255,255,255,0.6);
  font-size: 0.875rem;
  margin-top: 4px;
}

.footer-info p {
  color: rgba(255,255,255,0.8);
  font-size: 0.9rem;
  margin-bottom: 4px;
}

.footer-info .copy {
  color: rgba(255,255,255,0.4);
  font-size: 0.8rem;
}

@media (max-width: 640px) {
  .footer-content {
    flex-direction: column;
    text-align: center;
  }
}
</style>