---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout 
  title="Цельнолитая коронка — Никитина М.Г."
  description="Цельнолитые зубные коронки в Нижнем Новгороде. Металлические коронки из кобальт-хрома. Цена от 5900 рублей."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/services">Услуги</a>
        <span>/</span>
        <span>Цельнолитая коронка</span>
      </div>
    </nav>
    
    <article class="service-content">
      <div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Цельнолитая коронка</h1>
          <div class="service-header__price">от 5 900 ₽</div>
        </header>
        
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое цельнолитая коронка простыми словами</h2>
            <p>Цельнолитая коронка — это металлический колпачок на зуб, отлитый целиком из металла. Это самый прочный и долговечный вид коронок.</p>
            <p>Коронка отливается из кобальт-хромового или никель-хромового сплава. Металл заливается в форму, остывает и получается прочная конструкция, которая идеально сидит на зубе.</p>
          </section>
          
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Жевательные зубы (моляры и премоляры)</li>
              <li>Зубы после лечения каналов (для укрепления)</li>
              <li>Опора для мостовидного протеза</li>
              <li>Бюгельные коронки (для бюгельного протеза)</li>
              <li>Временное протезирование</li>
              <li>Низкий бюджет при сохранении функции</li>
            </ul>
          </section>
          
          <section class="info-section">
            <h2>Из чего делают</h2>
            <p><strong>Кобальт-хром (Co-Cr)</strong> — самый распространённый сплав. Прочный, недорогой, хорошо совместим с тканями. Серебристый цвет.</p>
            <p><strong>Никель-хром (Ni-Cr)</strong> — дешевле кобальта. Может вызывать аллергию на никель. Не рекомендуется при аллергии.</p>
            <p><strong>Золото</strong> — элитный вариант. Мягкий металл, идеально прилегает. Стоит дорого, используется редко.</p>
          </section>
          
          <div class="info-grid">
            <section class="info-block info-block--pros">
              <h3>Преимущества</h3>
              <ul>
                <li><strong>Прочность</strong> — выдерживает любые жевательные нагрузки</li>
                <li><strong>Долговечность</strong> — служит 15-20 лет</li>
                <li><strong>Точность</strong> — литьё обеспечивает идеальную посадку</li>
                <li><strong>Минимальная обточка</strong> — зуб обтачивается меньше, чем под металлокерамику</li>
                <li><strong>Стоимость</strong> — самый доступный вид коронок</li>
                <li><strong>Ремонт</strong> — можно паять и ремонтировать</li>
              </ul>
            </section>
            
            <section class="info-block info-block--cons">
              <h3>Ограничения</h3>
              <ul>
                <li><strong>Внешний вид</strong> — металл заметен, не подходит для передних зубов</li>
                <li><strong>Аллергия</strong> — возможна реакция на никель или хром</li>
                <li><strong>Теплопроводность</strong> — зуб может реагировать на горячее и холодное</li>
                <li><strong>Окисление</strong> — металл может потемнеть у десны</li>
                <li><strong>Вторичный кариес</strong> — нужно следить за краем коронки</li>
              </ul>
            </section>
          </div>
          
          <section class="info-section">
            <h2>Как изготавливается</h2>
            <p><strong>1. Обточка зуба</strong> — снимается 1-1.5 мм со всех сторон. Формируется уступ для края коронки.</p>
            <p><strong>2. Снятие слепка</strong> — с обточенного зуба и соседних зубов.</p>
            <p><strong>3. Моделирование</strong> — техник создаёт модель зуба из воска.</p>
            <p><strong>4. Литьё</strong> — восковая модель заменяется металлом в литьевой машине.</p>
            <p><strong>5. Обработка</strong> — коронка шлифуется, полируется до зеркального блеска.</p>
            <p><strong>6. Примерка и фиксация</strong> — коронка надевается на цемент.</p>
          </section>
          
          <section class="info-section">
            <h2>Виды цельнолитых коронок</h2>
            <p><strong>Без напыления</strong> — простая полированная металлическая коронка.</p>
            <p><strong>С напылением</strong> — на поверхность наносится слой керамики для эстетики.</p>
            <p><strong>С облицовкой</strong> — металлический каркас с керамической наружной частью.</p>
            <p><strong>Бюгельная</strong> — специальная коронка для крепления бюгельного протеза.</p>
          </section>
          
          <section class="info-section">
            <h2>Срок службы</h2>
            <p>Цельнолитые коронки служат 15-20 лет и более. Признаки замены: сколы, трещины металла, неплотное прилегание к десне, кариес под коронкой.</p>
          </section>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card__value">5 900 ₽</div>
              <div class="stat-card__label">от стоимость</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">15-20 лет</div>
              <div class="stat-card__label">срок службы</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1-2 дня</div>
              <div class="stat-card__label">срок изготовления</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1-1.5 мм</div>
              <div class="stat-card__label">обточка зуба</div>
            </div>
          </div>
          <section class="info-section"><h2>Когда выбирают цельнолитую коронку</h2>
            <p><strong>Жевательные зубы</strong> — не требуется эстетика, важна прочность.</p>
            <p><strong>Бюгельные протезы</strong> — дуга и кламмеры изготавливаются из того же сплава.</p>
            <p><strong>Опора моста</strong> — прочный каркас для мостовидных протезов.</p>
            <p><strong>Шинирование</strong> — несколько коронок соединяются для стабилизации.</p>
          </section>
        </div>
        
        <div class="service-cta">
          <p>Нужна консультация по цельнолитым коронкам?</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Написать в Telegram</a>
          </div>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>