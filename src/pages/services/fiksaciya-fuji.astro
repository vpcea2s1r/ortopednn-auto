---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Фиксация коронки Fuji | Никитина М.Г." description="Постоянная фиксация коронок стеклоиономерным цементом Fuji. Цена 960 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Фиксация коронки Fuji</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Фиксация коронки Fuji</h1>
          <div class="service-header__price">960 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое Fuji</h2>
            <p>Fuji — стеклоиономерный цемент (GIC) производства GC Corporation (Япония). Линейка Fuji включает несколько модификаций: Fuji I, Fuji II, Fuji Plus, Fuji Cem — каждая для своих целей.</p>
            <p>Стеклоиономерные цементы имеют несколько важных преимуществ: химическая адгезия к тканям зуба, выделение фтора (профилактика вторичного кариеса), биосовместимость, низкая растворимость в ротовой жидкости.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Фиксация одиночных коронок</li>
              <li>Фиксация мостовидных протезов</li>
              <li>Фиксация вкладок и накладок</li>
              <li>Пациенты с высоким риском вторичного кариеса</li>
              <li>Пациенты с чувствительностью к композитным материалам</li>
              <li>Фиксация при неидеальном препарировании (допускается больше погрешностей)</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Виды Fuji для фиксации</h2>
            <p><strong>Fuji I:</strong> классический стеклоиономер для фиксации. Требует тщательного смешивания, рабочее время 3-4 минуты.</p>
            <p><strong>Fuji Plus:</strong> модифицированный стеклоиономер с улучшенными свойствами. Лучше текучесть, меньше чувствительность к влаге.</p>
            <p><strong>Fuji Cem:</strong> самопротравливающий стеклоиономер. Упрощает протокол фиксации.</p>
            <p><strong>Fuji ORMO:</strong> для ортодонтических конструкций, не для фиксации коронок.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества стеклоиономеров</h3><ul>
              <li><strong>Химическая адгезия</strong> — связь с эмалью и дентином без адгезива</li>
              <li><strong>Фторвыделение</strong> — профилактика вторичного кариеса</li>
              <li><strong>Биосовместимость</strong> — минимальное раздражение пульпы</li>
              <li><strong>Терпеливость</strong> — прощает погрешности в работе</li>
              <li><strong>Рентгеноконтрастность</strong> — видно на снимках</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Прочность</strong> — ниже, чем у композитных цементов</li>
              <li><strong>Эстетика</strong> — не прозрачен, ограниченная цветовая гамма</li>
              <li><strong>Время</strong> — дольше застывает</li>
              <li><strong>Чувствительность</strong> — к влаге на этапе полимеризации</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Протокол фиксации на Fuji</h2>
            <p><strong>1. Изоляция:</strong> коффердам или ватные валики.</p>
            <p><strong>2. Очистка:</strong> промывание водой, высушивание (не пересушивать!).</p>
            <p><strong>3. Подготовка коронки:</strong> внутренняя поверхность очищается, может быть протравлена.</p>
            <p><strong>4. Замешивание:</strong> порошок и жидкость смешиваются согласно инструкции.</p>
            <p><strong>5. Нанесение:</strong> тонкий слой на внутреннюю поверхность коронки.</p>
            <p><strong>6. Фиксация:</strong> коронка надевается, прижимается.</p>
            <p><strong>7. Удаление излишков:</strong> через 2-3 минуты, когда цемент начинает застывать.</p>
            <p><strong>8. Полимеризация:</strong> полное застывание — 5-7 минут.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>