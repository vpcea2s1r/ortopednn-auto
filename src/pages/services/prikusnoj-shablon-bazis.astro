---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Прикусной шаблон на жестком базисе | Никитина М.Г." description="Прикусной шаблон на индивидуальном акриловом базисе. Цена 3 240 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Прикусной шаблон на жестком базисе</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Прикусной шаблон на жестком базисе</h1>
          <div class="service-header__price">3 240 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое шаблон на жестком базисе</h2>
            <p>Прикусной шаблон на жестком базисе — это пластина из акрила с восковым валиком для регистрации прикуса. В отличие от простого воскового шаблона, здесь основа — жёсткий акриловый базис, повторяющий форму альвеолярного гребня.</p>
            <p>Индивидуальный базис обеспечивает стабильность и точность фиксации, особенно при работе с беззубыми челюстями или большими дефектами зубного ряда.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Полное отсутствие зубов (тотальное протезирование)</li>
              <li>Большие дефекты без передних зубов</li>
              <li>Работы с окклюзионной плоскостью</li>
              <li>Требуется высокая точность фиксации</li>
              <li>Планирование имплантации</li>
              <li>Ортогнатическая хирургия</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Изготовление</h2>
            <p><strong>1. Оттиск:</strong> снимается оттиск челюсти.</p>
            <p><strong>2. Модель:</strong> отливается гипсовая модель.</p>
            <p><strong>3. Базис:</strong> изготавливается индивидуальный акриловый базис по модели.</p>
            <p><strong>4. Валик:</strong> на базис устанавливается восковой валик для прикусывания.</p>
            <p><strong>5. Коррекция:</strong> валик корректируется по высоте и форме.</p>
            <p><strong>6. Фиксация:</strong> пациент прикусывает шаблон.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества жесткого базиса</h3><ul>
              <li><strong>Стабильность</strong> — базис фиксируется на слизистой</li>
              <li><strong>Точность</strong> — выше, чем у воскового шаблона</li>
              <li><strong>Повторяемость</strong> — можно снять и надеть повторно</li>
              <li><strong>Определение ВНЧС</strong> — позволяет установить положение суставов</li>
              <li><strong>Окклюзионная плоскость</strong> — легко определить и скорректировать</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Время</strong> — изготовление занимает больше времени</li>
              <li><strong>Стоимость</strong> — выше, чем у простого шаблона</li>
              <li><strong>Техника</strong> — требуется лабораторный этап</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Определение окклюзионной плоскости</h2>
            <p>Шаблон на жестком базисе позволяет точно определить окклюзионную плоскость — плоскость, по которой смыкаются зубы.</p>
            <p><strong>Критерии правильной окклюзионной плоскости:</strong></p>
            <ul>
              <li>Параллельность Camper's line (линия от козелка уха до крыла носа)</li>
              <li>На уровне средней трети лица</li>
              <li>Симметричность справа и слева</li>
            </ul>
            <p>Исследования показывают, что правильное определение окклюзионной плоскости критически важно для эстетики и функции готовых протезов.</p>
          </section>
          <section class="info-section"><h2>Центрическое соотношение</h2>
            <p>Шаблон на жестком базисе используется для фиксации центрического соотношения — положения, при котором суставные головки находятся в центральном положении относительно суставных ямок.</p>
            <p>Это положение является отправной точкой для:</p>
            <ul>
              <li>Полных съёмных протезов</li>
              <li>Окклюзионных шин</li>
              <li>Реконструкции прикуса</li>
            </ul>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>