---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout 
  title="Лабораторная вкладка — Никитина М.Г."
  description="Лабораторная вкладка в Нижнем Новгороде. Керамическая или композитная вкладка, изготовленная в лаборатории. Цена от 5040 рублей."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/services">Услуги</a>
        <span>/</span>
        <span>Лабораторная вкладка</span>
      </div>
    </nav>
    
    <article class="service-content">
      <div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Лабораторная вкладка</h1>
          <div class="service-header__price">от 5 040 ₽</div>
        </header>
        
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое лабораторная вкладка простыми словами</h2>
            <p>Лабораторная вкладка — это микропротез зуба, который изготавливается в зуботехнической лаборатории по индивидуальному слепку. Это более точная и прочная альтернатива обычной пломбе.</p>
            <p>Вкладка делается на основе цифрового сканирования или слепка зуба. Зубной техник в лаборатории моделирует и изготавливает вкладку с высокой точностью — до 10 микрон.</p>
          </section>
          
          <section class="info-section">
            <h2>Когда нужна лабораторная вкладка</h2>
            <ul>
              <li>Зуб разрушен более чем на 30-50%</li>
              <li>Обычная пломба не выдерживает нагрузки</li>
              <li>Нужна высокая эстетика (передние зубы)</li>
              <li>Восстановление после лечения каналов</li>
              <li>Подготовка к установке коронки</li>
              <li>Альтернатива коронке при сохранённом нерве</li>
            </ul>
          </section>
          
          <section class="info-section">
            <h2>Чем отличается от врачебной вкладки</h2>
            <p><strong>Точность</strong> — лабораторная вкладка изготавливается на точной модели, прилегание идеальное.</p>
            <p><strong>Материалы</strong> — используются более прочные и эстетичные материалы: керамика E-max, диоксид циркония, золото.</p>
            <p><strong>Прочность</strong> — лабораторная вкладка прочнее композитной в 2-3 раза.</p>
            <p><strong>Срок</strong> — требует 1-2 визита (слепок — готовность — установка).</p>
          </section>
          
          <section class="info-section">
            <h2>Материалы вкладок</h2>
            <p><strong>Керамика E-max</strong> — самый эстетичный вариант. Полупрозрачная, имитирует натуральную эмаль. Подходит для передних и боковых зубов.</p>
            <p><strong>Диоксид циркония</strong> — очень прочный, но менее эстетичный (непрозрачный). Для жевательных зубов.</p>
            <p><strong>Композит</strong> — дешевле керамики, хорошая эстетика, но со временем темнеет.</p>
            <p><strong>Золото</strong> — для тех, кто хочет максимальную прочность и долговечность. Стоит дорого, но служит всю жизнь.</p>
          </section>
          
          <div class="info-grid">
            <section class="info-block info-block--pros">
              <h3>Преимущества</h3>
              <ul>
                <li><strong>Идеальная точность</strong> — цифровое планирование и изготовление</li>
                <li><strong>Прочность</strong> — служит 15-20 лет</li>
                <li><strong>Эстетика</strong> — керамика неотличима от зуба</li>
                <li><strong>Минимальная обработка</strong> — сохраняется больше собственных тканей зуба</li>
                <li><strong>Биосовместимость</strong> — керамика и цирконий не вызывают аллергии</li>
                <li><strong>Не меняет цвет</strong> — не окрашивается от кофе и чая</li>
              </ul>
            </section>
            
            <section class="info-block info-block--cons">
              <h3>Что учитывать</h3>
              <ul>
                <li><strong>Сроки</strong> — требует 1-2 недели на изготовление</li>
                <li><strong>Визиты</strong> — минимум 2 визита (слепок + установка)</li>
                <li><strong>Стоимость</strong> — дороже композитной пломбы</li>
                <li><strong>Ремонт</strong> — при сколе нужно переделывать</li>
              </ul>
            </section>
          </div>
          
          <section class="info-section">
            <h2>Как делается</h2>
            <p><strong>1. Подготовка</strong> — врач удаляет кариес, формирует полость под вкладку.</p>
            <p><strong>2. Снятие слепка</strong> — внутриротовым сканером или силиконовой массой.</p>
            <p><strong>3. Цвет</strong> — подбирается цвет под соседние зубы.</p>
            <p><strong>4. Временная пломба</strong> — на период изготовления ставится временная.</p>
            <p><strong>5. Изготовление</strong> — техник моделирует вкладку в CAD/CAM системе.</p>
            <p><strong>6. Примерка и фиксация</strong> — вкладка примеряется и цементируется на постоянный цемент.</p>
          </section>
          
          <section class="info-section">
            <h2>Уход</h2>
            <ul>
              <li>Чистить зубы два раза в день</li>
              <li>Использовать зубную нить</li>
              <li>Не жевать твёрдые предметы</li>
              <li>Раз в полгода — осмотр у стоматолога</li>
            </ul>
          </section>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card__value">5 040 ₽</div>
              <div class="stat-card__label">от стоимость</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1-2 недели</div>
              <div class="stat-card__label">срок изготовления</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">15-20 лет</div>
              <div class="stat-card__label">срок службы</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">до 10 мкм</div>
              <div class="stat-card__label">точность изготовления</div>
            </div>
          </div>
        </div>
        
        <div class="service-cta">
          <p>Хотите узнать больше о лабораторных вкладках?</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Написать в Telegram</a>
          </div>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>