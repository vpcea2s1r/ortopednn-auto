.material-card h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-sm); font-weight: 600; }
.material-card p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: var(--space-sm); font-size: var(--text-sm); }
.material-card ul { padding-left: var(--space-md); }
.material-card li { color: var(--color-text-muted); font-size: var(--text-sm); margin-bottom: 2px; }

.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: var(--space-lg); margin-bottom: var(--space-xl); }
.stat-card { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-xl); border-radius: var(--radius-xl); text-align: center; }
