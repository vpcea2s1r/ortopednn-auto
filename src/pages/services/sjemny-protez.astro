.info-section { margin-bottom: var(--space-2xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); font-weight: 600; }
.info-section p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); }
.info-section ul { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.7; }
