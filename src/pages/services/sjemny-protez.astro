.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 2px solid var(--color-primary); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); font-weight: 700; }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); white-space: nowrap; }
