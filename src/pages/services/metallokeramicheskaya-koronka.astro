---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Металлокерамическая коронка | Никитина М.Г." description="Металлокерамическая коронка — классическое решение для восстановления зуба. Цена от 9 000 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Металлокерамическая коронка</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Металлокерамическая коронка</h1>
          <div class="service-header__price">от 9 000 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое металлокерамическая коронка</h2>
            <p>Металлокерамическая коронка — это несъёмная ортопедическая конструкция, состоящая из металлического каркаса и керамического покрытия. Каркас обеспечивает прочность, а керамика — эстетику.</p>
            <p>Это проверенный десятилетиями метод восстановления сильно разрушенных зубов. Коронка полностью закрывает видимую часть зуба, защищая его от дальнейшего разрушения.</p>
          </section>
          <section class="info-section">
            <h2>Показания к установке</h2>
            <ul>
              <li>Разрушение зуба более чем на 50%</li>
              <li>Трещины и сколы эмали</li>
              <li>Пломбирование невозможно или нецелесообразно</li>
              <li>Изменение цвета зуба</li>
              <li>Аномалии формы зуба</li>
              <li>Опорные зубы для мостовидного протеза</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Структура коронки</h2>
            <p><strong>Каркас:</strong> металлический сплав (кобальт-хром или драгоценные металлы). Обеспечивает прочность и долговечность.</p>
            <p><strong>Керамическое покрытие:</strong> наносится на каркас послойно, запекается в печи. Имитирует цвет и прозрачность натурального зуба.</p>
            <p><strong>Край коронки:</strong> может быть металлическим или облицованным керамикой (для эстетики).</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества металлокерамики</h3><ul>
              <li><strong>Прочность</strong> — выдерживает значительную жевательную нагрузку</li>
              <li><strong>Долговечность</strong> — срок службы 10-15 лет</li>
              <li><strong>Эстетика</strong> — цвет можно подобрать к соседним зубам</li>
              <li><strong>Цена</strong> — доступнее цельнокерамических коронок</li>
              <li><strong>Ремонт</strong> — можно корректировать прямо во рту</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Обточка</strong> — требуется препарирование зуба</li>
              <li><strong>Металл</strong> — возможна аллергия на сплав</li>
              <li><strong>Эстетика</strong> — может просвечивать металл у десны</li>
              <li><strong>Прозрачность</strong> — ниже, чем у безметалловых коронок</li>
            </ul></section>
<div class="materials-grid">
            <h2 class="section-title">Виды металлокерамических коронок</h2>
            <div class="materials-cards">
              <div class="material-card">
                <div class="material-card__header"><span class="material-icon">🔩</span><h3>Стандартная</h3></div>
                <div class="material-card__body">
                  <p>Классический вариант с кобальт-хромовым каркасом.</p>
                  <ul>
                    <li>Каркас: Co-Cr сплав</li>
                    <li>Керамика: классическая облицовка</li>
                    <li>Срок: 10-15 лет</li>
                    <li>Цена: средняя</li>
                  </ul>
                </div>
              </div>
              <div class="material-card">
                <div class="material-card__header"><span class="material-icon">🥇</span><h3>На золоте</h3></div>
                <div class="material-card__body">
                  <p>Каркас из золото-платинового сплава с керамикой.</p>
                  <ul>
                    <li>Каркас: Au-Pt сплав</li>
                    <li>Биосовместимость: высокая</li>
                    <li>Эстетика: тёплый оттенок</li>
                    <li>Срок: 15-20 лет</li>
                  </ul>
                </div>
              </div>
              <div class="material-card">
                <div class="material-card__header"><span class="material-icon">⚡</span><h3>С плечевой массой</h3></div>
                <div class="material-card__body">
                  <p>Керамическая «плечевая масса» на краях коронки.</p>
                  <ul>
                    <li>Без металла на десневом крае</li>
                    <li>Эстетика: лучше у десны</li>
                    <li>Прочность: усиленная</li>
                    <li>Рекомендуется для передних зубов</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card__value">9 000 ₽</div>
              <div class="stat-card__label">стандартная коронка</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">12 000 ₽</div>
              <div class="stat-card__label">с плечевой массой</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">10-15 лет</div>
              <div class="stat-card__label">срок службы</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">7-10 дней</div>
              <div class="stat-card__label">срок изготовления</div>
            </div>
          </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Подготовка зуба:</strong> обточка под коронку, формирование уступа.</p>
            <p><strong>2. Снятие слепков:</strong> рабочий и вспомогательный.</p>
            <p><strong>3. Изготовление каркаса:</strong> литьё или фрезерование металлического каркаса.</p>
            <p><strong>4. Примерка каркаса:</strong> проверка посадки на зубе.</p>
            <p><strong>5. Нанесение керамики:</strong> послойное нанесение и запекание.</p>
            <p><strong>6. Финишная обработка:</strong> глазурование, полировка.</p>
            <p><strong>7. Фиксация:</strong> на постоянный цемент.</p>
          </section>
          <section class="info-section"><h2>Правила ухода</h2>
            <ul>
              <li>Чистить зубы два раза в день щёткой и пастой</li>
              <li>Использовать зубную нить в области коронок</li>
              <li>Ежегодно — профессиональная чистка у стоматолога</li>
              <li>Не грызть твёрдые предметы (орехи, леденцы)</li>
              <li>При бруксизме — ночная защитная каппа</li>
              <li>Раз в полгода — осмотр и рентген-контроль</li>
            </ul>
          </section>
        </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Подготовка:</strong> лечение зуба, пломбирование каналов при необходимости.</p>
            <p><strong>2. Обточка:</strong> снятие слоя тканей для коронки.</p>
            <p><strong>3. Снятие слепков:</strong> точное моделирование.</p>
            <p><strong>4. Временная коронка:</strong> защита зуба на время изготовления.</p>
            <p><strong>5. Изготовление:</strong> в лаборатории создаётся металлокерамика.</p>
            <p><strong>6. Примерка и фиксация:</strong> корректировка, цементирование.</p>
          </section>
          <section class="info-section"><h2>Уход за коронкой</h2>
            <p>Чистите зубы дважды в день щёткой и флоссом. Особое внимание уделяйте области на границе коронки и десны. Посещайте стоматолога дважды в год для осмотра и профессиональной чистки.</p>
            <p>Избегайте чрезмерной нагрузки (открывание бутылок, разгрызание орехов). При правильном уходе коронка прослужит 10-15 лет.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>