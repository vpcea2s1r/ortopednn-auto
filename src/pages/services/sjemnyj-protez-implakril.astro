---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Съемный протез из Имплакрила | Никитина М.Г." description="Съёмный протез из материала Имплакрил — гипоаллергенный, комфортный, термопластичный. Цена 41 400 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Съёмный протез из Имплакрила</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Съёмный протез из Имплакрила</h1>
          <div class="service-header__price">41 400 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое Имплакрил</h2>
            <p>Имплакрил (Implacril) — это термопластичный акриловый материал для съёмных зубных протезов. При нагревании до 70-80°C размягчается и принимает нужную форму, при охлаждении застывает. Не содержит мономера — гипоаллергенен.</p>
            <p>Имплакрил мягче обычного акрила (~60 единиц по Шору D против 80-85), что делает протез комфортнее для чувствительной слизистой. Процесс перебазировки можно повторять многократно.</p>
          </section>

          <section class="info-section">
            <h2>Кому подходит</h2>
            <ul>
              <li>Частичная или полная адентия — отсутствие части или всех зубов</li>
              <li>Непереносимость обычного акрила (аллергия на мономер)</li>
              <li>Болезненная, атрофированная слизистая</li>
              <li>Пожилые пациенты с хрупкой слизистой</li>
              <li>Пациенты с бруксизмом — мягкий слой амортизирует</li>
              <li>После хирургических вмешательств — возможность коррекции</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Виды съёмных протезов из Имплакрила</h2>
            <div class="materials-grid">
              <div class="material-card material-card--featured">
                <h3>Частичный</h3>
                <div class="material-price">при частичном отсутствии</div>
                <ul>
                  <li>Замещает несколько отсутствующих зубов</li>
                  <li>Опора на оставшиеся зубы и слизистую</li>
                  <li>Кламмерная фиксация</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Полный</h3>
                <div class="material-price">при полном отсутствии</div>
                <ul>
                  <li>Замещает все зубы одной или обеих челюстей</li>
                  <li>Держится на эффекте присоски</li>
                  <li>Имплакрил мягче акрила — лучше прилегание</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Свойства Имплакрила</h2>
            <p><strong>Термопластичность:</strong> размягчается при 70-80°C, моделируется вручную. При охлаждении застывает. Цикл можно повторять многократно — корректировать форму протеза.</p>
            <p><strong>Биосовместимость:</strong> не содержит мономера — аллергия крайне редка. Главное преимущество перед обычным акрилом.</p>
            <p><strong>Эластичность:</strong> мягче обычного акрила. Комфортнее при чувствительной слизистой, меньше натирает.</p>
            <p><strong>Ремонтопригодность:</strong> при изменении формы слизистой — повторный нагрев и перебазировка. Можно корректировать многократно.</p>
            <p><strong>Цвет:</strong> розовый, имитирует слизистую оболочку. Полупрозрачный — сквозь него видна модель.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества</h3><ul>
              <li><strong>Гипоаллергенность</strong> — без мономера</li>
              <li><strong>Комфорт</strong> — мягче обычного акрила, не давит</li>
              <li><strong>Можно перебазировать</strong> — термопластичность</li>
              <li><strong>Хорошая фиксация</strong> — эластичность помогает прилеганию</li>
              <li><strong>Эстетика</strong> — розовый цвет, имитирует десну</li>
              <li><strong>Ремонт</strong> — приварка зуба возможна</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — дороже обычного акрила</li>
              <li><strong>Прочность</strong> — ниже, чем у обычного акрила</li>
              <li><strong>Не для всех</strong> — при хорошей слизистой акрил достаточен</li>
              <li><strong>Требуется нагрев</strong> — для перебазировки</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Этапы изготовления</h2>
            <p><strong>1. Консультация:</strong> осмотр, обсуждение плана, снятие оттисков.</p>
            <p><strong>2. Оттиски:</strong> снятие слепков для диагностических моделей.</p>
            <p><strong>3. Модели:</strong> изготовление рабочих моделей в лаборатории.</p>
            <p><strong>4. Примерка:</strong> проверка посадки, окклюзии, эстетики.</p>
            <p><strong>5. Готовый протез:</strong> полировка, передача пациенту.</p>
            <p><strong>6. Коррекция:</strong> при необходимости — подточка в местах натиска.</p>
          </section>

          <section class="info-section">
            <h2>Уход за протезом из Имплакрила</h2>
            <p><strong>Температура:</strong> не используйте кипяток — Имплакрил деформируется. Максимум — тёплая вода (до 50°C).</p>
            <p><strong>Чистка:</strong> мягкая щётка + специальные средства для протезов. Не абразивные пасты.</p>
            <p><strong>Хранение:</strong> в воде или контейнере. Не сушить на батарее.</p>
            <p><strong>Коррекция:</strong> при изменении слизистой — перебазировка нагревом. Обратитесь к врачу.</p>
            <p><strong>Профосмотр:</strong> раз в полгода — проверка состояния протеза и слизистой.</p>
          </section>

          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card__value">5-7</div>
              <div class="stat-card__label">дней на изготовление</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">3-5</div>
              <div class="stat-card__label">визитов</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">до 5</div>
              <div class="stat-card__label">лет срок службы</div>
            </div>
          </div>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.materials-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-md); margin-bottom: var(--space-xl); }
.material-card { background: white; padding: var(--space-md); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.material-card--featured { border-color: var(--color-primary); background: linear-gradient(to bottom, white, var(--color-bg-alt)); }
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); margin-bottom: var(--space-xl); }
.stat-card { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); text-align: center; }
.stat-card__value { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); }
.stat-card__label { font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-xs); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .stats-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>