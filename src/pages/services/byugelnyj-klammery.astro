---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Бюгельный протез на кламмерах | Никитина М.Г." description="Бюгельный протез на кламмерах ДенталДи — прочное и комфортное решение. Цена от 52 200 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Бюгельный протез на кламмерах</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Бюгельный протез на кламмерах</h1>
          <div class="service-header__price">от 52 200 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое бюгельный протез на кламмерах</h2>
            <p>Бюгельный протез на кламмерах — это съёмная конструкция с металлическим каркасом (дугой) и крючками (кламмерами) для фиксации на опорных зубах. Это классический и наиболее распространённый вид бюгельного протезирования.</p>
            <p>Кламмеры обхватывают опорные зубы и удерживают протез на месте. Это обеспечивает надёжную фиксацию без сложных замковых систем.</p>
          </section>

          <section class="info-section">
            <h2>Сравнение типов бюгельных протезов</h2>
            <div class="materials-grid">
              <div class="material-card material-card--featured">
                <h3>Кламмеры (рекомендуем)</h3>
                <div class="material-price">от 52 200 ₽</div>
                <ul>
                  <li>Металлические крючки</li>
                  <li>Простая конструкция</li>
                  <li>Ремонтопригодность</li>
                  <li>Срок 5-7 лет</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Замки (аттачмены)</h3>
                <div class="material-price">от 65 000 ₽</div>
                <ul>
                  <li>Эстетичнее</li>
                  <li>Надёжная фиксация</li>
                  <li>Обточка под коронки</li>
                  <li>Срок 7-10 лет</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Телескопические</h3>
                <div class="material-price">от 80 000 ₽</div>
                <ul>
                  <li>Максимальная эстетика</li>
                  <li>Сложная конструкция</li>
                  <li>Дорогой</li>
                  <li>Срок 10-15 лет</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Нейлоновый</h3>
                <div class="material-price">от 41 400 ₽</div>
                <ul>
                  <li>Гибкий и мягкий</li>
                  <li>Без металла</li>
                  <li>Эстетичный</li>
                  <li>Срок 3-5 лет</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Показания к применению</h2>
            <ul>
              <li>Частичное отсутствие зубов (от 2 и более)</li>
              <li>Невозможность установки мостовидного протеза</li>
              <li>Отсутствие концевых зубов (не на что закрепить мост)</li>
              <li>Желание сохранить оставшиеся зубы (не нужно обтачивать)</li>
              <li>Нужна съёмная конструкция при наличии противопоказаний к имплантации</li>
              <li>Достаточное количество и качество опорных зубов</li>
              <li>Пародонтит — бюгель можно использовать как шину</li>
              <li>Ограниченный бюджет</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Устройство бюгельного протеза на кламмерах</h2>
            <p><strong>Дуга (бюгель):</strong> металлический каркас в форме дуги. Обеспечивает жёсткость и распределение жевательной нагрузки между опорными зубами и слизистой. Толщина 0.8-1.5 мм. Изготавливается из кобальт-хромового сплава или титана.</p>
            <p><strong>Кламмеры (крючки):</strong> элементы фиксации, которые обхватывают опорные зубы. Бывают удерживающие (многозвеньевые) и опорные (окклюзионные). Классические кламмеры Роуча — самый распространённый тип.</p>
            <p><strong>Базис:</strong> пластмассовая часть розового цвета, имитирующая десну. Крепится к дуге и несёт искусственные зубы.</p>
            <p><strong>Искусственные зубы:</strong> керамика, композиты или пластмасса. Подбираются по цвету и форме.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества</h3><ul>
              <li><strong>Надёжность</strong> — проверенная десятилетиями конструкция</li>
              <li><strong>Равномерная нагрузка</strong> — дуга распределяет давление на зубы и слизистую</li>
              <li><strong>Сохранение зубов</strong> — опорные зубы не нужно обтачивать</li>
              <li><strong>Долговечность</strong> — срок службы 5-7 лет</li>
              <li><strong>Ремонтопригодность</strong> — можно корректировать и чинить</li>
              <li><strong>Доступная цена</strong> — дешевле замковых и телескопических систем</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Видимость</strong> — металлические кламмеры могут быть заметны</li>
              <li><strong>Металл</strong> — возможна аллергия на кобальт-хром</li>
              <li><strong>Адаптация</strong> — требуется время на привыкание (1-2 недели)</li>
              <li><strong>Передача нагрузки</strong> — часть нагрузки на опорные зубы может их расшатывать</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Статистика и показатели</h2>
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-value">5-7</div>
                <div class="stat-label">лет срок службы</div>
                <div class="stat-desc">при правильном уходе</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">0.8-1.5</div>
                <div class="stat-label">мм толщина дуги</div>
                <div class="stat-desc">кобальт-хром сплав</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">75%</div>
                <div class="stat-label">всех бюгелей</div>
                <div class="stat-desc">на кламмерах</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">2-4</div>
                <div class="stat-label">недели адаптация</div>
                <div class="stat-desc">до полного комфорта</div>
              </div>
            </div>
          </section>

          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Обследование:</strong> осмотр полости рта, оценка состояния зубов и слизистой, рентген.</p>
            <p><strong>2. Подготовка:</strong> лечение опорных зубов при необходимости (кариес, пульпит).</p>
            <p><strong>3. Снятие слепков:</strong> точное моделирование обеих челюстей.</p>
            <p><strong>4. Изготовление каркаса:</strong> отливка металлической дуги и кламмеров в лаборатории.</p>
            <p><strong>5. Примерка каркаса:</strong> проверка посадки дуги и кламмеров на зубах.</p>
            <p><strong>6. Постановка зубов:</strong> на каркас крепятся искусственные зубы на восковом базисе.</p>
            <p><strong>7. Примерка и корректировка:</strong> проверка прикуса, эстетики, комфорта.</p>
            <p><strong>8. Готовый протез:</strong> замена воска на акрил, финишная обработка, полировка.</p>
            <p><strong>9. Установка:</strong> фиксация, обучение пациента.</p>
          </section>

          <section class="info-section"><h2>Уход за бюгельным протезом</h2>
            <p><strong>После еды:</strong> промывайте протез водой, очищайте от остатков пищи.</p>
            <p><strong>Чистка:</strong> мягкая зубная щётка + специальные средства для протезов. Не абразивные пасты.</p>
            <p><strong>На ночь:</strong> можно снимать и хранить в воде или контейнере. Первое время — носить постоянно.</p>
            <p><strong>Ограничения:</strong> не грызть твёрдую пищу (орехи, сухари, карамель).</p>
            <p><strong>Осмотры:</strong> каждые 6 месяцев — проверка кламмеров и своевременная корректировка.</p>
            <p><strong>Профессиональная чистка:</strong> раз в год — ультразвуковая чистка протеза.</p>
          </section>
          <section class="info-section">
            <h2>Показания к применению</h2>
            <ul>
              <li>Частичное отсутствие зубов (2 и более)</li>
              <li>Невозможность установки мостовидного протеза</li>
              <li>Отсутствие концевых зубов</li>
              <li>Желание сохранить оставшиеся зубы</li>
              <li>Нужна съёмная конструкция</li>
              <li>Достаточное количество опорных зубов</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Особенности протеза на кламмерах</h2>
            <p><strong>Дуга (бюгель):</strong> обеспечивает жёсткость и распределение нагрузки.</p>
            <p><strong>Кламмеры:</strong> крючки из кобальт-хромового сплава или нейлона.</p>
            <p><strong>Базис:</strong> акриловый или термопластичный, розового цвета.</p>
            <p><strong>Искусственные зубы:</strong> керамика или композиту.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества</h3><ul>
              <li><strong>Надёжность</strong> — проверенная десятилетиями конструкция</li>
              <li><strong>Равномерная нагрузка</strong> — дуга распределяет давление</li>
              <li><strong>Сохранение зубов</strong> — опорные зубы не нужно обтачивать</li>
              <li><strong>Долговечность</strong> — срок службы 5-7 лет</li>
              <li><strong>Ремонтопригодность</strong> — можно корректировать</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Видимость</strong> — кламмеры могут быть заметны</li>
              <li><strong>Металл</strong> — возможна аллергия на сплав</li>
              <li><strong>Адаптация</strong> — требуется время на привыкание</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Обследование:</strong> оценка состояния зубов и слизистой.</p>
            <p><strong>2. Подготовка:</strong> лечение опорных зубов при необходимости.</p>
            <p><strong>3. Снятие слепков:</strong> точное моделирование.</p>
            <p><strong>4. Изготовление:</strong> каркас, базис, искусственные зубы.</p>
            <p><strong>5. Примерка и установка:</strong> корректировка и фиксация.</p>
          </section>
          <section class="info-section"><h2>Уход за бюгельным протезом</h2>
            <p>Очищайте протез после еды, промывая водой. Используйте мягкую щётку и специальные средства. На ночь можно снимать и хранить в сухом контейнере или воде.</p>
            <p>Не рекомендуется грызть твёрдую пищу (орехи, сухари). Посещайте стоматолога для проверки кламмеров и своевременной корректировки.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }

.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.material-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.material-card--featured {
  border-color: var(--color-primary);
  background: linear-gradient(to bottom, white, var(--color-bg-alt));
}
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.stat-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  text-align: center;
}
.stat-value { font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); }
.stat-label { font-size: var(--text-sm); color: var(--color-text); font-weight: 600; margin-top: var(--space-xs); }
.stat-desc { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: 2px; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>