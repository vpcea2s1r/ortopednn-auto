---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout 
  title="Винир на рефракторе — Никитина М.Г."
  description="Виниры на рефракторе в Нижнем Новгороде. Максимальная эстетика для идеальной улыбки. Цена от 39000 рублей."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/services">Услуги</a>
        <span>/</span>
        <span>Винир на рефракторе</span>
      </div>
    </nav>
    
    <article class="service-content">
      <div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Винир на рефракторе</h1>
          <div class="service-header__price">от 39 000 ₽</div>
        </header>
        
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое винир на рефракторе простыми словами</h2>
            <p>Винир на рефракторе — это особый вид керамического винира, который изготавливается на специальной модели (рефракторе). Это позволяет добиться максимальной точности и эстетики.</p>
            <p>Рефрактор — это модель из огнеупорного материала, на которой можно многократно запекать керамику при высоких температурах. Каждый слой керамики спекается, добавляется новый, и так достигается идеальная форма и цвет.</p>
          </section>
          
          <section class="info-section">
            <h2>Чем отличается от обычного винира E-MAX</h2>
            <p><strong>Технология</strong> — рефракторная техника позволяет послойно наносить керамику и запекать при 900°C. Это даёт более плотную и однородную структуру.</p>
            <p><strong>Эстетика</strong> — можно создать сложные градиенты цвета, эффекты опалесценции, как у натуральных зубов.</p>
            <p><strong>Прочность</strong> — многократное запекание делает керамику более прочной.</p>
            <p><strong>Точность</strong> — каждый слой проверяется, корректируется, шлифуется.</p>
          </section>
          
          <section class="info-section">
            <h2>Когда выбирают виниры на рефракторе</h2>
            <ul>
              <li>Требовательные пациенты, желающие максимальную эстетику</li>
              <li>Сложные случаи с изменением цвета (тетрациклин, флюороз)</li>
              <li>Виниры на всю переднюю группу зубов</li>
              <li>Пациенты с высокими эстетическими требованиями</li>
              <li>Когда обычные виниры не дают нужного результата</li>
            </ul>
          </section>
          
          <div class="info-grid">
            <section class="info-block info-block--pros">
              <h3>Преимущества</h3>
              <ul>
                <li><strong>Идеальная эстетика</strong> — неотличим от натуральных зубов</li>
                <li><strong>Градиенты цвета</strong> — можно сделать плавные переходы оттенков</li>
                <li><strong>Прочность</strong> — многократное запекание укрепляет керамику</li>
                <li><strong>Точность</strong> — идеальное прилегание к зубу</li>
                <li><strong>Долговечность</strong> — служит 15-20 лет</li>
                <li><strong>Стабильность цвета</strong> — не меняет оттенок со временем</li>
              </ul>
            </section>
            
            <section class="info-block info-block--cons">
              <h3>Что учитывать</h3>
              <ul>
                <li><strong>Стоимость</strong> — дороже стандартных виниров</li>
                <li><strong>Сроки</strong> — требует больше лабораторного времени (3-5 дней)</li>
                <li><strong>Требования</strong> — нужен опытный зубной техник</li>
                <li><strong>Обточка</strong> — требуется препарирование зуба</li>
              </ul>
            </section>
          </div>
          
          <section class="info-section">
            <h2>Как изготавливается</h2>
            <p><strong>1. Подготовка</strong> — обточка зуба, снятие слепков.</p>
            <p><strong>2. Модель</strong> — изготовление рефрактора (модели из огнеупорного материала).</p>
            <p><strong>3. Каркас</strong> — первый слой керамики запекается на модели.</p>
            <p><strong>4. Послойное нанесение</strong> — каждый слой спекается при высокой температуре.</p>
            <p><strong>5. Корректировка</strong> — после каждого запекания техник шлифует и оценивает результат.</p>
            <p><strong>6. Глазурование</strong> — финишный слой для блеска и защиты.</p>
            <p><strong>7. Фиксация</strong> — винир приклеивается на специальный цемент.</p>
          </section>
          
          <section class="info-section">
            <h2>Срок службы</h2>
            <p>Виниры на рефракторе служат 15-25 лет при правильном уходе. Это самый долговечный вид эстетических реставраций.</p>
          </section>
        </div>
        
        <div class="service-cta">
          <p>Хотите идеальную улыбку? Запишитесь на консультацию.</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Написать в Telegram</a>
          </div>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>