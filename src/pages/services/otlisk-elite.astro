---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Двухслойные оттиски Elite | Никитина М.Г." description="Двухслойные оттиски материалом Elite. Высокая точность для сложных работ. Цена 1 800 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Снятие двухслойных оттисков Elite</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Двухслойные оттиски Elite</h1>
          <div class="service-header__price">1 800 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое двухслойный оттиск Elite</h2>
            <p>Elite — линейка А-силиконовых материалов от Zhermack, специально разработанная для стоматологических оттисков. Двухслойная техника с использованием Elite обеспечивает исключительную точность воспроизведения тканей полости рта.</p>
            <p>Elite представлен несколькими консистенциями: Maxi (базовый), Regular, Medium, Light, Putty — что позволяет подобрать оптимальную комбинацию для любой клинической ситуации.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Эстетические реставрации (виниры, коронки)</li>
              <li>Сложные мостовидные протезы</li>
              <li>Работы на имплантатах</li>
              <li>Бюгельное протезирование</li>
              <li>Точные работы с уступами</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Особенности Elite</h2>
            <p><strong>Гидрофильность:</strong> Elite имеет улучшенную гидрофильность по сравнению со стандартными PVS. Это важно при снятии оттисков во влажной среде полости рта.</p>
            <p><strong>Тиксотропность:</strong> материал легко течёт, но не стекает, что обеспечивает хорошее затекание в поднутрения и межзубные промежутки.</p>
            <p><strong>Комфорт:</strong> мягкая консистенция снижает дискомфорт для пациента при фиксации ложки.</p>
            <p><strong>Точность:</strong> детализация до 25 микрон гарантирует высокое качество готовых конструкций.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества Elite</h3><ul>
              <li><strong>Высокая точность</strong> — детализация до 25 микрон</li>
              <li><strong>Стабильность</strong> — не даёт усадки, хранится неделями</li>
              <li><strong>Гидрофильность</strong> — хорошее смачивание тканей</li>
              <li><strong>Эластичность</strong> — лёгкое снятие без деформации</li>
              <li><strong>Биосовместимость</strong> — гипоаллергенный материал</li>
              <li><strong>Простота</strong> — лёгкое замешивание и внесение</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — дороже альгината, но точность соответствует</li>
              <li><strong>Техника</strong> — требует двухэтапного протокола</li>
              <li><strong>Время</strong> — больше, чем одноэтапные материалы</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Протокол двухслойного оттиска</h2>
            <p><strong>1. Подготовка:</strong> подбор ложки, нанесение адгезива.</p>
            <p><strong>2. Базовый слой:</strong> Elite Maxi или Regular наносится на ложку, формируя основу.</p>
            <p><strong>3. Первная фиксация:</strong> ложка вводится в рот на 60 секунд.</p>
            <p><strong>4. Корректирующий слой:</strong> после удаления первого слоя наносится Elite Light вокруг области препарирования.</p>
            <p><strong>5. Финальная фиксация:</strong> ложка возвращается на 3-4 минуты до полной полимеризации.</p>
            <p><strong>6. Снятие и оценка:</strong> проверка качества оттиска, отсутствие дефектов.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>