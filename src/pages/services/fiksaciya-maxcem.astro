---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Фиксация коронки Maxcem | Никитина М.Г." description="Фиксация коронок на самопротравливающий композитный цемент Maxcem. Цена 1 320 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Фиксация коронки Maxcem</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Фиксация коронки Maxcem</h1>
          <div class="service-header__price">1 320 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое Maxcem</h2>
            <p>Maxcem — самопротравливающий адгезивный композитный цемент от Kerr. Один из первых самопротравливающих цементов, который значительно упростил протокол фиксации.</p>
            <p>Maxcem не требует отдельного протравливания и адгезива — он сам протравливает поверхность и связывается с тканями зуба. Это сокращает время процедуры и снижает риск ошибок.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Фиксация цельнокерамических коронок и виниров</li>
              <li>Фиксация металлокерамических коронок</li>
              <li>Фиксация циркониевых коронок</li>
              <li>Фиксация вкладок и накладок</li>
              <li>Цементирование штифтов</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Линейка Maxcem</h2>
            <p><strong>Maxcem:</strong> оригинальный самопротравливающий цемент. Прозрачный, голубой, розовый, жёлтый оттенки.</p>
            <p><strong>Maxcem Elite:</strong> обновлённая формула с улучшенными свойствами. Лучше текучесть, выше прочность.</p>
            <p><strong>Maxcem Elite Glow:</strong> флуоресцентный вариант для эстетических зон.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества Maxcem</h3><ul>
              <li><strong>Простота</strong> — один этап, без протравливания и адгезива</li>
              <li><strong>Экономия времени</strong> — быстрее классических систем</li>
              <li><strong>Прочность</strong> — высокая адгезия к эмали и дентину</li>
              <li><strong>Эстетика</strong> — полупрозрачность для естественного вида</li>
              <li><strong>Биосовместимость</strong> — без эвгенола, гипоаллергенен</li>
              <li><strong>Рентгеноконтрастность</strong> — виден на снимках</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Влажность</strong> — требует контролируемой влажности</li>
              <li><strong>Толщина</strong> — не для конструкций с большими зазорами</li>
              <li><strong>Цена</strong> — дороже стеклоиономеров</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Протокол фиксации Maxcem</h2>
            <p><strong>1. Изоляция:</strong> коффердам.</p>
            <p><strong>2. Очистка:</strong> промывание, высушивание.</p>
            <p><strong>3. Подготовка конструкции:</strong> внутренняя поверхность обрабатывается праймером (входит в комплект).</p>
            <p><strong>4. Нанесение цемента:</strong> тонкий слой на внутреннюю поверхность.</p>
            <p><strong>5. Фиксация:</strong> коронка надевается.</p>
            <p><strong>6. Полимеризация:</strong> 10-20 секунд на каждую поверхность.</p>
            <p><strong>7. Удаление излишков:</strong> после полимеризации.</p>
          </section>
          <section class="info-section"><h2>Сравнение с другими цементами</h2>
            <p><strong>Maxcem vs Fuji:</strong> Maxcem прочнее и эстетичнее, но требует более точного препарирования. Fuji проще и прощает погрешности.</p>
            <p><strong>Maxcem vs Panavia:</strong> Panavia — более универсальный цемент с отдельным адгезивом. Maxcem — быстрее и проще.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>