---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Временная фиксация Temp-Bond | Никитина М.Г." description="Временная фиксация коронок и протезов цементом Temp-Bond. Цена 350 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Временная фиксация Temp-Bond</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Временная фиксация Temp-Bond</h1>
          <div class="service-header__price">350 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое Temp-Bond</h2>
            <p>Temp-Bond — непостоянный (временный) цемент производства Keystone Dental. Используется для фиксации временных конструкций и пробного ношения постоянных.</p>
            <p>Временная фиксация позволяет снять конструкцию при необходимости без повреждения. Это важно для диагностики, коррекции прикуса, оценки эстетики и комфорта.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Временные коронки на период изготовления постоянных</li>
              <li>Пробное ношение постоянных коронок (try-in)</li>
              <li>Тестирование окклюзии и эстетики</li>
              <li>Пациенты с риском аллергии (пробная фиксация)</li>
              <li>Мостовидные протезы на время лабораторного этапа</li>
              <li>Фиксация на имплантатах на время приживления</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Формы выпуска</h2>
            <p><strong>Temp-Bond NE (Non-Eugenol):</strong> без эвгенола. Рекомендуется для пациентов с аллергией на эвгенол и когда важна адгезия.</p>
            <p><strong>Temp-Bond (с эвгенолом):</strong> классическая формула. Эвгенол обладает успокаивающим действием на пульпу, но может влиять на адгезию последующих композитных материалов.</p>
            <p><strong>Temp-Bond Micro:</strong> пакуется в шприцы для удобства нанесения.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества временной фиксации</h3><ul>
              <li><strong>Обратимость</strong> — легко снимается</li>
              <li><strong>Диагностика</strong> — можно оценить комфорт и эстетику</li>
              <li><strong>Тестирование</strong> — проверка конструкции перед постоянной фиксацией</li>
              <li><strong>Защита</strong> — зуб защищён на время ожидания</li>
              <li><strong>Доступность</strong> — низкая стоимость</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Герметичность</strong> — временная фиксация не полностью герметична</li>
              <li><strong>Срок</strong> — не рекомендуется более 2-3 недель</li>
              <li><strong>Микроподвижность</strong> — конструкция может немного смещаться</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Протокол временной фиксации</h2>
            <p><strong>1. Подготовка:</strong> очистка конструкции и культи от назубных отложений.</p>
            <p><strong>2. Высушивание:</strong> культя высушивается (не пересушивать!).</p>
            <p><strong>3. Замешивание:</strong> паста и жидкость смешиваются на блокноте.</p>
            <p><strong>4. Нанесение:</strong> тонкий слой на внутреннюю поверхность коронки.</p>
            <p><strong>5. Фиксация:</strong> коронка надевается, прижимается.</p>
            <p><strong>6. Удаление излишков:</strong> сразу или через 1-2 минуты.</p>
            <p><strong>7. Проверка:</strong> конструкция не должна мешать прикусу.</p>
          </section>
          <section class="info-section"><h2>Как снять конструкцию</h2>
            <p>При необходимости временную конструкцию можно снять:</p>
            <p><strong>Методы:</strong> расшатывание гладилкой у края коронки, ультразвуковое воздействие, специальный инструмент для снятия коронок.</p>
            <p>После снятия цемент легко удаляется с внутренней поверхности коронки и с культи зуба. Зуб не повреждается.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>