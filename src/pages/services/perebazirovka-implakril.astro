---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Перебазировка из Имплакрила | Никитина М.Г." description="Перебазировка протеза материалом Имплакрил — прочный и комфортный базис. Цена 9 600 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Перебазировка из Имплакрила</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Перебазировка из Имплакрила</h1>
          <div class="service-header__price">9 600 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое Имплакрил?</h2>
            <p>Имплакрил (Implacril) — это термопластичный акриловый материал, используемый для перебазировки съёмных протезов. Обладает уникальными свойствами: при нагревании размягчается, принимает форму, при охлаждении застывает в новой форме.</p>
            <p>В отличие от обычного акрила, Имплакрил более пластичен и комфортен. Процесс перебазировки можно повторять многократно — термопластичность позволяет корректировать форму неограниченное число раз. Это особенно ценно для пожилых пациентов с болезненной слизистой.</p>
          </section>

          <section class="info-section">
            <h2>Какие виды перебазировки существуют?</h2>
            <div class="materials-grid">
              <div class="material-card">
                <h3>Имплакрил</h3>
                <div class="material-price">мягкая</div>
                <ul>
                  <li>Размягчается при 70-80°C</li>
                  <li>Комфорт для болезненной слизистой</li>
                  <li>Многократная коррекция</li>
                  <li>Срок 1-2 года</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Врачебная</h3>
                <div class="material-price">быстрая</div>
                <ul>
                  <li>Выполняется в кресле</li>
                  <li>20-40 минут</li>
                  <li>Мягкий или твёрдый акрил</li>
                  <li>Срок 1-2 года</li>
                </ul>
              </div>
              <div class="material-card material-card--featured">
                <h3>Лабораторная</h3>
                <div class="material-price">точная</div>
                <ul>
                  <li>На новой модели</li>
                  <li>1-2 дня без протеза</li>
                  <li>Максимальная точность</li>
                  <li>Срок 3-5 лет</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Кому подходит Имплакрил</h2>
            <ul>
              <li>Пациенты с болезненной, атрофированной слизистой</li>
              <li>Непереносимость обычного акрила (аллергия на мономер)</li>
              <li>Повторные перебазировки — можно корректировать многократно</li>
              <li>Пациенты с аллергией на мономер</li>
              <li>Комфортное долгосрочное решение</li>
              <li>После хирургических вмешательств (экстракции, имплантация)</li>
              <li>Пациенты с бруксизмом (мягкий слой амортизирует)</li>
              <li>Пожилые пациенты с хрупкой слизистой</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Свойства Имплакрила</h2>
            <p><strong>Термопластичность:</strong> размягчается при 70-80°C в горячей воде, моделируется вручную. При охлаждении застывает. Можно повторять цикл многократно.</p>
            <p><strong>Биосовместимость:</strong> не содержит мономера — аллергия крайне редка. Это главное преимущество перед обычным акрилом.</p>
            <p><strong>Эластичность:</strong> мягче обычного акрила (твёрдость ~60 единиц по Шору D против 80-85 у акрила). Комфортнее для чувствительных слизистых.</p>
            <p><strong>Ремонтопригодность:</strong> можно переделывать и корректировать. При потере формы — повторный нагрев и моделирование.</p>
            <p><strong>Цвет:</strong> розовый, имитирует слизистую оболочку. Полупрозрачный — сквозь него видна модель.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества Имплакрила</h3><ul>
              <li><strong>Комфорт</strong> — мягче обычного акрила, не давит</li>
              <li><strong>Без мономера</strong> — гипоаллергенен</li>
              <li><strong>Можно переделывать</strong> — термопластичность</li>
              <li><strong>Долговечность</strong> — служит 1-2 года до повторной коррекции</li>
              <li><strong>Хорошая фиксация</strong> — эластичность помогает прилеганию</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Ограничения</h3><ul>
              <li><strong>Цена</strong> — дороже обычного акрила</li>
              <li><strong>Требуется нагрев</strong> — специальное оборудование</li>
              <li><strong>Прочность</strong> — ниже, чем у обычного акрила</li>
              <li><strong>Не для всех</strong> — при хорошей слизистой акрил достаточен</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Этапы перебазировки Имплакрилом</h2>
            <p><strong>1. Подготовка:</strong> очистка протеза, проверка состояния базиса.</p>
            <p><strong>2. Нагрев:</strong> Имплакрил размягчается в горячей воде (70-80°C) в течение 5-10 минут.</p>
            <p><strong>3. Формовка:</strong> размягчённый материал вносится на внутреннюю поверхность протеза. Протез надевается на модель или в рот пациента.</p>
            <p><strong>4. Моделирование:</strong> врач формирует равномерный слой, проверяет прилегание.</p>
            <p><strong>5. Охлаждение:</strong> Имплакрил застывает в новой форме (3-5 минут).</p>
            <p><strong>6. Обработка:</strong> обрезка излишков по краям, шлифовка и полировка.</p>
            <p><strong>7. Проверка:</strong> посадка и комфорт. При необходимости — повторный нагрев и корректировка.</p>
          </section>

          <section class="info-section"><h2>Уход за протезом с Имплакрилом</h2>
            <p><strong>Температура:</strong> не используйте кипяток — Имплакрил деформируется. Максимум — тёплая вода (до 50°C).</p>
            <p><strong>Чистка:</strong> мягкая щётка + специальные средства. Не абразивные пасты.</p>
            <p><strong>Хранение:</strong> в воде или контейнере. Не сушить на батарее.</p>
            <p><strong>Коррекция:</strong> при изменении формы слизистой — повторный нагрев и перебазировка. Это можно делать многократно.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Пациенты с болезненной, атрофированной слизистой</li>
              <li>Непереносимость обычного акрила</li>
              <li>Повторные перебазировки</li>
              <li>Пациенты с аллергией на мономер</li>
              <li>Комфортное долгосрочное решение</li>
              <li>После хирургических вмешательств</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Свойства Имплакрила</h2>
            <p><strong>Термопластичность:</strong> размягчается при 70-80°C, моделируется вручную.</p>
            <p><strong>Биосовместимость:</strong> не содержит мономера (аллергия редка).</p>
            <p><strong>Эластичность:</strong> более мягкий, чем обычный акрил.</p>
            <p><strong>Ремонтопригодность:</strong> можно переделывать.</p>
            <p><strong>Цвет:</strong> розовый, имитирует слизистую.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества Имплакрила</h3><ul>
              <li><strong>Комфорт</strong> — мягче обычного акрила</li>
              <li><strong>Без мономера</strong> — гипоаллергенен</li>
              <li><strong>Можно переделывать</strong> — термопластичность</li>
              <li><strong>Долговечность</strong> — служит годами</li>
              <li><strong>Хорошая фиксация</strong> — эластичность помогает</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — дороже обычного акрила</li>
              <li><strong>Требуется нагрев</strong> — специальное оборудование</li>
              <li><strong>Прочность</strong> — ниже, чем у обычного акрила</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Как проходит перебазировка</h2>
            <p><strong>1. Подготовка:</strong> очистка протеза.</p>
            <p><strong>2. Нагрев:</strong> Имплакрил размягчается в горячей воде.</p>
            <p><strong>3. Формовка:</strong> материал вносится в протез, протез надевается на модель/в рот.</p>
            <p><strong>4. Охлаждение:</strong> Имплакрил застывает в новой форме.</p>
            <p><strong>5. Обработка:</strong> обрезка излишков, полировка.</p>
            <p><strong>6. Проверка:</strong> посадка и комфорт.</p>
          </section>
          <section class="info-section"><h2>Сравнение с обычным акрилом</h2>
          <p><strong>Имплакрил:</strong> мягче, гипоаллергенен, ремонтопригоден. Идеален для чувствительных слизистых. Дороже.</p>
          <p><strong>Обычный акрил:</strong> прочнее, дешевле. Может вызывать аллергию на мономер. Более жёсткий.</p>
          <p>Выбор зависит от клинической ситуации и предпочтений пациента. При аллергии или болезненности — Имплакрил. При хорошем здоровье слизистой — обычный акрил достаточен.</p>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }

.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.material-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.material-card--featured { border-color: var(--color-primary); background: linear-gradient(to bottom, white, var(--color-bg-alt)); }
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>