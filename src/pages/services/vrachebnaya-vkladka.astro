---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout 
  title="Врачебная вкладка — Никитина М.Г."
  description="Врачебная вкладка в Нижнем Новгороде. Восстановление зуба пломбировочным материалом. Цена от 3180 рублей."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/services">Услуги</a>
        <span>/</span>
        <span>Врачебная вкладка</span>
      </div>
    </nav>
    
    <article class="service-content">
      <div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Врачебная вкладка</h1>
          <div class="service-header__price">от 3 180 ₽</div>
        </header>
        
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое врачебная вкладка простыми словами</h2>
            <p>Врачебная вкладка — это пломба, которую стоматолог делает прямо во рту пациента за один визит. В отличие от обычной пломбы, вкладка более точная и прочная, потому что врач может лучше контролировать форму.</p>
            <p>Вкладка используется, когда зуб сильно разрушен, но корень ещё цел. Это как "заплатка" на зуб, которая повторяет его форму и функцию.</p>
          </section>
          
          <section class="info-section">
            <h2>Когда нужна врачебная вкладка</h2>
            <ul>
              <li>Зуб разрушен наполовину или больше</li>
              <li>Обычная пломба не держится (зуб слишком хрупкий)</li>
              <li>Нужно восстановить форму зуба после лечения каналов</li>
              <li>Под коронку требуется прочное основание</li>
              <li>Дефект зуба нельзя закрыть обычной пломбой</li>
            </ul>
          </section>
          
          <section class="info-section">
            <h2>Чем отличается от обычной пломбы</h2>
            <p><strong>Прочность</strong> — вкладка делается из прочных материалов (композит, керамика), она монолитная и не даёт усадки.</p>
            <p><strong>Точность</strong> — врач моделирует вкладку на модели зуба, добиваясь идеального прилегания.</p>
            <p><strong>Долговечность</strong> — служит значительно дольше обычной пломбы (10-15 лет против 3-5).</p>
            <p><strong>Эстетика</strong> — можно подобрать цвет под соседние зубы.</p>
          </section>
          
          <div class="info-grid">
            <section class="info-block info-block--pros">
              <h3>Преимущества</h3>
              <ul>
                <li><strong>Один визит</strong> — делается за одно посещение, не нужно ждать лабораторию</li>
                <li><strong>Прочность</strong> — выдерживает жевательную нагрузку</li>
                <li><strong>Точность</strong> — идеально прилегает к стенкам зуба</li>
                <li><strong>Сохраняет зуб</strong> — не требует обточки соседних зубов</li>
                <li><strong>Эстетика</strong> — можно подобрать цвет</li>
                <li><strong>Ремонтопригодность</strong> — можно шлифовать и полировать</li>
              </ul>
            </section>
            
            <section class="info-block info-block--cons">
              <h3>Что учитывать</h3>
              <ul>
                <li><strong>Время</strong> — требует больше времени, чем обычная пломба (1-2 часа)</li>
                <li><strong>Материал</strong> — композит впитывает красители со временем</li>
                <li><strong>Стоимость</strong> — дороже обычной пломбы</li>
                <li><strong>Требования</strong> — нужно хорошее оборудование и навыки врача</li>
              </ul>
            </section>
          </div>
          
          <section class="info-section">
            <h2>Как делается</h2>
            <p><strong>1. Осмотр и подготовка</strong> — врач оценивает зуб, удаляет кариес, обрабатывает полость.</p>
            <p><strong>2. Изоляция</strong> — зуб изолируется от слюны (коффердам).</p>
            <p><strong>3. Нанесение материала</strong> — композитный материал послойно наносится на зуб.</p>
            <p><strong>4. Моделирование</strong> — врач придаёт вкладке нужную форму, повторяя анатомию зуба.</p>
            <p><strong>5. Полимеризация</strong> — каждый слой засвечивается специальной лампой.</p>
            <p><strong>6. Финишная обработка</strong> — шлифовка и полировка до идеальной гладкости.</p>
          </section>
          
          <section class="info-section">
            <h2>Материалы</h2>
            <p><strong>Композит</strong> — самый распространённый материал. Светоотверждаемый, прочный, можно подобрать цвет.</p>
            <p><strong>Керамокомпозит</strong> — композит с добавлением керамики. Более прочный и меньше стирается.</p>
            <p><strong>Glass ionomer (стеклоиономер)</strong> — выделяет фтор, защищает от кариеса. Используется реже.</p>
          </section>
          
          <section class="info-section">
            <h2>Срок службы</h2>
            <p>Врачебная вкладка служит 10-15 лет при правильном уходе. Срок зависит от качества материала, размера вкладки и нагрузки на зуб.</p>
            <p>Признаки, что вкладку пора менять: изменение цвета, сколы краёв, чувствительность к холодному.</p>
          </section>
          
          <section class="info-section">
            <h2>Альтернативы</h2>
            <p><strong>Лабораторная вкладка</strong> — делается в зуботехнической лаборатории, более точная и прочная.</p>
            <p><strong>Коронка</strong> — если зуб сильно разрушен, вкладка может быть этапом перед коронкой.</p>
            <p><strong>Обычная пломба</strong> — если дефект небольшой.</p>
          </section>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card__value">3 180 ₽</div>
              <div class="stat-card__label">стоимость</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1 визит</div>
              <div class="stat-card__label">срок изготовления</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">10-15 лет</div>
              <div class="stat-card__label">срок службы</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1-2 часа</div>
              <div class="stat-card__label">время процедуры</div>
            </div>
          </div>
        </div>
        
        <div class="service-cta">
          <p>Нужна вкладка или хотите узнать больше?</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Написать в Telegram</a>
          </div>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>