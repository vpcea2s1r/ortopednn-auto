---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];

const services = [
  { slug: 'metallokeramika', title: 'Металлокерамическая коронка', desc: 'Коронки с металлическим каркасом и керамическим покрытием.', price: 'от 9 000 ₽' },
  { slug: 'cirkonievaya-koronka', title: 'Безметалловая коронка (цирконий)', desc: 'Эстетичные коронки из диоксида циркония. Максимальная естественность.', price: 'от 27 000 ₽' },
  { slug: 'viniry-emaks', title: 'Винир E-MAX', desc: 'Тонкие керамические накладки для идеальной улыбки.', price: 'от 30 000 ₽' },
  { slug: 'vrachebnaya-vkladka', title: 'Врачебная вкладка', desc: 'Пломбировочная вкладка, изготовленная врачом за один визит.', price: 'от 3 180 ₽' },
  { slug: 'vkladka', title: 'Зубная вкладка', desc: 'Микропротез для восстановления сильно разрушенных зубов.', price: 'от 3 180 ₽' },
  { slug: 'laboratornaya-vkladka', title: 'Лабораторная вкладка', desc: 'Керамическая или композитная вкладка, изготовленная в лаборатории.', price: 'от 5 040 ₽' },
  { slug: 'celnolitaya-koronka', title: 'Цельнолитая коронка', desc: 'Прочные металлические коронки из кобальт-хрома.', price: 'от 5 900 ₽' },
  { slug: 'celnolitaya-koronka-na-vkladke', title: 'Цельнолитая коронка на вкладке', desc: 'Монолитная металлическая конструкция для сильно разрушенных зубов.', price: 'от 8 200 ₽' },
  { slug: 'metallokeramicheskaya-koronka-na-vkladke', title: 'Металлокерамика на вкладке', desc: 'Эстетичная коронка на прочном металлическом основании.', price: 'от 12 000 ₽' },
  { slug: 'metalloplastmassovaya-koronka', title: 'Металлопластмассовая коронка', desc: 'Бюджетный вариант с металлическим каркасом и пластмассовым покрытием.', price: 'от 7 500 ₽' },
  { slug: 'iskusstvennaya-desna', title: 'Искусственная десна', desc: 'Керамическая имитация десны для эстетики при рецессии.', price: 'от 2 080 ₽' },
  { slug: 'vremennaya-koronka', title: 'Временная коронка', desc: 'Защита обточенного зуба на время изготовления постоянной конструкции.', price: 'от 2 160 ₽' },
  { slug: 'esteticheskij-prototip', title: 'Эстетический прототип', desc: 'Визуализация будущих зубов из воска или пластмассы.', price: 'от 1 500 ₽' },
  { slug: 'prototype', title: 'Прототип зубов', desc: 'Примерка улыбки до начала лечения. Восковая моделировка.', price: 'от 1 500 ₽' },
  { slug: 'sjemny-protez', title: 'Съёмные протезы', desc: 'Акриловые, AcryFree, нейлоновые. Полное или частичное протезирование.', price: 'от 15 000 ₽' },
  { slug: 'byugelnyj', title: 'Бюгельные протезы', desc: 'На замках и кламмерах. Удобные и эстетичные съёмные конструкции.', price: 'от 25 000 ₽' },
  { slug: 'korrekciya', title: 'Ремонт и коррекция протезов', desc: 'Исправление натирания, перебазировка, починка протезов.', price: 'от 2 000 ₽' },
];
---

<BaseLayout 
  title="Услуги протезирования зубов | Никитина М.Г."
  description="Услуги стоматолога-ортопеда Никитиной М.Г.: коронки, виниры, съёмные и бюгельные протезы в Нижнем Новгороде"
  doctor={doctor} 
  socials={socials}
>
  <Navbar />
  <main class="services-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <span>Услуги</span>
      </div>
    </nav>
    
    <section class="services-content">
      <div class="container">
        <h1>Услуги протезирования зубов</h1>
        <p class="services-intro">Выберите интересующую услугу для получения подробной информации.</p>
        
        <div class="services-grid">
          {services.map(item => (
            <a href={`/services/${item.slug}`} class="service-card">
              <h2>{item.title}</h2>
              <p>{item.desc}</p>
              <span class="service-price">{item.price}</span>
            </a>
          ))}
        </div>
        
        <div class="services-cta">
          <h2>Нужна консультация?</h2>
          <p>Позвоните — поможем подобрать оптимальное решение для вашего случая.</p>
          <a href="tel:+79202537317" class="btn">Позвонить</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
.services-page { min-height: 100vh; }

.breadcrumbs {
  padding: var(--space-sm) 0;
  background: white;
  border-bottom: 1px solid var(--color-border);
}
.breadcrumbs .container {
  display: flex;
  gap: var(--space-sm);
  font-size: var(--text-sm);
}
.breadcrumbs a { color: var(--color-primary); }

.services-content { padding: var(--space-3xl) 0; }

.services-content h1 {
  font-size: var(--text-3xl);
  text-align: center;
  margin-bottom: var(--space-sm);
}

.services-intro {
  text-align: center;
  color: var(--color-text-muted);
  margin-bottom: var(--space-2xl);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.service-card {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  text-decoration: none;
  transition: all var(--transition-normal);
  display: flex;
  flex-direction: column;
}

.service-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
  text-decoration: none;
}

.service-card h2 {
  font-size: var(--text-xl);
  color: var(--color-text);
  margin-bottom: var(--space-sm);
}

.service-card p {
  color: var(--color-text-muted);
  flex-grow: 1;
  margin-bottom: var(--space-md);
}

.service-price {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-primary);
}

.services-cta {
  text-align: center;
  padding: var(--space-3xl) 0;
  margin-top: var(--space-2xl);
  background: var(--color-bg-alt);
  border-radius: var(--radius-xl);
}

.services-cta h2 {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-md);
}

.services-cta p {
  color: var(--color-text-muted);
  margin-bottom: var(--space-lg);
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-primary);
  color: white;
  padding: var(--space-sm) var(--space-xl);
  border-radius: var(--radius-lg);
  text-decoration: none;
  font-weight: 600;
  transition: all var(--transition-fast);
}

.btn:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
  text-decoration: none;
}

@media (max-width: 640px) {
  .services-content { padding: var(--space-xl) 0; }
  .services-grid { grid-template-columns: 1fr; }
}
</style>