---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { categories } from '../../../data/services.ts';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout 
  title="Услуги протезирования зубов в Нижнем Новгороде | Никитина М.Г."
  description="Услуги стоматолога-ортопеда Никитиной М.Г.: коронки, съёмные и бюгельные протезы в Нижнем Новгороде"
  doctor={doctor} 
  socials={socials}
>
  <Navbar />
  <main class="services-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <span>Услуги</span>
      </div>
    </nav>
    
    <section class="services-content">
      <div class="container">
        <h1>Услуги протезирования зубов</h1>
        <p class="services-intro">Выберите интересующую услугу для получения подробной информации.</p>
        
        {categories.map(cat => (
          <div class="services-category">
            <h2 class="category-title">{cat.name}</h2>
            <div class="services-grid">
              {cat.items.map(item => (
                <a href={`/services/${item.slug}`} class="service-card">
                  <h3>{item.title}</h3>
                  <p>{item.desc}</p>
                </a>
              ))}
            </div>
          </div>
        ))}
        
        <div class="services-cta">
          <h2>Нужна консультация?</h2>
          <p>Позвоните — поможем подобрать оптимальное решение для вашего случая.</p>
          <a href="tel:+79202537317" class="btn">Позвонить</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
.services-page { min-height: 100vh; }

.breadcrumbs {
  padding: var(--space-sm) 0;
  background: white;
  border-bottom: 1px solid var(--color-border);
}

.breadcrumbs a { color: var(--color-primary); }

.services-content { padding: var(--space-3xl) 0; }

.services-content h1 {
  font-size: var(--text-3xl);
  text-align: center;
  margin-bottom: var(--space-sm);
}

.services-category {
  margin-bottom: var(--space-3xl);
}

.category-title {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-xs);
  border-bottom: 2px solid var(--color-primary);
}

.services-intro {
  text-align: center;
  color: var(--color-text-muted);
  margin-bottom: var(--space-2xl);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-lg);
}

@media (max-width: 640px) {
  .services-grid { grid-template-columns: 1fr; }
}

.service-card {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  text-decoration: none;
  transition: all var(--transition-normal);
  display: flex;
  flex-direction: column;
}

.service-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
  text-decoration: none;
}

.service-card h3 {
  font-size: var(--text-xl);
  color: var(--color-text);
  margin-bottom: var(--space-sm);
}

.service-card p {
  color: var(--color-text-muted);
  flex-grow: 1;
  margin-bottom: var(--space-md);
}

.services-cta {
  text-align: center;
  padding: var(--space-3xl) 0;
  margin-top: var(--space-2xl);
  background: var(--color-bg-alt);
  border-radius: var(--radius-xl);
}

.services-cta h2 {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-md);
}

.services-cta p {
  color: var(--color-text-muted);
  margin-bottom: var(--space-lg);
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-primary);
  color: white;
  padding: var(--space-sm) var(--space-xl);
  border-radius: var(--radius-lg);
  text-decoration: none;
  font-weight: 600;
  transition: all var(--transition-fast);
}

.btn:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
  text-decoration: none;
}

@media (max-width: 640px) {
  .services-content { padding: var(--space-xl) 0; }
}
</style>