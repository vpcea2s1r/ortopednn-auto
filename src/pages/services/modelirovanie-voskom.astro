---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Диагностическое моделирование воском | Никитина М.Г." description="Wax-up — восковое моделирование будущих зубов для планирования эстетики. Цена 1 500 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Диагностическое моделирование воском</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Диагностическое моделирование воском</h1>
          <div class="service-header__price">1 500 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое Wax-up</h2>
            <p>Wax-up (вакс-ап) — это восковое моделирование будущих зубов на диагностической модели. Зубной техник послойно наносит стоматологический воск, формируя желаемую форму, размер и положение зубов.</p>
            <p>Это ключевой этап планирования эстетического лечения. Wax-up позволяет визуализировать результат ещё до начала препарирования и при необходимости внести коррективы.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Планирование виниров и коронок</li>
              <li>Полная реконструкция зубов</li>
              <li>Исправление формы и размера зубов</li>
              <li>Коррекция окклюзии</li>
              <li>Планирование имплантации</li>
              <li>Изготовление хирургического шаблона</li>
              <li>Коммуникация с пациентом (Mock-up)</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Материалы для Wax-up</h2>
            <p><strong>Стоматологический воск:</strong> специальный воск с контролируемым расширением. Не даёт усадки, пластичен при нагревании, твёрдый при комнатной температуре.</p>
            <p><strong>Виды воска:</strong> моделировочный воск (base wax), изолирующий воск, вода для полировки.</p>
            <p><strong>Инструменты:</strong> шпатели, воскоплавители, горелки, кюретки для придания формы.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества Wax-up</h3><ul>
              <li><strong>Визуализация</strong> — пациент видит результат</li>
              <li><strong>Планирование</strong> — точное определение параметров</li>
              <li><strong>Коммуникация</strong> — врач, техник, пациент понимают цель</li>
              <li><strong>Mock-up</strong> — основа для переноса в полость рта</li>
              <li><strong>Хирургический шаблон</strong> — можно изготовить по Wax-up</li>
              <li><strong>Обратимость</strong> — легко корректируется</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Время</strong> — изготовление занимает 1-4 часа</li>
              <li><strong>Стоимость</strong> — работа техника</li>
              <li><strong>Ограничения</strong> — не учитывает биотип десны</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Этапы изготовления Wax-up</h2>
            <p><strong>1. Диагностическая модель:</strong> гипсовая модель или 3D-печатная.</p>
            <p><strong>2. Изоляция:</strong> нанесение изолятора на поверхность модели.</p>
            <p><strong>3. Моделирование:</strong> послойное нанесение воска с формированием анатомической формы зубов.</p>
            <p><strong>4. Коррекция:</strong> проверка формы, контактов, окклюзии.</p>
            <p><strong>5. Финишная обработка:</strong> полировка поверхности.</p>
            <p><strong>6. Силиконовый ключ:</strong> изготовление ключа для Mock-up.</p>
          </section>
          <section class="info-section"><h2>Связь с Mock-up</h2>
            <p>После изготовления Wax-up изготавливается силиконовый ключ. С его помощью восковая модель переносится в полость рта пациента с помощью композитного материала — это называется Mock-up.</p>
            <p>Mock-up позволяет пациенту оценить внешний вид, форму зубов, прикус. При необходимости вносятся коррективы в Wax-up и процедура повторяется.</p>
            <p>Клинические исследования показывают, что использование Wax-up и Mock-up повышает удовлетворённость пациентов результатами лечения на 30-50%.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>