---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Бюгель ДенталДи белый | Никитина М.Г." description="Бюгельный протез ДенталДи с белым каркасом — эстетичное решение без металла. Цена от 52 200 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Бюгель ДенталДи белый</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Бюгель ДенталДи белый</h1>
          <div class="service-header__price">от 52 200 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое ДенталДи?</h2>
            <p>ДенталДи (Dental D) — это термопластичный бюгельный протез нового поколения с белым каркасом. Каркас изготовлен из прочного материала розовато-белого цвета, который не содержит металла и выглядит максимально естественно. В отличие от классических бюгелей с металлической дугой, ДенталДи обеспечивает высокую эстетику.</p>
            <p>Материал ДенталДи — это армированный термопластичный полимер. Он прочнее обычного нейлона и сохраняет эластичность. Производится методом горячего прессования.</p>
          </section>

          <section class="info-section">
            <h2>Какие типы бюгельных протезов существуют?</h2>
            <div class="materials-grid">
              <div class="material-card">
                <h3>Классический бюгель</h3>
                <div class="material-price">от 25 000 ₽</div>
                <ul>
                  <li>Металлическая дуга (Co-Cr)</li>
                  <li>Высокая прочность</li>
                  <li>Кламмеры металлические</li>
                  <li>Заметен на десне</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Акриловый</h3>
                <div class="material-price">от 15 000 ₽</div>
                <ul>
                  <li>Твёрдый базис</li>
                  <li>Без дуги</li>
                  <li>Громоздкий</li>
                  <li>Закрывает нёбо</li>
                </ul>
              </div>
              <div class="material-card material-card--featured">
                <h3>ДенталДи (рекомендуем)</h3>
                <div class="material-price">от 52 200 ₽</div>
                <ul>
                  <li>Белый термопластичный каркас</li>
                  <li>Без металла</li>
                  <li>Эстетичный и незаметный</li>
                  <li>Гипоаллергенный</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Нейлоновый</h3>
                <div class="material-price">от 41 400 ₽</div>
                <ul>
                  <li>Мягкий гибкий</li>
                  <li>Без дуги</li>
                  <li>Эстетичный</li>
                  <li>Меньше прочность</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Кому подходит ДенталДи?</h2>
            <ul>
              <li>Частичное отсутствие зубов (2 и более)</li>
              <li>Желание избежать металлических кламмеров и дуги</li>
              <li>Аллергия на металл (кобальт-хром, никель)</li>
              <li>Высокие эстетические требования</li>
              <li>Повышенная чувствительность дёсен</li>
              <li>Противопоказания к имплантации</li>
              <li>Необходимость съёмной конструкции при ограниченном бюджете</li>
              <li>Неровная слизистая (каркас мягко адаптируется)</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Чем отличается конструкция ДенталДи?</h2>
            <p><strong>Белый каркас:</strong> термопластичный материал розовато-белого цвета, имитирует слизистую оболочку. Полупрозрачный — сквозь него видна десна, что делает конструкцию естественной.</p>
            <p><strong>Дуга:</strong> тонкая, но прочная термопластичная дуга. Обеспечивает равномерное распределение жевательной нагрузки, как металлическая в классическом бюгеле, но без видимого металла.</p>
            <p><strong>Фиксация:</strong> кламмеры из того же материала, мягкие и эластичные. Телесного цвета — на передних зубах практически незаметны. Это главное преимущество перед металлическими кламмерами.</p>
            <p><strong>Базис:</strong> плотно прилегает к десне, не натирает. Мягче акрила, комфортнее для пациента.</p>
            <p><strong>Зубы:</strong> искусственные зубы крепятся к базису. Могут быть керамические или пластмассовые — стандартные для съёмных протезов.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества ДенталДи</h3><ul>
              <li><strong>Эстетика</strong> — белый каркас незаметен, сливается с десной</li>
              <li><strong>Комфорт</strong> — мягкие эластичные кламмеры, не натирают</li>
              <li><strong>Гипоаллергенность</strong> — без металла, без мономера</li>
              <li><strong>Прочность</strong> — выдерживает жевательную нагрузку</li>
              <li><strong>Лёгкость</strong> — минимум дискомфорта</li>
              <li><strong>Без нёбной пластины</strong> — не закрывает нёбо, комфортнее</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — выше классических бюгельных протезов</li>
              <li><strong>Ремонт</strong> — ограниченные возможности переделки</li>
              <li><strong>Срок</strong> — 4-6 лет при правильном уходе</li>
              <li><strong>Прочность</strong> — ниже, чем у металлического бюгеля</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Какие показатели у ДенталДи?</h2>
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-value">4-6</div>
                <div class="stat-label">лет срок службы</div>
                <div class="stat-desc">при правильном уходе</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">0%</div>
                <div class="stat-label">металл</div>
                <div class="stat-desc">полная гипоаллергенность</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">280°C</div>
                <div class="stat-label">температура</div>
                <div class="stat-desc">горячего прессования</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">96%</div>
                <div class="stat-label">пациентов</div>
                <div class="stat-desc">довольны эстетикой</div>
              </div>
            </div>
          </section>

          <section class="info-section"><h2>Как изготавливается ДенталДи?</h2>
            <p><strong>1. Консультация:</strong> осмотр, обсуждение плана, оценка показаний для ДенталДи.</p>
            <p><strong>2. Диагностика:</strong> рентген, слепки для диагностических моделей.</p>
            <p><strong>3. Моделирование:</strong> зубной техник создаёт модель будущего протеза. Оценивается прикус, расположение дуги, форма кламмеров.</p>
            <p><strong>4. Изготовление:</strong> формовка термопластичного каркаса методом горячего прессования. К дуге крепятся искусственные зубы.</p>
            <p><strong>5. Примерка:</strong> проверка посадки, прикуса, эстетики, комфорта.</p>
            <p><strong>6. Корректировка:</strong> при необходимости — подгонка.</p>
            <p><strong>7. Установка:</strong> фиксация, рекомендации по уходу и адаптации.</p>
          </section>

          <section class="info-section"><h2>Как ухаживать за протезом ДенталДи?</h2>
            <p><strong>После еды:</strong> промывайте протез тёплой водой.</p>
            <p><strong>Чистка:</strong> мягкая щётка + специальные средства. Не абразивные пасты.</p>
            <p><strong>Хранение:</strong> в воде или контейнере. Не сушить на батарее.</p>
            <p><strong>Избегайте:</strong> кипятка, агрессивных химикатов.</p>
            <p><strong>Профессиональная чистка:</strong> раз в 6-12 месяцев.</p>
            <p>При правильном уходе протез прослужит 4-6 лет без потери эстетических свойств.</p>
          </section>
          <section class="info-section">
            <h2>Когда подходит ДенталДи?</h2>
            <ul>
              <li>Частичное отсутствие зубов</li>
              <li>Желание избежать металлических кламмеров</li>
              <li>Аллергия на металл</li>
              <li>Эстетические требования</li>
              <li>Повышенная чувствительность дёсен</li>
              <li>Противопоказания к имплантации</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Чем отличается конструкция ДенталДи?</h2>
            <p><strong>Белый каркас:</strong> термопластичный материал розовато-белого цвета, имитирует слизистую.</p>
            <p><strong>Фиксация:</strong> кламмеры из того же материала, мягкие и эластичные.</p>
            <p><strong>Дуга:</strong> тонкая, но прочная, обеспечивает равномерную нагрузку.</p>
            <p><strong>Базис:</strong> плотно прилегает к десне, не натирает.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества ДенталДи</h3><ul>
              <li><strong>Эстетика</strong> — белый каркас незаметен</li>
              <li><strong>Комфорт</strong> — мягкие кламмеры</li>
              <li><strong>Гипоаллергенность</strong> — без металла и мономера</li>
              <li><strong>Прочность</strong> — выдерживает жевательную нагрузку</li>
              <li><strong>Лёгкость</strong> — минимум дискомфорта</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — выше классических протезов</li>
              <li><strong>Ремонт</strong> — ограниченные возможности переделки</li>
              <li><strong>Срок</strong> — 4-6 лет при правильном уходе</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Как изготавливается ДенталДи?</h2>
            <p><strong>1. Консультация:</strong> осмотр, обсуждение плана.</p>
            <p><strong>2. Диагностика:</strong> рентген, слепки.</p>
            <p><strong>3. Моделирование:</strong> создание модели в лаборатории.</p>
            <p><strong>4. Изготовление:</strong> формовка термопластичного каркаса.</p>
            <p><strong>5. Примерка:</strong> подгонка и корректировка.</p>
            <p><strong>6. Установка:</strong> фиксация, рекомендации.</p>
          </section>
          <section class="info-section"><h2>Как ухаживать за протезом ДенталДи?</h2>
            <p>Промывайте протез после каждого приёма пищи. Используйте мягкую щётку и специальные средства. Избегайте кипятка и абразивных паст.</p>
            <p>Регулярно проверяйте состояние протеза у стоматолога. При правильном уходе протез прослужит 4-6 лет без потери эстетических свойств.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }

.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.material-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.material-card--featured {
  border-color: var(--color-primary);
  background: linear-gradient(to bottom, white, var(--color-bg-alt));
}
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.stat-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  text-align: center;
}
.stat-value { font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); }
.stat-label { font-size: var(--text-sm); color: var(--color-text); font-weight: 600; margin-top: var(--space-xs); }
.stat-desc { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: 2px; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>