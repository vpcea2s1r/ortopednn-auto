.protocol-list li { margin-bottom: var(--space-md); color: var(--color-text-muted); line-height: 1.6; }
.protocol-list li strong { color: var(--color-text); }

.materials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--space-lg); margin-bottom: var(--space-xl); }
.material-card { background: var(--color-bg-alt); padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.material-card h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-sm); font-weight: 600; }
.material-card p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: var(--space-sm); font-size: var(--text-sm); }
