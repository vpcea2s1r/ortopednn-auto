---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Перебазировка лабораторная | Никитина М.Г." description="Лабораторная перебазировка съёмного протеза — точная коррекция в зуботехнической лаборатории. Цена 5 700 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Перебазировка лабораторная</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Перебазировка лабораторная</h1>
          <div class="service-header__price">5 700 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое лабораторная перебазировка</h2>
            <p>Лабораторная перебазировка — это полная замена базиса (основания) съёмного протеза в зуботехнической лаборатории. Процесс занимает 1-2 дня и обеспечивает высокую точность и долговечность.</p>
            <p>В отличие от врачебной перебазировки, лабораторная выполняется на новой модели слизистой пациента, что гарантирует идеальную посадку.</p>
          </section>
          <section class="info-section">
            <h2>Когда нужна лабораторная перебазировка</h2>
            <ul>
              <li>Сильная атрофия слизистой</li>
              <li>Протез сильно «гуляет»</li>
              <li>Многократные коррекции не помогают</li>
              <li>Износ базиса (трещины, деформация)</li>
              <li>Хроническое натирание</li>
              <li>После имплантации или хирургии</li>
              <li>Протез старше 5-7 лет</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Этапы лабораторной перебазировки</h2>
            <p><strong>1. Оттиск:</strong> врач снимает оттиск протезом — на базис наносится мягкий материал, протез фиксируется во рту. Получается модель новой слизистой.</p>
            <p><strong>2. Гипсовка:</strong> в лаборатории отливается модель.</p>
            <p><strong>3. Изоляция:</strong> модель изолируется.</p>
            <p><strong>4. Постановка на модель:</strong> зубы снимаются с протеза и переставляются на новую модель.</p>
            <p><strong>5. Перебазировка:</strong> базисный материал заливается на новую модель.</p>
            <p><strong>6. Обработка:</strong> полировка, проверка.</p>
            <p><strong>7. Контроль:</strong> врач проверяет посадку и окклюзию.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества лабораторной перебазировки</h3><ul>
              <li><strong>Точность</strong> — идеальная посадка</li>
              <li><strong>Долговечность</strong> — служит годы</li>
              <li><strong>Качество</strong> — новый базис без дефектов</li>
              <li><strong>Прочность</strong> — монолитная конструкция</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Время</strong> — 1-2 дня без протеза</li>
              <li><strong>Цена</strong> — дороже врачебной</li>
              <li><strong>Процесс</strong> — больше этапов</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Материалы для лабораторной перебазировки</h2>
            <p><strong>Холодный акрил:</strong> самый распространённый. Прочный, долговечный, доступный.</p>
            <p><strong>Горячий акрил:</strong> прочнее холодного. Используется для долгосрочных решений.</p>
            <p><strong>Акрил повышенной прочности:</strong> для пациентов с бруксизмом или высокой нагрузкой.</p>
            <p><strong>Мягкие подкладки:</strong> иногда используются комбинированные решения.</p>
            <p>Исследования показывают, что лабораторная перебазировка восстанавливает функцию протеза на 95-100% и служит в среднем 3-5 лет до следующей перебазировки.</p>
          </section>
          <section class="info-section"><h2>Сравнение с другими методами</h2>
          <p><strong>Лабораторная vs врачебная:</strong> лабораторная точнее и долговечнее, но требует времени без протеза. При значительной атрофии лабораторная — предпочтительный выбор.</p>
          <p><strong>Перебазировка vs новый протез:</strong> если протез в хорошем состоянии (зубы целы, нет трещин), перебазировка — экономически обоснованный выбор. При множественных дефектах — новый протез.</p>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>