---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Съёмный протез AcryFree | Никитина М.Г." description="Протез AcryFree — полужесткий термопластичный съёмный протез. Цена от 41 400 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>AcryFree</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Съёмный протез AcryFree</h1>
          <div class="service-header__price">от 41 400 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое протез AcryFree?</h2>
            <p>AcryFree — это полужесткий термопластичный материал нового поколения для съёмных зубных протезов. Разработан специально для пациентов, которым стандартный акрил доставляет дискомфорт. Протезы AcryFree сочетают эластичность нейлона и прочность акрила.</p>
            <p>Материал не содержит мономера, что делает его гипоаллергенным. AcryFree производится методом горячего прессования при температуре около 260°C, что обеспечивает однородную структуру без пор и внутренних напряжений.</p>
          </section>

          <section class="info-section">
            <h2>Как сравнить AcryFree с другими протезами?</h2>
            <div class="materials-grid">
              <div class="material-card">
                <h3>Акрил (твёрдый)</h3>
                <div class="material-price">самый доступный</div>
                <ul>
                  <li>Твёрдый базис, возможно натирание</li>
                  <li>Хорошая ремонтопригодность</li>
                  <li>Возможна перебазировка</li>
                  <li>Срок 5-7 лет</li>
                </ul>
              </div>
              <div class="material-card material-card--featured">
                <h3>AcryFree (рекомендуем)</h3>
                <div class="material-price">полужёсткий</div>
                <ul>
                  <li>Комфортнее акрила</li>
                  <li>Прочнее нейлона</li>
                  <li>Гипоаллергенный</li>
                  <li>Ремонтопригодный</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>Нейлон</h3>
                <div class="material-price">самый мягкий</div>
                <ul>
                  <li>Гибкий и мягкий</li>
                  <li>Идеален при аллергии</li>
                  <li>Сложнее в ремонте</li>
                  <li>Эстетичный</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>ДенталДи</h3>
                <div class="material-price">белый каркас</div>
                <ul>
                  <li>Без металлической дуги</li>
                  <li>Эстетичный белый каркас</li>
                  <li>Гипоаллергенный</li>
                  <li>Срок 4-6 лет</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Кому подходит протез AcryFree?</h2>
            <ul>
              <li>Частичное или полное отсутствие зубов</li>
              <li>Аллергия на акрил или металл (не содержит мономера)</li>
              <li>Повышенная чувствительность дёсен и слизистой</li>
              <li>Непереносимость жёстких протезов</li>
              <li>Пародонтит и пародонтоз (мягкое прилегание)</li>
              <li>Желание комфортного и эстетичного решения</li>
              <li>Неровный альвеолярный гребень (мягко адаптируется)</li>
              <li>Атрофия слизистой (меньше давления на кость)</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Свойства материала AcryFree</h2>
            <p><strong>Полужёсткость:</strong> мягче акрила, но прочнее нейлона. Это обеспечивает баланс между комфортом и долговечностью. Жёсткость по Шору около 80-85 единиц.</p>
            <p><strong>Гипоаллергенность:</strong> не содержит мономера (метилметакрилата) и латекса. Безопасен для пациентов с аллергией на акриловые протезы.</p>
            <p><strong>Эстетика:</strong> полупрозрачный розовый цвет, имитирует слизистую оболочку. Кламмеры из того же материала — телесного цвета, незаметны.</p>
            <p><strong>Стабильность:</strong> не впитывает влагу, не окрашивается от кофе и чая. Сохраняет форму и цвет на протяжении срока службы.</p>
            <p><strong>Ремонтопригодность:</strong> в отличие от нейлона, AcryFree можно корректировать и ремонтировать в лаборатории. Приварка зубов и перебазировка возможны.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества AcryFree</h3><ul>
              <li><strong>Комфорт</strong> — мягкий и гибкий, не натирает дёсны</li>
              <li><strong>Эстетика</strong> — полупрозрачный розовый, незаметен в полости рта</li>
              <li><strong>Гипоаллергенность</strong> — без мономера, латекса</li>
              <li><strong>Прочность</strong> — устойчив к переломам и ударам</li>
              <li><strong>Лёгкость</strong> — меньше нагрузка на челюсть и слизистую</li>
              <li><strong>Ремонтопригодность</strong> — возможна приварка зубов и перебазировка</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — выше, чем у акриловых протезов</li>
              <li><strong>Ремонт при сложных поломках</strong> — может потребоваться замена</li>
              <li><strong>Срок</strong> — 3-5 лет при правильном уходе</li>
              <li><strong>Жёсткость</strong> — некоторым пациентам привычнее мягкий нейлон</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Показатели и статистика</h2>
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-value">3-5</div>
                <div class="stat-label">лет срок службы</div>
                <div class="stat-desc">при правильном уходе</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">80-85</div>
                <div class="stat-label">единиц твёрдости</div>
                <div class="stat-desc">по Шору D</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">260°C</div>
                <div class="stat-label">температура</div>
                <div class="stat-desc">горячего прессования</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">0%</div>
                <div class="stat-label">мономер</div>
                <div class="stat-desc">полная гипоаллергенность</div>
              </div>
            </div>
          </section>

          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Консультация:</strong> осмотр полости рта, обсуждение плана лечения. Оценка показаний для AcryFree.</p>
            <p><strong>2. Снятие слепков:</strong> альгинатные оттиски обеих челюстей для диагностики и рабочих моделей.</p>
            <p><strong>3. Изготовление:</strong> в зуботехнической лаборатории. По рабочей модели прессуется каркас из материала AcryFree. Затем крепятся искусственные зубы.</p>
            <p><strong>4. Примерка:</strong> проверка посадки, окклюзии, эстетики, комфорта.</p>
            <p><strong>5. Корректировка:</strong> при необходимости — подгонка базиса и кламмеров.</p>
            <p><strong>6. Установка:</strong> фиксация протеза, подробные рекомендации по уходу.</p>
          </section>

          <section class="info-section"><h2>Протокол ухода за AcryFree</h2>
            <p><strong>После еды:</strong> промывайте протез тёплой водой. Избегайте кипятка — деформация.</p>
            <p><strong>Чистка:</strong> мягкая зубная щётка + специальные средства для протезов (не абразивные!).</p>
            <p><strong>На ночь:</strong> можно снимать и хранить в воде или контейнере. Первое время лучше носить постоянно для адаптации.</p>
            <p><strong>Избегайте:</strong> кипятка, агрессивных химических средств, абразивных паст, отбеливателей.</p>
            <p><strong>Профессиональная чистка:</strong> раз в 6-12 месяцев у стоматолога.</p>
          </section>
          <section class="info-section">
            <h2>Когда подходит AcryFree</h2>
            <ul>
              <li>Частичное или полное отсутствие зубов</li>
              <li>Аллергия на акрил или металл</li>
              <li>Повышенная чувствительность дёсен</li>
              <li>Непереносимость жёстких протезов</li>
              <li>Пародонтит и пародонтоз</li>
              <li>Желание комфортного и эстетичного решения</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Свойства материала AcryFree</h2>
            <p><strong>Полужёсткость:</strong> мягче акрила, но прочнее нейлона.</p>
            <p><strong>Гипоаллергенность:</strong> не содержит мономера и латекса.</p>
            <p><strong>Эстетика:</strong> полупрозрачный розовый цвет, имитирует слизистую.</p>
            <p><strong>Стабильность:</strong> не впитывает влагу, не окрашивается.</p>
            <p><strong>Ремонтопригодность:</strong> можно корректировать и ремонтировать.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества AcryFree</h3><ul>
              <li><strong>Комфорт</strong> — мягкий и гибкий, не натирает</li>
              <li><strong>Эстетика</strong> — полупрозрачный, незаметен</li>
              <li><strong>Гипоаллергенность</strong> — без мономера</li>
              <li><strong>Прочность</strong> — устойчив к переломам</li>
              <li><strong>Лёгкость</strong> — меньше нагрузка на челюсть</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — выше, чем у акриловых протезов</li>
              <li><strong>Ремонт</strong> — при сложных поломках может потребоваться замена</li>
              <li><strong>Срок</strong> — служит 3-5 лет при правильном уходе</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Консультация:</strong> осмотр, обсуждение плана лечения.</p>
            <p><strong>2. Снятие слепков:</strong> точное моделирование челюсти.</p>
            <p><strong>3. Изготовление:</strong> в лаборатории из материала AcryFree.</p>
            <p><strong>4. Примерка:</strong> подгонка и корректировка.</p>
            <p><strong>5. Установка:</strong> фиксация, рекомендации по уходу.</p>
          </section>
          <section class="info-section"><h2>Уход за протезом AcryFree</h2>
            <p>Промывайте протез после каждого приёма пищи тёплой водой. Используйте мягкую зубную щётку и специальные средства для протезов. На ночь можно снимать или хранить в контейнере с водой.</p>
            <p>Избегайте кипятка и агрессивных химических средств. Регулярно посещайте стоматолога для профессиональной чистки и проверки состояния протеза.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }

.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.material-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.material-card--featured {
  border-color: var(--color-primary);
  background: linear-gradient(to bottom, white, var(--color-bg-alt));
}
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.stat-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  text-align: center;
}
.stat-value { font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); }
.stat-label { font-size: var(--text-sm); color: var(--color-text); font-weight: 600; margin-top: var(--space-xs); }
.stat-desc { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: 2px; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>