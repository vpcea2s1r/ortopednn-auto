---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout 
  title="Виниры E-MAX — Никитина М.Г."
  description="Виниры E-MAX в Нижнем Новгороде. Цена от 25000 рублей. Технология, показания, уход."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs" aria-label="Хлебные крошки">
      <div class="container">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/services">Услуги</a>
        <span>/</span>
        <span>Виниры E-MAX</span>
      </div>
    </nav>
    
    <article class="service-content">
      <div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Виниры E-MAX</h1>
          <div class="service-header__price">от 25 000 ₽</div>
        </header>
        
        <div class="service-body">
          <section class="info-section">
            <h2>Технология</h2>
            <p>Виниры E-MAX — это тонкие керамические накладки на переднюю поверхность зубов, изготовленные из литийсиликатной керамики (IPS e.max). Эта технология позволяет добиться максимальной естественности и эстетики.</p>
            <p>Толщина винира составляет всего 0.3-0.7 мм, что позволяет минимально препарировать зуб. Керамика E-MAX обладает высокой прочностью (400 МПа) и превосходной прозрачностью, имитирующей натуральную эмаль зуба.</p>
          </section>
          
          <section class="info-section">
            <h2>Показания к применению</h2>
            <ul>
              <li>Изменение цвета зубов, не поддающееся отбеливанию</li>
              <li>Сколы и трещины на передних зубах</li>
              <li>Щели между зубами (диастемы, тремы)</li>
              <li>Неровные или кривые зубы при незначительном искривлении</li>
              <li>Желание пациента изменить форму зубов</li>
              <li>Стираемость зубов</li>
              <li>Некачественные пломбы на передних зубах</li>
            </ul>
          </section>
          
          <section class="info-section">
            <h2>Противопоказания</h2>
            <ul>
              <li>Сильное искривление зубов (требуется ортодонтическое лечение)</li>
              <li>Бруксизм (скрежетание зубами)</li>
              <li>Недостаточная высота зубов для установки винира</li>
              <li>Пародонтит в активной стадии</li>
              <li>Кариес на передних зубах (требуется лечение)</li>
              <li>Привычка грызть ногти, открывать бутылки зубами</li>
            </ul>
          </section>
          
          <section class="info-section">
            <h2>Как проходит процесс</h2>
            <p><strong>Консультация:</strong> Осмотр, обсуждение ожиданий, Digital Smile Design при необходимости.</p>
            <p><strong>Подготовка:</strong> Минимальная обточка зуба (0.3-0.7 мм). Процедура проводится под местной анестезией.</p>
            <p><strong>Снятие слепков:</strong> Цифровой сканер или классические силиконовые оттиски.</p>
            <p><strong>Временные виниры:</strong> Устанавливаются на время изготовления постоянных (1-2 недели).</p>
            <p><strong>Примерка и фиксация:</strong> Готовые виниры примеряются и фиксируются на специальный цемент.</p>
          </section>
          
          <div class="info-grid">
            <section class="info-block info-block--pros">
              <h3>Преимущества</h3>
              <ul>
                <li>Максимальная эстетика — неотличимы от натуральных зубов</li>
                <li>Минимальная обточка зуба (иногда возможна установка без препарирования)</li>
                <li>Высокая прочность и долговечность</li>
                <li>Устойчивость к окрашиванию (не меняют цвет со временем)</li>
                <li>Биосовместимость — не вызывают аллергии</li>
                <li>Быстрый результат — 2-3 визита</li>
              </ul>
            </section>
            
            <section class="info-block info-block--cons">
              <h3>Особенности</h3>
              <ul>
                <li>Более высокая стоимость по сравнению с композитными винирами</li>
                <li>Необратимость процесса (зуб обтачивается)</li>
                <li>Требуется замена при повреждении (не ремонтируются)</li>
                <li>Необходимость соблюдать осторожность с твёрдой пищей</li>
                <li>Может потребоваться замена через 10-15 лет</li>
              </ul>
            </section>
          </div>
          
          <section class="info-section">
            <h2>Виды виниров E-MAX</h2>
            <p><strong>E-MAX PRESS:</strong> Изготавливаются методом прессования. Более прочные, подходят для сложных случаев.</p>
            <p><strong>E-MAX CUT:</strong> Фрезеруются из блока. Максимальная точность и эстетика.</p>
            <p><strong>E-MAX TRANSLUCENT:</strong> Полупрозрачные, для максимальной естественности.</p>
            <p><strong>E-MAX MULTI:</strong> Многослойные, сочетают прочность и эстетику.</p>
          </section>
          
          <section class="info-section">
            <h2>Уход за винирами E-MAX</h2>
            <ul>
              <li>Чистка зубов два раза в день мягкой щёткой</li>
              <li>Использование зубной нити для очистки межзубных промежутков</li>
              <li>Избегать чрезмерно твёрдой пищи (орехи, леденцы)</li>
              <li>Не использовать зубы для открывания упаковок, бутылок</li>
              <li>Ночная защитная капа при бруксизме</li>
              <li>Регулярные осмотры у стоматолога каждые 6 месяцев</li>
              <li>Профессиональная чистка зубов раз в год</li>
            </ul>
          </section>
          
          <section class="info-section">
            <h2>Срок службы</h2>
            <p>При правильном уходе и соблюдении рекомендаций виниры E-MAX служат 10-20 лет. На срок службы влияют: качество гигиены, наличие бруксизма, травмы, состояние десны.</p>
          </section>
        </div>
        
        <div class="service-cta">
          <p>Хотите узнать больше о винирах E-MAX?</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Написать в Telegram</a>
          </div>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }

.breadcrumbs {
  padding: var(--space-sm) 0;
  background: white;
  border-bottom: 1px solid var(--color-border);
}
.breadcrumbs .container {
  display: flex;
  gap: var(--space-sm);
  font-size: var(--text-sm);
  flex-wrap: wrap;
}
.breadcrumbs a { color: var(--color-primary); }

.service-content { padding: var(--space-3xl) 0; }

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-xl);
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--color-border);
  flex-wrap: wrap;
  gap: var(--space-md);
}
.service-header__title {
  font-size: var(--text-3xl);
  color: var(--color-text);
}
.service-header__price {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%);
  color: white;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-lg);
  font-weight: 700;
  font-size: var(--text-xl);
}

.info-section {
  margin-bottom: var(--space-xl);
}
.info-section h2 {
  font-size: var(--text-xl);
  color: var(--color-primary);
  margin-bottom: var(--space-md);
}
.info-section p {
  color: var(--color-text-muted);
  line-height: 1.7;
}
.info-section ul {
  padding-left: var(--space-lg);
}
.info-section li {
  color: var(--color-text-muted);
  margin-bottom: var(--space-xs);
  line-height: 1.6;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-lg);
  margin-bottom: var(--space-xl);
}

.info-block {
  background: white;
  padding: var(--space-lg);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.info-block h3 {
  font-size: var(--text-lg);
  color: var(--color-text);
  margin-bottom: var(--space-md);
}
.info-block ul {
  list-style: none;
  padding: 0;
}
.info-block li {
  color: var(--color-text-muted);
  padding: var(--space-xs) 0;
  border-bottom: 1px solid var(--color-bg);
}

.service-cta {
  text-align: center;
  padding: var(--space-2xl);
  background: var(--color-bg-alt);
  border-radius: var(--radius-xl);
  margin-top: var(--space-xl);
}
.service-cta p {
  color: var(--color-text-muted);
  margin-bottom: var(--space-md);
}
.cta-buttons {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
}
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-primary);
  color: white;
  padding: var(--space-sm) var(--space-xl);
  border-radius: var(--radius-lg);
  text-decoration: none;
  font-weight: 600;
  transition: all var(--transition-fast);
}
.btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  text-decoration: none;
}
.btn--secondary {
  background: white;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

@media (max-width: 768px) {
  .info-grid { grid-template-columns: 1fr; }
  .service-header { flex-direction: column; }
  .service-header__price { width: 100%; text-align: center; }
}
</style>