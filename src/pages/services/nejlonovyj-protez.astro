---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Нейлоновый съёмный протез | Никитина М.Г." description="Нейлоновый съёмный протез — мягкий, гибкий и гипоаллергенный. Цена от 41 400 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Нейлоновый протез</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Нейлоновый съёмный протез</h1>
          <div class="service-header__price">от 41 400 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое нейлоновый протез</h2>
            <p>Нейлоновый протез — это съёмная конструкция из мягкого термопластичного материала на основе полиамида (нейлона). Отличается гибкостью, лёгкостью и высокой эстетикой. Материал полупрозрачный розовый, что делает протез практически незаметным в полости рта.</p>
            <p>В отличие от акрила, нейлон не содержит мономера (метилметакрилата) и практически не вызывает аллергии. Протез изготавливается методом горячего прессования при высокой температуре, что обеспечивает однородную структуру.</p>
          </section>

          <section class="info-section">
            <h2>Кому подходит нейлоновый протез</h2>
            <ul>
              <li>Частичное отсутствие зубов (2 и более)</li>
              <li>Полное отсутствие зубов на челюсти</li>
              <li>Аллергия на акрил и металл</li>
              <li>Повышенная чувствительность дёсен и слизистой</li>
              <li>Непереносимость жёстких и твёрдых конструкций</li>
              <li>Пародонтит и пародонтоз (мягкое прилегание не травмирует десну)</li>
              <li>Высокие эстетические требования (кламмеры телесного цвета)</li>
              <li>Неровный альвеолярный гребень (мягко адаптируется к поверхности)</li>
              <li>Пациенты с рвотным рефлексом (мягкий край меньше раздражает)</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Сравнение с другими материалами</h2>
            <div class="materials-grid">
              <div class="material-card">
                <h3>Акрил</h3>
                <div class="material-price">от 15 000 ₽</div>
                <ul>
                  <li>Твёрдый, возможно натирание</li>
                  <li>Лучшая ремонтопригодность</li>
                  <li>Перебазировка возможна</li>
                  <li>Срок 5-7 лет</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>AcryFree</h3>
                <div class="material-price">от 41 400 ₽</div>
                <ul>
                  <li>Полужёсткий, баланс</li>
                  <li>Прочнее нейлона</li>
                  <li>Проще ремонт</li>
                  <li>Срок 3-5 лет</li>
                </ul>
              </div>
              <div class="material-card material-card--featured">
                <h3>Нейлон (рекомендуем)</h3>
                <div class="material-price">от 41 400 ₽</div>
                <ul>
                  <li>Мягкий и гибкий</li>
                  <li>Гипоаллергенный</li>
                  <li>Эстетичный, незаметен</li>
                  <li>Не натирает</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>ДенталДи</h3>
                <div class="material-price">от 52 200 ₽</div>
                <ul>
                  <li>Без металлической дуги</li>
                  <li>Белый термопластичный каркас</li>
                  <li>Гипоаллергенный</li>
                  <li>Срок 4-6 лет</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Свойства нейлона</h2>
            <p><strong>Гибкость:</strong> протез мягко прилегает к слизистой, не давит на дёсны. Гибкость позволяет протезу адаптироваться к неровной поверхности альвеолярного гребня. Твёрдость по Шору D около 75-80 единиц.</p>
            <p><strong>Гипоаллергенность:</strong> не содержит мономера, акрилата, латекса. Идеален для пациентов с аллергией на акриловые протезы или металлы.</p>
            <p><strong>Эстетика:</strong> полупрозрачный розовый цвет, имитирует слизистую оболочку. Кламмеры (крючки) также из нейлона телесного цвета — на передних зубах практически не заметны.</p>
            <p><strong>Лёгкость:</strong> нейлон легче акрила, меньше нагрузка на челюсть и оставшиеся зубы. Пациенты быстрее адаптируются к лёгким конструкциям.</p>
            <p><strong>Прочность:</strong> устойчив к ударам и переломам. Не ломается при падении на твёрдую поверхность (в отличие от акрила). Однако при точечной нагрузке может деформироваться.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества нейлона</h3><ul>
              <li><strong>Комфорт</strong> — мягкий и гибкий, не натирает дёсны</li>
              <li><strong>Эстетика</strong> — незаметен в полости рта, телесные кламмеры</li>
              <li><strong>Гипоаллергенность</strong> — без мономера, акрилата, латекса</li>
              <li><strong>Лёгкость</strong> — минимум дискомфорта, быстрая адаптация</li>
              <li><strong>Прочность</strong> — не ломается при падении</li>
              <li><strong>Адаптация</strong> — мягко прилегает к неровной слизистой</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — выше акриловых протезов</li>
              <li><strong>Ремонт сложнее</strong> — при серьёзных поломках может потребоваться замена</li>
              <li><strong>Уход</strong> — требует специальных средств, нельзя кипятить</li>
              <li><strong>Срок</strong> — 3-5 лет, меньше чем у бюгеля</li>
              <li><strong>Перебазировка</strong> — сложнее, чем акрила, иногда невозможна</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Статистика и показатели</h2>
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-value">3-5</div>
                <div class="stat-label">лет срок службы</div>
                <div class="stat-desc">при правильном уходе</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">75-80</div>
                <div class="stat-label">единиц твёрдости</div>
                <div class="stat-desc">по Шору D</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">0%</div>
                <div class="stat-label">мономер</div>
                <div class="stat-desc">полная гипоаллергенность</div>
              </div>
              <div class="stat-card">
                <div class="stat-value">92%</div>
                <div class="stat-label">пациентов</div>
                <div class="stat-desc">отмечают высокий комфорт</div>
              </div>
            </div>
          </section>

          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Консультация:</strong> осмотр полости рта, обсуждение плана лечения, оценка показаний для нейлонового протеза.</p>
            <p><strong>2. Снятие слепков:</strong> альгинатные оттиски обеих челюстей для диагностических и рабочих моделей.</p>
            <p><strong>3. Моделирование:</strong> на рабочей модели зубной техник моделирует конструкцию.</p>
            <p><strong>4. Изготовление:</strong> горячее прессование нейлона в специальной форме. Температура около 280°C, давление 6-8 атмосфер.</p>
            <p><strong>5. Примерка:</strong> проверка посадки, окклюзии, эстетики, комфорта.</p>
            <p><strong>6. Корректировка:</strong> при необходимости — подгонка базиса и кламмеров. Нейлон можно корректировать шлифовкой.</p>
            <p><strong>7. Установка:</strong> фиксация протеза, подробные рекомендации по уходу и адаптации.</p>
          </section>

          <section class="info-section"><h2>Протокол ухода за нейлоновым протезом</h2>
            <p><strong>После еды:</strong> промывайте протез тёплой водой. Избегайте кипятка — нейлон деформируется при высокой температуре (выше 80°C).</p>
            <p><strong>Чистка:</strong> мягкая зубная щётка + специальные средства для протезов. Не используйте абразивные пасты — они царапают поверхность.</p>
            <p><strong>Хранение:</strong> в контейнере с водой или специальным раствором. Не сушите на батарее — может деформироваться.</p>
            <p><strong>Избегайте:</strong> кипятка, агрессивных химических средств, абразивных паст, отбеливателей, ультразвуковых ванн.</p>
            <p><strong>Профессиональная чистка:</strong> раз в 6-12 месяцев у стоматолога. Только щадящие методы.</p>
            <p><strong>Не ремонтируйте самостоятельно:</strong> при повреждении — обратитесь в лабораторию.</p>
          </section>
          <section class="info-section">
            <h2>Когда подходит нейлоновый протез</h2>
            <ul>
              <li>Частичное или полное отсутствие зубов</li>
              <li>Аллергия на акрил и металл</li>
              <li>Повышенная чувствительность дёсен</li>
              <li>Непереносимость жёстких конструкций</li>
              <li>Пародонтит и пародонтоз</li>
              <li>Эстетические требования</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Свойства нейлона</h2>
            <p><strong>Гибкость:</strong> протез мягко прилегает к слизистой, не давит.</p>
            <p><strong>Гипоаллергенность:</strong> не содержит мономера, акрилата, латекса.</p>
            <p><strong>Эстетика:</strong> полупрозрачный розовый цвет, гибкие кламмеры телесного цвета.</p>
            <p><strong>Лёгкость:</strong> меньше нагрузка на челюсть и оставшиеся зубы.</p>
            <p><strong>Прочность:</strong> устойчив к переломам и деформации.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества нейлона</h3><ul>
              <li><strong>Комфорт</strong> — мягкий, не натирает</li>
              <li><strong>Эстетика</strong> — незаметен в полости рта</li>
              <li><strong>Гипоаллергенность</strong> — без мономера</li>
              <li><strong>Лёгкость</strong> — минимум дискомфорта</li>
              <li><strong>Прочность</strong> — не ломается при падении</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Цена</strong> — выше акриловых протезов</li>
              <li><strong>Ремонт</strong> — сложнее поддаётся переделке</li>
              <li><strong>Уход</strong> — требует специальных средств</li>
              <li><strong>Срок</strong> — 3-5 лет, меньше чем у бюгеля</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Консультация:</strong> осмотр, план лечения.</p>
            <p><strong>2. Снятие слепков:</strong> точное моделирование.</p>
            <p><strong>3. Изготовление:</strong> горячее прессование нейлона.</p>
            <p><strong>4. Примерка:</strong> проверка посадки и комфорта.</p>
            <p><strong>5. Корректировка:</strong> подгонка по необходимости.</p>
            <p><strong>6. Установка:</strong> фиксация, обучение уходу.</p>
          </section>
          <section class="info-section"><h2>Уход за нейлоновым протезом</h2>
            <p>Промывайте протез после каждого приёма пищи тёплой водой. Используйте мягкую щётку и специальные средства для протезов. Не используйте кипяток — нейлон может деформироваться.</p>
            <p>Храните в контейнере с водой или специальным раствором. Избегайте абразивных паст. Посещайте стоматолога для проверки состояния протеза и дёсен.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }

.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.material-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.material-card--featured {
  border-color: var(--color-primary);
  background: linear-gradient(to bottom, white, var(--color-bg-alt));
}
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.stat-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  text-align: center;
}
.stat-value { font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); }
.stat-label { font-size: var(--text-sm); color: var(--color-text); font-weight: 600; margin-top: var(--space-xs); }
.stat-desc { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: 2px; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>