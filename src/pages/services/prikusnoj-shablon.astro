---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Прикусной шаблон | Никитина М.Г." description="Прикусной шаблон для регистрации соотношения челюстей. Цена 1 140 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Прикусной шаблон</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Прикусной шаблон</h1>
          <div class="service-header__price">1 140 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое прикусной шаблон</h2>
            <p>Прикусной шаблон — это восковая или пластмассовая пластина, которая фиксирует взаимоотношение верхней и нижней челюстей. Используется для переноса положения зубных рядов в артикулятор.</p>
            <p>Шаблон изготавливается из воска, акрила или термопластичного материала. Он должен точно повторять форму зубных рядов и фиксировать прикусное соотношение.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Перенос прикуса в артикулятор</li>
              <li>Моделирование окклюзии</li>
              <li>Проверка прикуса при изготовлении протезов</li>
              <li>Ортодонтическая диагностика</li>
              <li>Подготовка к тотальному протезированию</li>
              <li>Фиксация центрального соотношения</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Виды прикусных шаблонов</h2>
            <p><strong>Восковый шаблон:</strong> классический вариант. Воск размягчается, прикусывается пациентом, застывает в нужном положении. Простой и доступный.</p>
            <p><strong>Пластмассовый шаблон:</strong> изготавливается заранее из акрила. Более стабилен, но сложнее в изготовлении.</p>
            <p><strong>Силиконовый:</strong> используется для особо точной фиксации. Силикон застывает и сохраняет форму.</p>
            <p><strong>CAD/CAM шаблон:</strong> цифровой вариант, изготовленный по данным сканирования.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества</h3><ul>
              <li><strong>Точность</strong> — фиксирует положение челюстей</li>
              <li><strong>Простота</strong> — быстрое изготовление</li>
              <li><strong>Доступность</strong> — недорого</li>
              <li><strong>Универсальность</strong> — подходит для большинства случаев</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Деформация</strong> — воск может деформироваться</li>
              <li><strong>Точность</strong> — стандартный шаблон менее точен, чем индивидуальный</li>
              <li><strong>Температура</strong> — воск чувствителен к температуре</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Подготовка:</strong> проверка прикуса в полости рта.</p>
            <p><strong>2. Разогрев воска:</strong> пластинка воска нагревается в теплой воде.</p>
            <p><strong>3. Фиксация:</strong> пациент прикусывает шаблон в нужном положении.</p>
            <p><strong>4. Охлаждение:</strong> воск застывает, фиксируя положение.</p>
            <p><strong>5. Проверка:</strong> проверка точности фиксации.</p>
          </section>
          <section class="info-section"><h2>Центральное соотношение</h2>
            <p>Прикусной шаблон часто используется для фиксации центрального соотношения — положения, при котором суставные головки находятся в центре суставных ямок.</p>
            <p>Это положение используется при:</p>
            <ul>
              <li>Полное отсутствие зубов</li>
              <li>Большие дефекты без передней группы зубов</li>
              <li>Тотальное протезирование</li>
              <li>Проблемы с прикусом</li>
            </ul>
            <p>Исследования показывают, что фиксация центрального соотношения с помощью прикусного шаблона обеспечивает достаточную точность для большинства клинических ситуаций.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>