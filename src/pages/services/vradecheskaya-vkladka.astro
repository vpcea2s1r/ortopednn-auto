---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Врачебная вкладка | Никитина М.Г." description="Врачебная вкладка — микропротезирование для восстановления разрушенного зуба. Цена 3 180 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Врачебная вкладка</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Врачебная вкладка</h1>
          <div class="service-header__price">3 180 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое врачебная вкладка</h2>
            <p>Врачебная вкладка (иногда называется культевая вкладка) — это микропротез, который устанавливается в корень зуба для его восстановления. Служит основой для будущей коронки.</p>
            <p>Вкладка изготавливается в лаборатории по индивидуальным слепкам и точно повторяет форму каналов зуба. Это обеспечивает плотное прилегание и долговечность конструкции.</p>
          </section>
          <section class="info-section">
            <h2>Показания к установке</h2>
            <ul>
              <li>Значительное разрушение коронковой части зуба</li>
              <li>Необходимость опоры для коронки</li>
              <li>Депульпированные зубы (без нерва)</li>
              <li>Аномалии формы зуба</li>
              <li>Пломба не может обеспечить прочность</li>
              <li>Подготовка к мостовидному протезу</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Виды вкладок</h2>
            <p><strong>Разборная:</strong> состоит из нескольких частей, устанавливается в сложные корневые каналы.</p>
            <p><strong>Несъёмная (цельнолитая):</strong> цельная конструкция для простых случаев.</p>
            <p><strong>Материал:</strong> металлические (кобальт-хром, золото), керамические, циркониевые.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества вкладки</h3><ul>
              <li><strong>Прочность</strong> — служит надёжной основой для коронки</li>
              <li><strong>Точность</strong> — изготавливается по индивидуальным слепкам</li>
              <li><strong>Долговечность</strong> — срок службы более 10 лет</li>
              <li><strong>Сохранение зуба</strong> — позволяет сохранить даже сильно разрушенный</li>
              <li><strong>Равномерная нагрузка</strong> — правильно распределяет жевательное давление</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Этапность</strong> — требуется несколько визитов</li>
              <li><strong>Обточка</strong> — зуб препарируется под вкладку</li>
              <li><strong>Цена</strong> — дороже обычной пломбы</li>
            </ul></section>
<div class="materials-grid">
            <h2 class="section-title">Виды врачебных вкладок</h2>
            <div class="materials-cards">
              <div class="material-card">
                <div class="material-card__header"><span class="material-icon">🩹</span><h3>Inlay (инлей)</h3></div>
                <div class="material-card__body">
                  <p>Вкладка внутри зуба, не заходит на бугры.</p>
                  <ul>
                    <li>Зона: полость зуба</li>
                    <li>Бугры: не перекрывает</li>
                    <li>Применение: небольшие дефекты</li>
                    <li>Материал: композит, керамика</li>
                  </ul>
                </div>
              </div>
              <div class="material-card">
                <div class="material-card__header"><span class="material-icon">🔲</span><h3>Onlay (онлей)</h3></div>
                <div class="material-card__body">
                  <p>Вкладка перекрывает один или несколько бугров.</p>
                  <ul>
                    <li>Зона: полость + бугры</li>
                    <li>Защита: усиленная</li>
                    <li>Применение: средние дефекты</li>
                    <li>Прочность: высокая</li>
                  </ul>
                </div>
              </div>
              <div class="material-card">
                <div class="material-card__header"><span class="material-icon">🏔️</span><h3>Overlay (оверлей)</h3></div>
                <div class="material-card__body">
                  <p>Вкладка перекрывает все бугры и часть стенок.</p>
                  <ul>
                    <li>Зона: вся жевательная поверхность</li>
                    <li>Защита: максимальная</li>
                    <li>Применение: сильное разрушение</li>
                    <li>Альтернатива: коронка</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card__value">3 180 ₽</div>
              <div class="stat-card__label">стоимость вкладки</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1 визит</div>
              <div class="stat-card__label">срок изготовления</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">10-15 лет</div>
              <div class="stat-card__label">срок службы</div>
            </div>
            <div class="stat-card">
              <div class="stat-card__value">1-2 часа</div>
              <div class="stat-card__label">время процедуры</div>
            </div>
          </div>
          <section class="info-section"><h2>Отличие от лабораторной вкладки</h2>
            <p>Врачебная вкладка делается прямо во рту за один визит. Лабораторная — в зуботехнической лаборатории по слепку, за 1-2 дня. Лабораторная точнее и прочнее, врачебная — быстрее и дешевле.</p>
            <p>Для небольших дефектов врачебная вкладка — отличный выбор. Для крупных реставраций лучше лабораторная.</p>
          </section>
        </div>
          <section class="info-section"><h2>Этапы изготовления и установки</h2>
            <p><strong>1. Подготовка:</strong> лечение каналов, пломбирование.</p>
            <p><strong>2. Снятие слепков:</strong> точные слепки корневых каналов.</p>
            <p><strong>3. Изготовление:</strong> лабораторное создание вкладки.</p>
            <p><strong>4. Примерка:</strong> проверка посадки.</p>
            <p><strong>5. Фиксация:</strong> цементирование вкладки в каналы.</p>
            <p><strong>6. Коронка:</strong> на вкладку устанавливается коронка.</p>
          </section>
          <section class="info-section"><h2>Вкладка vs пломба</h2>
            <p>Вкладка превосходит пломбу по прочности и долговечности. Она выдерживает значительные нагрузки и не даёт усадки со временем. Рекомендуется при разрушении более 30-50% зуба.</p>
            <p>Пломба подходит для небольших полостей. При значительном разрушении пломба может сломаться или выпасть, а вкладка прослужит десятилетия.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>