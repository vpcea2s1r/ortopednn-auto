---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';

export async function getStaticPaths() {
  const s = await getCollection('services');
  return s.map(i => {
    const slug = i.id.replace(/\.md$/, '');
    return {params: {slug}, props: {service: i, slug}};
  });
}

const { service, slug } = Astro.props;
---

<BaseLayout 
  title={service.data.title} 
  description={service.data.title} 
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="container">
    <a href="/" class="back">← На главную</a>
    
    <article class="service-page">
      <div class="service-header">
        <h1>{service.data.title}</h1>
        <div class="price-badge">
          {new Intl.NumberFormat('ru', {style: 'currency', currency: 'RUB'}).format(service.data.price)}
        </div>
      </div>
      
      <div class="content">
        <div set:html={service.render().Content}></div>
      </div>
      
      <div class="cta-box">
        <p>Заинтересовала услуга?</p>
        <a href={`tel:${doctor.phone}`} class="btn">Позвонить</a>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
.container {
  max-width: 800px;
  margin: 0 auto;
  padding: 32px 24px;
}

.back {
  color: var(--primary);
  font-weight: 500;
  margin-bottom: 24px;
  display: inline-block;
}

.service-page {
  background: white;
  border-radius: 16px;
  padding: 40px;
  border: 1px solid var(--border);
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--border);
}

.service-header h1 {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--text);
}

.price-badge {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
  padding: 12px 24px;
  border-radius: 12px;
  font-weight: 700;
  font-size: 1.125rem;
}

.content {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--text-muted);
}

.content :global(h2) {
  color: var(--text);
  font-size: 1.25rem;
  font-weight: 700;
  margin: 32px 0 16px;
}

.content :global(h3) {
  color: var(--primary);
  font-size: 1rem;
  font-weight: 600;
  margin: 24px 0 12px;
}

.content :global(p) {
  margin-bottom: 16px;
}

.content :global(ul) {
  padding-left: 20px;
  margin-bottom: 16px;
}

.content :global(li) {
  margin-bottom: 8px;
}

.cta-box {
  background: linear-gradient(135deg, var(--primary-light) 0%, #f5f3ff 100%);
  border-radius: 16px;
  padding: 32px;
  text-align: center;
  margin-top: 40px;
}

.cta-box p {
  color: var(--text-muted);
  margin-bottom: 16px;
  font-size: 1.125rem;
}

.btn {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
  padding: 14px 32px;
  border-radius: 12px;
  font-weight: 600;
  text-decoration: none;
  box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
}

.btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
}

@media (max-width: 640px) {
  .service-page {
    padding: 24px;
  }
  .service-header {
    flex-direction: column;
    gap: 16px;
  }
  .price-badge {
    width: 100%;
    text-align: center;
  }
}
</style>