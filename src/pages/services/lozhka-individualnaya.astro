---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout title="Ложка индивидуальная | Никитина М.Г." description="Индивидуальная оттискная ложка по модели. Цена 3 000 руб." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="service-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/services">Услуги</a><span>/</span><span>Ложка индивидуальная</span></div></nav>
    <article class="service-content"><div class="container">
        <header class="service-header">
          <h1 class="service-header__title">Ложка индивидуальная</h1>
          <div class="service-header__price">3 000 ₽</div>
        </header>
        <div class="service-body">
          <section class="info-section">
            <h2>Что такое индивидуальная ложка</h2>
            <p>Индивидуальная оттискная ложка — это ложка, изготовленная по модели конкретного пациента. В отличие от стандартных ложек, она точно повторяет форму альвеолярного гребня и обеспечивает равномерное распределение оттискного материала.</p>
            <p>Индивидуальная ложка необходима для точных работ и является золотым стандартом для беззубых челюстей. Стандартные ложки не могут обеспечить точную посадку на беззубую челюсть.</p>
          </section>

          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Точные оттиски для коронок и мостовидных протезов</li>
              <li>Оттиски при полном отсутствии зубов</li>
              <li>Сложные клинические случаи</li>
              <li>Глубокие поддесневые уступы</li>
              <li>Узкие альвеолярные гребни</li>
              <li>Выраженные торусы и экзостозы</li>
              <li>Работы на имплантатах</li>
            </ul>
          </section>

          <section class="info-section">
            <h2>Сравнение видов ложек</h2>
            <div class="materials-grid">
              <div class="material-card">
                <h3>Стандартная</h3>
                <div class="material-price">базовая</div>
                <ul>
                  <li>Универсальный размер</li>
                  <li>Не точно</li>
                  <li>Дешёвая</li>
                  <li>Только для диагностики</li>
                </ul>
              </div>
              <div class="material-card material-card--featured">
                <h3>Индивидуальная</h3>
                <div class="material-price">точная</div>
                <ul>
                  <li>По модели пациента</li>
                  <li>Идеальная посадка</li>
                  <li>Равномерный слой</li>
                  <li>Золотой стандарт</li>
                </ul>
              </div>
              <div class="material-card">
                <h3>CAD/CAM</h3>
                <div class="material-price">цифровая</div>
                <ul>
                  <li>Фрезерованная</li>
                  <li>Высочайшая точность</li>
                  <li>Дорогая</li>
                  <li>Будущее</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="info-section">
            <h2>Материалы для изготовления</h2>
            <p><strong>Термопластичный материал:</strong> пластины, размягчаемые при нагревании. Лёгкие в изготовлении, но деформируются со временем. Толщина 1-1.5 мм.</p>
            <p><strong>Акрил:</strong> самый распространённый материал. Прочный, стабильный, долговечный. Толщина 2-3 мм. Можно корректировать.</p>
            <p><strong>Фотополимер:</strong> светоотверждаемый материал. Быстрое изготовление (на приёме), хорошая точность. Не деформируется.</p>
            <p><strong>CAD/CAM:</strong> цифровое изготовление из пластика или металла. Высочайшая точность, но дорого.</p>
          </section>

          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества индивидуальной ложки</h3><ul>
              <li><strong>Точность</strong> — идеально подходит пациенту</li>
              <li><strong>Комфорт</strong> — удобнее стандартной</li>
              <li><strong>Равномерность</strong> — материал распределяется равномерно</li>
              <li><strong>Меньше искажений</strong> — выше качество оттиска</li>
              <li><strong>Повторное использование</strong> — можно использовать для последующих оттисков</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Учитывайте</h3><ul>
              <li><strong>Время</strong> — требуется лабораторный этап (кроме фотополимера)</li>
              <li><strong>Стоимость</strong> — дороже стандартной ложки</li>
              <li><strong>Хранение</strong> — требует правильного хранения</li>
            </ul></section>
          </div>

          <section class="info-section">
            <h2>Этапы изготовления</h2>
            <p><strong>1. Оттиск:</strong> снимается предварительный оттиск стандартной ложкой для получения модели.</p>
            <p><strong>2. Модель:</strong> отливается модель челюсти из гипса.</p>
            <p><strong>3. Изготовление:</strong> из материала формируется ложка по модели с запасом 3-5 мм от тканей.</p>
            <p><strong>4. Обработка:</strong> обрезка краёв, шлифовка, формирование ручек.</p>
            <p><strong>5. Проверка:</strong> проверка посадки в полости рта.</p>
            <p><strong>6. Адгезив:</strong> на внутреннюю поверхность наносится адгезив для оттискного материала.</p>
          </section>

          <section class="info-section">
            <h2>Требования к ложке</h2>
            <p><strong>Края:</strong> должны перекрывать зубы/гребень на 3-5 мм, не давить на слизистую, повторять переходную складку.</p>
            <p><strong>Ручка:</strong> удобная для удержания, не мешает открыванию рта, расположена спереди.</p>
            <p><strong>Толщина:</strong> равномерная, 2-3 мм. Слишком тонкая — деформируется. Слишком толстая — дискомфорт.</p>
            <p><strong>Поверхность:</strong> гладкая, без острых краёв.</p>
            <p><strong>Адгезия:</strong> внутренняя поверхность должна удерживать оттискный материал.</p>
          </section>
          <section class="info-section">
            <h2>Когда применяется</h2>
            <ul>
              <li>Точные оттиски для коронок и мостовидных протезов</li>
              <li>Оттиски при полном отсутствии зубов</li>
              <li>Сложные клинические случаи</li>
              <li>Глубокие поддесневые уступы</li>
              <li>Узкие альвеолярные гребни</li>
              <li>Выраженные торусы и экзостозы</li>
            </ul>
          </section>
          <section class="info-section">
            <h2>Материалы для изготовления</h2>
            <p><strong>Термопластичный материал:</strong> пластины, размягчаемые при нагревании. Лёгкие в изготовлении, но деформируются со временем.</p>
            <p><strong>Акрил:</strong> самый распространённый материал. Прочный, стабильный, долговечный.</p>
            <p><strong>Фотополимер:</strong> светоотверждаемый материал. Быстрое изготовление, хорошая точность.</p>
            <p><strong>CAD/CAM:</strong> цифровое изготовление из пластика или металла. Высочайшая точность.</p>
          </section>
          <div class="info-grid">
            <section class="info-block info-block--pros"><h3>Преимущества индивидуальной ложки</h3><ul>
              <li><strong>Точность</strong> — идеально подходит пациенту</li>
              <li><strong>Комфорт</strong> — удобнее стандартной</li>
              <li><strong>Равномерность</strong> — материал распределяется равномерно</li>
              <li><strong>Меньше искажений</strong> — выше качество оттиска</li>
              <li><strong>Повторное использование</strong> — можно использовать повторно</li>
            </ul></section>
            <section class="info-block info-block--cons"><h3>Что учитывать</h3><ul>
              <li><strong>Время</strong> — требуется лабораторный этап</li>
              <li><strong>Стоимость</strong> — дороже стандартной ложки</li>
              <li><strong>Хранение</strong> — требует правильного хранения</li>
            </ul></section>
          </div>
          <section class="info-section"><h2>Этапы изготовления</h2>
            <p><strong>1. Оттиск:</strong> снимается предварительный оттиск стандартной ложкой.</p>
            <p><strong>2. Модель:</strong> отливается модель челюсти.</p>
            <p><strong>3. Изготовление:</strong> из материала формируется ложка по модели с запасом 3-5 мм от тканей.</p>
            <p><strong>4. Обработка:</strong> обрезка краёв, шлифовка, формирование ручек.</p>
            <p><strong>5. Проверка:</strong> проверка посадки в полости рта.</p>
            <p><strong>6. Адгезив:</strong> на внутреннюю поверхность наносится адгезив для оттискного материала.</p>
          </section>
          <section class="info-section"><h2>Требования к ложке</h2>
            <p><strong>Края:</strong> должны перекрывать зубы/гребень на 3-5 мм, не давить на слизистую.</p>
            <p><strong>Ручка:</strong> удобная для удержания, не мешает открыванию рта.</p>
            <p><strong>Толщина:</strong> равномерная, 2-3 мм.</p>
            <p><strong>Поверхность:</strong> гладкая, без острых краёв.</p>
            <p><strong>Адгезия:</strong> внутренняя поверхность должна удерживать оттискный материал.</p>
          </section>
        </div>
        <div class="service-cta"><p>Нужна консультация?</p><div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Telegram</a></div></div>
    </div></article>
  </main>
</BaseLayout>

<style>
.service-page { min-height: 100vh; }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.service-content { padding: var(--space-3xl) 0; }
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); flex-wrap: wrap; gap: var(--space-md); }
.service-header__title { font-size: var(--text-3xl); color: var(--color-text); }
.service-header__price { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-lg); font-weight: 700; font-size: var(--text-xl); }
.info-section { margin-bottom: var(--space-xl); }
.info-section h2 { font-size: var(--text-xl); color: var(--color-primary); margin-bottom: var(--space-md); }
.info-section p { color: var(--color-text-muted); line-height: 1.7; }
.info-section ul { padding-left: var(--space-lg); }
.info-section li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.6; }

.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}
.material-card {
  background: white;
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
}
.material-card--featured { border-color: var(--color-primary); background: linear-gradient(to bottom, white, var(--color-bg-alt)); }
.material-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); }
.material-price { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.material-card ul { list-style: none; padding: 0; }
.material-card li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 2px 0; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-xl); }
.info-block { background: white; padding: var(--space-lg); border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.info-block h3 { font-size: var(--text-lg); color: var(--color-text); margin-bottom: var(--space-md); }
.info-block ul { list-style: none; padding: 0; }
.info-block li { color: var(--color-text-muted); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-bg); }
.service-cta { text-align: center; padding: var(--space-2xl); background: var(--color-bg-alt); border-radius: var(--radius-xl); margin-top: var(--space-xl); }
.service-cta p { color: var(--color-text-muted); margin-bottom: var(--space-md); }
.cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: var(--space-xs); background: var(--color-primary); color: white; padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; transition: all var(--transition-fast); }
.btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
.btn--secondary { background: white; color: var(--color-primary); border: 1px solid var(--color-primary); }
@media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .service-header { flex-direction: column; } .service-header__price { width: 100%; text-align: center; } }
</style>