  .faq-item { background: var(--color-bg-alt); border-radius: 8px; padding: 1rem; margin-bottom: 0.8rem; }
  .faq-item h3 { margin-top: 0; font-size: 1rem; color: var(--color-text); }
  .faq-item p { margin-bottom: 0; }
  .cta { text-align: center; padding: 1.5rem; background: var(--color-bg-alt); border-radius: 8px; margin-top: 2rem; }
