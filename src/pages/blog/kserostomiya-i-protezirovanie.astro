---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'kserostomiya-i-protezirovanie';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Ксеростомия (сухость во рту) и протезирование зубов",
  "description": "Причины сухости во рту, влияние на ношение протезов. Облегчение симптомов, увлажнение, выбор конструкции протеза при ксеростомии.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-06-15",
  "dateModified": "2026-06-15",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout
  title="Ксеростомия (сухость во рту) и протезирование зубов в Нижнем Новгороде"
  description="Сухость во рту и протезы — как они связаны. Причины ксеростомии, облегчение симптомов, выбор протеза. Телефон +7 (920) 253-73-17."
  breadcrumbTitle="Ксеростомия и протезирование"
  doctor={doctor}
  socials={socials}
  datePublished="2026-06-15"
  dateModified="2026-06-15"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Ксеростомия (сухость во рту) и протезирование зубов</h1>
      <div class="meta">15 июня 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead"><strong>Ксеростомия</strong> — сухость во рту из-за снижения выработки слюны. Это не болезнь, а симптом. Слюна защищает зубы, увлажняет слизистую, помогает говорить и глотать. При её нехватке носить зубные протезы становится сложнее, а риск воспаления растёт.</p>

      <h2>Почему возникает сухость во рту</h2>
      <p>Самые частые причины:</p>
      <ul>
        <li><strong>Лекарства</strong> — антидепрессанты, антигистаминные, диуретики, гипотензивные. Более 400 препаратов вызывают сухость</li>
        <li><strong>Сахарный диабет</strong> — один из ранних симптомов</li>
        <li><strong>Аутоиммунные заболевания</strong> — синдром Шегрена, ревматоидный артрит</li>
        <li><strong>Лучевая терапия</strong> — при раке головы и шеи слюнные железы повреждаются</li>
        <li><strong>Возраст</strong> — с годами слюнные железы работают хуже</li>
      </ul>

      <h2>Как сухость во рту влияет на зубные протезы</h2>
      <p>Слюна выполняет роль естественного смазочного материала. Для съёмных протезов это критично:</p>
      <ul>
        <li><strong>Фиксация</strong> — протез хуже прилегает, съезжает, натирает</li>
        <li><strong>Трение</strong> — без слюны протез трёт слизистую, появляются язвы и трещины</li>
        <li><strong>Инфекции</strong> — слюна подавляет бактерии и грибки. Без неё чаще развивается кандидоз (молочница)</li>
        <li><strong>Дикция</strong> — без смазки говорить сложнее, протез щёлкает</li>
      </ul>

      <h2>Рекомендации для пациентов с ксеростомией</h2>
      <h3>Увлажнение</h3>
      <ul>
        <li>Пейте воду маленькими глотками в течение дня — не меньше 1,5–2 литров</li>
        <li>Используйте искусственную слюну (спреи BioXtra, Dentaid Xeros) — по необходимости</li>
        <li>Жевательная резинка без сахара стимулирует слюноотделение</li>
        <li>Леденцы с ксилитом — увлажняют и защищают от кариеса</li>
      </ul>

      <h3>Уход за протезами</h3>
      <ul>
        <li>Увлажняйте протез перед установкой — подержите в воде 1–2 минуты</li>
        <li>Используйте фиксирующий крем (Corega, Protefix) — он компенсирует недостаток фиксации</li>
        <li>Чистите протез мягкой щёткой без абразивных паст</li>
        <li>На ночь замачивайте протез в увлажняющем растворе</li>
      </ul>

      <h3>Материалы протезов</h3>
      <p>При ксеростомии предпочтительны гибкие материалы — <a href="/services/nejlonovyj-protez">нейлон</a> или <a href="/services/acri-free">AcryFree</a>. Они не раздражают слизистую даже при недостатке слюны. Жёсткий акрил чаще провоцирует натирание.</p>

      <h2>Когда обратиться к врачу</h2>
      <p>Если сухость сохраняется больше 2–3 недель, запишитесь к терапевту или стоматологу. Причина может быть в скрытом заболевании. Заодно врач подберёт оптимальную конструкцию протеза.</p>

      <h2>FAQ</h2>

      <h3>Может ли протез сам вызывать сухость во рту?</h3>
      <p>Да, особенно если протез перекрывает выводные протоки слюнных желёз. Обычно это исправляется коррекцией или заменой конструкции.</p>

      <h3>Помогают ли ополаскиватели при сухости?</h3>
      <p>Только специальные — без спирта и с увлажняющими компонентами (ксилит, алоэ). Обычные ополаскиватели с ментолом и спиртом сушат ещё сильнее.</p>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Носите протез и чувствуете сухость во рту?</p>
        <a href={`tel:${doctor.phone}`} class="btn">Позвонить: +7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
article { background: white; border-radius: 12px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
.meta { color: #7a9ab8; font-size: 0.9rem; margin-bottom: 1rem; }
.lead { font-size: 1.1rem; color: #5a7a9a; margin-bottom: 2rem; }
h2 { color: #2e6ab3; margin: 2rem 0 1rem; font-size: 1.3rem; }
h3 { color: #1e3a5f; margin: 1.5rem 0 0.75rem; font-size: 1.1rem; }
p { color: #5a7a9a; line-height: 1.7; margin-bottom: 1rem; }
ul { color: #5a7a9a; padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
a { color: #4a90d9; }
.cta { text-align: center; padding: 1.5rem; background: #f8fafc; border-radius: 8px; margin-top: 2rem; }
.cta p { margin-bottom: 1rem; }
.btn { display: inline-block; background: #4a90d9; color: white; padding: 0.75rem 2rem; border-radius: 100px; text-decoration: none; font-weight: 600; }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
