const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Имплантация при пародонтите: можно ли ставить импланты",
  "description": "Имплантация зубов при пародонтите: показания, противопоказания, подготовка, особенности. Можно ли ставить импланты при пародонтите.",
