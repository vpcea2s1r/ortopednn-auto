const catId = category ? category.id : null;
const ldArticle = {"@context": "https://schema.org", "@type": "Article", "headline": "3D печать зубных протезов — технологии в стоматологии", "description": "3D-печать в стоматологии: диагностические модели, хирургические шаблоны, временные коронки, базисы протезов. Как работает цифровой протокол.", "author": {"@type": "Person", "name": "Никитина Марина Георгиевна", "medicalSpecialty": "Prosthodontics"}, "datePublished": "2026-06-01", "dateModified": "2026-06-01", "mainEntityOfPage": {"@type": "WebPage", "@id": "https://ortopednn.ru/blog/3d-pechat-zubnykh-protezov/"}, "image": "https://ortopednn.ru/og-image.svg", "publisher": {"@type": "Organization", "name": "ОртопедНН"}};
