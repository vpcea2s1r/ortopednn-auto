---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'bisfosfonaty-i-osteonekroz';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Бисфосфонаты и остеонекроз челюсти — риски, профилактика, стоматологическое ведение",
  "description": "Как бисфосфонаты влияют на челюстную кость. Риск остеонекроза челюсти при приёме препаратов. Подготовка к протезированию и имплантации.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-06-15",
  "dateModified": "2026-06-15",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout
  title="Бисфосфонаты и остеонекроз челюсти в Нижнем Новгороде"
  description="Как бисфосфонаты влияют на кость челюсти. Риск остеонекроза, подготовка к протезированию. Запись +7 (920) 253-73-17."
  breadcrumbTitle="Бисфосфонаты и остеонекроз"
  doctor={doctor}
  socials={socials}
  datePublished="2026-06-15"
  dateModified="2026-06-15"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Бисфосфонаты и остеонекроз челюсти</h1>
      <div class="meta">15 июня 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead"><strong>Короткий ответ:</strong> бисфосфонаты повышают риск остеонекроза челюсти — отмирания участка костной ткани. Осложнение редкое (0.1–5%), но серьёзное. Перед имплантацией или удалением зуба нужен перерыв в приёме — обычно 3 месяца. Решение принимает врач.</p>

      <h2>Что такое бисфосфонаты и зачем их назначают</h2>
      <p>Бисфосфонаты — это группа препаратов для лечения остеопороза, метастазов в костях, миеломы и других заболеваний костной ткани. Они замедляют разрушение кости, но заодно подавляют её регенерацию.</p>
      <p>Торговые названия: Алендронат (Фосамакс), Золедроновая кислота (Акласта, Зомета), Ибандронат (Бонвива), Ризедронат (Актонель). Внутривенные формы дают более высокий риск, чем таблетированные.</p>

      <h2>Остеонекроз челюсти — что это</h2>
      <p>Остеонекроз — отмирание участка челюстной кости. Кость перестаёт кровоснабжаться, обнажается через слизистую, не заживает 8 недель и дольше. Выглядит как открытый участок кости в полости рта, часто с гноем и болью.</p>
      <p>В 2023 году у пациентов с бисфосфонатами остеонекроз возникает с частотой:</p>
      <ul>
        <li>при приёме таблеток от остеопороза — 0.1–1%</li>
        <li>при внутривенном введении (онкология) — 1–10%</li>
        <li>после удаления зуба на фоне бисфосфонатов — до 5%</li>
      </ul>

      <h2>Что делать перед стоматологическим лечением</h2>
      <p>Если вы принимаете бисфосфонаты, сообщите стоматологу до начала лечения. Врач должен знать:</p>
      <ul>
        <li>название препарата и дозировку</li>
        <li>как долго вы принимаете (месяцы или годы)</li>
        <li>перорально или внутривенно</li>
        <li>результаты анализа крови (СТХ — маркер костного обмена)</li>
      </ul>
      <p>Стандартные рекомендации (<em>AAOMS</em>, 2022): если планируется имплантация, удаление или костная пластика — приём таблетированных бисфосфонатов приостанавливают на 3 месяца до и 3 месяца после операции. При внутривенных формах перерыв решает онколог.</p>

      <h2>Можно ли ставить импланты на фоне бисфосфонатов</h2>
      <p>Да, но с оговорками. Если пациент принимает бисфосфонаты меньше 3 лет и нет других факторов риска, имплантацию можно проводить без перерыва. При более длительном приёме нужен перерыв 3 месяца.</p>
      <p>После установки имплантов пациент должен соблюдать гигиену строже обычного — остеонекроз может начаться с обычного воспаления вокруг импланта.</p>

      <h2>Альтернативы для пациентов из группы риска</h2>
      <ul>
        <li><strong><a href="/services/nejlonovyj-protez">Нейлоновые протезы</a></strong> — без сверления кости</li>
        <li><strong><a href="/services/byugelnyj/">Бюгельные протезы</a></strong> — опора на зубы, не трогает кость</li>
        <li><strong>Мостовидные протезы</strong> — при наличии опорных зубов</li>
      </ul>

      <h2>Что важно запомнить</h2>
      <ul>
        <li>Не прекращайте бисфосфонаты самостоятельно — это может привести к перелому</li>
        <li>Перед любой костной операцией сообщите стоматологу о приёме этих препаратов</li>
        <li>Остеонекроз лечится, но долго — от 3 месяцев до года</li>
        <li>Гигиена полости рта на фоне бисфосфонатов критически важна</li>
      </ul>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Принимаете бисфосфонаты и планируете протезирование?</p>
        <a href={`tel:${doctor.phone}`} class="btn">Позвонить: +7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
article { background: white; border-radius: 12px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
.meta { color: #7a9ab8; font-size: 0.9rem; margin-bottom: 1rem; }
.lead { font-size: 1.1rem; color: #5a7a9a; margin-bottom: 2rem; }
h2 { color: #2e6ab3; margin: 2rem 0 1rem; font-size: 1.3rem; }
h3 { color: #1e3a5f; margin: 1.5rem 0 0.75rem; font-size: 1.1rem; }
p { color: #5a7a9a; line-height: 1.7; margin-bottom: 1rem; }
ul { color: #5a7a9a; padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
a { color: #4a90d9; }
.cta { text-align: center; padding: 1.5rem; background: #f8fafc; border-radius: 8px; margin-top: 2rem; }
.cta p { margin-bottom: 1rem; }
.btn { display: inline-block; background: #4a90d9; color: white; padding: 0.75rem 2rem; border-radius: 100px; text-decoration: none; font-weight: 600; }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
