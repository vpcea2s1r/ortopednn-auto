---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'implant-ili-most-chto-luchshe';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Имплант или мост — что лучше: сравнение, плюсы и минусы",
  "description": "Имплант или мост: что лучше при отсутствии одного или нескольких зубов. Сравнение по цене, сроку службы, сохранению кости, эстетике. Таблица различий.",
  "author": { "@type": "Person", "name": "Никитина Марина Георгиевна", "medicalSpecialty": "Prosthodontics" },
  "datePublished": "2026-05-31",
  "dateModified": "2026-05-31",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@type": "Organization", "name": "ОртопедНН" }
};
---

<BaseLayout 
  title="Имплант или мост — что лучше: сравнение, плюсы и минусы | Никитина М.Г."
  description="Имплант или мост при отсутствии зуба — что выбрать. Сравнение по цене, долговечности, сохранению соседних зубов и костной ткани. Когда мост лучше импланта."
  breadcrumbTitle="Имплант или мост — что лучше"
  doctor={doctor}
  socials={socials}
  datePublished="2026-05-31"
  dateModified="2026-05-31"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Имплант или мост — что лучше: сравнение, плюсы и минусы</h1>
      <div class="meta">31 мая 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead"><strong>TL;DR:</strong> Имплант предпочтительнее, если здоровые соседние зубы не хотят обтачивать и есть бюджет и время. Мост — если нужно быстро, дёшево, или рядом уже стоят коронки. Имплант сохраняет кость и служит дольше. Мост делается за 2–4 недели, имплант — 4–7 месяцев.</p>

      <h2>Принципиальная разница</h2>

      <p>Имплант замещает корень зуба — титановый стержень вживляется в кость, на него ставится коронка. Соседние зубы не трогают.</p>

      <p>Мостовидный протез замещает зуб с опорой на соседние зубы — их обтачивают под коронки, а между ними крепится искусственный зуб.</p>

      <p>Это два принципиально разных подхода: сохранить соседние зубы (имплант) или использовать их как опору (мост).</p>

      <h2>Сравнительная таблица</h2>

      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Параметр</th><th>Имплант</th><th>Мост</th></tr>
        </thead>
        <tbody>
          <tr><td>Обточка соседних зубов</td><td>Не нужна</td><td>Нужна — снимают эмаль со здоровых зубов</td></tr>
          <tr><td>Сохранение кости</td><td>Предотвращает атрофию</td><td>Кость под мостом атрофируется</td></tr>
          <tr><td>Срок службы</td><td>20+ лет (средний 15–25)</td><td>8–12 лет, потом замена</td></tr>
          <tr><td>Срок лечения</td><td>4–7 месяцев</td><td>2–4 недели</td></tr>
          <tr><td>Цена за 1 зуб</td><td>40 000–80 000 руб.</td><td>20 000–35 000 руб.</td></tr>
          <tr><td>Эстетика</td><td>Максимальная</td><td>Хорошая (зависит от материала)</td></tr>
          <tr><td>Гигиена</td><td>Как обычный зуб</td><td>Нужен ирригатор, сложнее чистить</td></tr>
          <tr><td>Ограничения по нагрузке</td><td>Нет, как свой зуб</td><td>Нельзя грызть твёрдое</td></tr>
          <tr><td>Хирургия</td><td>Нужна операция</td><td>Без хирургии</td></tr>
        </tbody>
      </table>
      </div>

      <h2>Когда выбирать имплант</h2>

      <ul>
        <li>Соседние зубы здоровы, нет пломб и коронок</li>
        <li>Есть бюджет и время на полноценное лечение</li>
        <li>Важна долговечность — имплант обычно ставится один раз</li>
        <li>Хотите сохранить кость на месте отсутствующего зуба</li>
        <li>Готовы к хирургическому этапу</li>
      </ul>

      <h2>Когда выбирать мост</h2>

      <ul>
        <li>На соседних зубах уже есть коронки или большие пломбы</li>
        <li>Противопоказания к имплантации (диабет, остеопороз, курение)</li>
        <li>Недостаточно костной ткани, а костная пластика нежелательна</li>
        <li>Нужно быстро — мост делается за 2–4 недели</li>
        <li>Бюджет ограничен</li>
      </ul>

      <h2>Что дольше служит</h2>

      <p>Большинство исследований показывают преимущество имплантов. По данным обзора в <em>Journal of Dentistry</em> (2023), 10-летняя выживаемость одиночных имплантов — 95.6%, мостов — 82.3%. Однако при правильном уходе мост может прослужить 12–15 лет. Имплант при хорошей гигиене может стоять десятилетиями.</p>
      <p class="translation">10-летняя выживаемость: импланты 95.6%, мосты 82.3%.</p>

      <h2>Что дороже в долгосрочной перспективе</h2>

      <p>Имплант дороже на старте, но дешевле в долгосрочной перспективе. Мост дешевле сейчас, но его придётся менять каждые 8–12 лет. За 30 лет пациент с мостом может потратить больше, чем пациент с имплантом, из-за повторных протезирований и лечения зубов под мостом.</p>

      <p>Кроме того, под мостом на опорных зубах часто развивается кариес — это дополнительное лечение, которое может привести к потере опорных зубов.</p>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Не знаете, что выбрать? Приходите на консультацию</p>
        <a href={`tel:${doctor.phone}`} class="btn">+7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--color-primary); margin-bottom: 1rem; display: inline-block; }
article { background: white; border-radius: 12px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
h1 { color: var(--color-text); margin-bottom: 0.5rem; font-size: 1.75rem; }
.meta { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }
.lead { font-size: 1.1rem; color: var(--color-text); line-height: 1.7; margin-bottom: 2rem; background: var(--color-bg-alt); padding: 1rem; border-radius: 8px; }
h2 { color: var(--color-primary); margin: 2rem 0 1rem; font-size: 1.3rem; }
p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: 1rem; }
ul, ol { color: var(--color-text-muted); padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
.translation { font-style: italic; color: var(--color-text); background: var(--color-bg-alt); padding: 0.75rem; border-radius: 8px; }
.table-wrap { overflow-x: auto; margin: 1rem 0; }
table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid #e5e7eb; }
th { background: var(--color-bg-alt); font-weight: 600; color: var(--color-text); }
td { color: var(--color-text-muted); }
.cta { text-align: center; padding: 1.5rem; background: var(--color-bg-alt); border-radius: 8px; margin-top: 2rem; }
.cta p { margin-bottom: 1rem; color: var(--color-text); }
.btn { display: inline-block; background: var(--color-primary); color: white; padding: 0.75rem 2rem; border-radius: var(--radius-full); text-decoration: none; font-weight: 600; }
.btn:hover { background: var(--color-primary-hover); }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
