---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'skolko-delayut-koronku';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Сколько делают коронку на зуб: сроки изготовления",
  "description": "Сколько делают зубную коронку: от слепка до установки. Сроки изготовления разных видов — металлокерамика, цирконий, керамика, пластмасса.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-05-26",
  "dateModified": "2026-05-26",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout 
  title="Сколько делают коронку на зуб: сроки изготовления | Никитина М.Г."
  description="Сколько делают коронку на зуб: от визита к врачу до фиксации. Сроки для металлокерамики, циркония, E-max, пластмассы. Почему ждать 7-14 дней."
  breadcrumbTitle="Сколько делают коронку"
  doctor={doctor}
  socials={socials}
  datePublished="2026-05-26"
  dateModified="2026-05-26"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Сколько делают коронку на зуб: сроки изготовления</h1>
      <div class="meta">26 мая 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead">Стандартный срок изготовления коронки — от 7 до 14 рабочих дней. Время зависит от материала, загруженности лаборатории и сложности работы. Быстрее всего — пластмассовая коронка (за день), дольше всего — керамическая или циркониевая.</p>

      <h2>Этапы изготовления коронки</h2>
      <ul>
        <li><strong>Первое посещение</strong> — обточка зуба, снятие слепков, установка временной коронки. 1 час.</li>
        <li><strong>Работа в лаборатории</strong> — отливка модели, моделирование коронки, нанесение керамики, обжиг. 7–14 дней.</li>
        <li><strong>Примерка и фиксация</strong> — врач проверяет прилегание, цвет, контакт с соседними зубами. Фиксирует на цемент. 30–60 минут.</li>
      </ul>

      <h2>Сроки по материалам</h2>
      <div class="table-wrap">
        <table>
          <tr><th>Материал</th><th>Срок</th></tr>
          <tr><td>Пластмассовая (временная)</td><td>1 день</td></tr>
          <tr><td>Металлокерамика</td><td>7–10 дней</td></tr>
          <tr><td>Циркониевая</td><td>10–14 дней</td></tr>
          <tr><td>E-max (прессованная керамика)</td><td>10–14 дней</td></tr>
          <tr><td>Цельнолитая металлическая</td><td>5–7 дней</td></tr>
        </table>
      </div>

      <h2>Почему нельзя сделать за один день?</h2>
      <p>Коронка изготавливается в зуботехнической лаборатории. Техник отливает гипсовую модель, наносит керамику слоями, обжигает при высокой температуре. Каждый слой керамики требует обжига. Для циркония нужна фрезеровка блока и окрашивание. Это ручная работа, которая занимает время.</p>

      <h2>Что влияет на сроки</h2>
      <ul>
        <li>Загруженность лаборатории</li>
        <li>Количество коронок (одиночная быстрее, мост дольше)</li>
        <li>Необходимость дополнительных примерок</li>
        <li>Керамическая индивидуальная роспись</li>
      </ul>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Нужна коронка? Приходите — обточим, поставим временную, закажем постоянную.</p>
        <a href={`tel:${doctor.phone}`} class="btn">+7 (920) 253-73-17</a>
      </div>

    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
  main { max-width: 800px; margin: 0 auto; padding: 1.5rem; }
  .back { color: var(--color-primary); text-decoration: none; font-size: 0.9rem; }
  .back:hover { text-decoration: underline; }
  h1 { font-size: 1.8rem; color: var(--color-text); margin-bottom: 0.5rem; }
  .meta { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .lead { background: var(--color-bg-alt); padding: 1rem 1.2rem; border-radius: 8px; font-size: 1.05rem; line-height: 1.6; margin-bottom: 1.5rem; }
  h2 { font-size: 1.35rem; color: var(--color-primary); margin-top: 1.8rem; margin-bottom: 0.8rem; }
  p { line-height: 1.7; color: var(--color-text-muted); margin-bottom: 1rem; }
  ul { padding-left: 1.2rem; margin-bottom: 1.5rem; }
  li { line-height: 1.7; color: var(--color-text-muted); margin-bottom: 0.4rem; }
  .table-wrap { overflow-x: auto; margin-bottom: 1.5rem; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 0.6rem 1rem; border-bottom: 1px solid var(--color-border); }
  th { background: var(--color-bg-alt); font-weight: 600; }
  .cta { background: var(--color-bg-alt); padding: 1.2rem; border-radius: 8px; text-align: center; margin-top: 2rem; }
  .cta p { margin-bottom: 0.8rem; color: var(--color-text); }
  .btn { display: inline-block; background: var(--color-primary); padding: 0.7rem 1.5rem; border-radius: var(--radius-full); text-decoration: none; font-weight: 600; }
  .btn:hover { background: var(--color-primary-hover); }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
