---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'privkus-metalla-ot-koronki';
const pageUrl = `https://ortopednn.ru/blog/privkus-metalla-ot-koronki/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Привкус металла во рту от коронки",
  "description": "Металлический привкус во рту после установки коронки — причины: окисление сплава, гальванический эффект. Что делать.",
  "author": { "@type": "Person", "name": "Никитина Марина Георгиевна", "medicalSpecialty": "Prosthodontics" },
  "datePublished": "2026-01-15",
  "dateModified": "2026-05-16",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@type": "Organization", "name": "ОртопедНН" }
};
---

<BaseLayout 
  title="Привкус металла во рту от коронки | Никитина М.Г."
  description="Металлический привкус во рту после установки коронки — причины: окисление сплава, гальванический эффект. Что делать."
  breadcrumbTitle="Привкус металла от коронки"
  doctor={doctor}
  socials={socials}
  datePublished="2026-01-15"
  dateModified="2026-05-16"
>
  <Navbar />
  <main class="container container--w800">
    <article>
      <header class="article-header">
        <h1>Привкус металла от коронки</h1>
        <time>15 января 2026</time>
      </header>

      <p class="lead">Металлический привкус после установки металлокерамической коронки — редкое, но возможное явление. Связано с электрохимическими процессами в полости рта.</p>
        <section id="почему-появляется-привкус"><h2>Почему появляется привкус</h2>
        <p>Во рту находятся разные металлы (коронки, пломбы, имплантаты). Между ними возникает слабый гальванический ток — как в батарейке. Это явление называется гальванизмом. Привкус усиливается при употреблении кислой пищи. Наиболее активны сплавы никель-хрома — они чаще вызывают гальванический эффект. Кобальт-хром и золото-платина — стабильнее.</p></section>
        <section id="что-делать"><h2>Что делать</h2>
        <p>В течение 1–2 недель после установки привкус может пройти сам — полость рта адаптируется. Если привкус сохраняется дольше — обратитесь к стоматологу. Возможные решения: замена коронки на безметалловую (цирконий), замена сплава на более инертный (кобальт-хром или золото), устранение разноимённых металлов в полости рта.</p></section>
    </article>

    <script type="application/ld+json" set:html={JSON.stringify(ldArticle)}></script>

    {relatedArticles.length > 0 && (
      <RelatedArticles articles={relatedArticles} />
    )}
    <RelatedServices services={getRelatedServices(slug, category?.id)} />
  </main>
</BaseLayout>

<style>
  .article-header { margin-bottom: var(--space-xl); }
  .article-header h1 { font-size: var(--text-3xl); margin-bottom: var(--space-sm); }
  .article-header time { font-size: var(--text-sm); color: var(--color-text-muted); }
  p { line-height: 1.8; margin-bottom: var(--space-md); }
  ul, ol { margin-bottom: var(--space-lg); padding-left: var(--space-lg); }
  li { line-height: 1.7; margin-bottom: var(--space-xs); }
  h2 { font-size: var(--text-2xl); margin: var(--space-xl) 0 var(--space-md); color: var(--color-primary); }
  h2:first-of-type { margin-top: 0; }
  strong { color: var(--color-text); }
</style>