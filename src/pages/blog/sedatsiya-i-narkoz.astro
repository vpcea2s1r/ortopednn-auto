ul { color: #5a7a9a; padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
a { color: #4a90d9; }
table { width: 100%; border-collapse: collapse; margin: 1rem 0; color: #5a7a9a; }
