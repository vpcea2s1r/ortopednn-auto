---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'sedatsiya-i-narkoz';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Седация и наркоз в стоматологии — что выбрать при протезировании",
  "description": "Виды обезболивания в стоматологии — местная анестезия, седация (закись азота, внутривенная), наркоз. Что подходит для протезирования и имплантации.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-06-15",
  "dateModified": "2026-06-15",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout
  title="Седация и наркоз в стоматологии в Нижнем Новгороде"
  description="Виды обезболивания — местная анестезия, седация, наркоз. Что подходит для протезирования. Запись +7 (920) 253-73-17."
  breadcrumbTitle="Седация и наркоз"
  doctor={doctor}
  socials={socials}
  datePublished="2026-06-15"
  dateModified="2026-06-15"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Седация и наркоз в стоматологии</h1>
      <div class="meta">15 июня 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead"><strong>Короткий ответ:</strong> для протезирования обычно достаточно местной анестезии. Седация закисью азота или внутривенная — для пациентов со страхом, рвотным рефлексом или при объёмных работах. Наркоз — только при сложных операциях в стационаре.</p>

      <h2>Местная анестезия — основной метод</h2>
      <p>Обезболивание уколом — стандарт для обточки зубов, снятия слепков, установки коронок и мостов. Современные анестетики (артикаин, мепивакаин) работают 2–4 часа. Пациент в сознании, все рефлексы сохранены.</p>
      <p>Плюсы: безопасно, не требует подготовки, можно сразу уйти домой. Минусы: не подходит при паническом страхе, аллергии на анестетик, рвотном рефлексе.</p>

      <h2>Седация закисью азота (веселящий газ)</h2>
      <p>Пациент дышит смесью кислорода и закиси азота через маску. Расслабление наступает через 2–3 минуты, сознание сохраняется, но тревога и боль притупляются. Седация закисью азота — самая безопасная форма успокоения в стоматологии.</p>
      <p>Подходит для:</p>
      <ul>
        <li>пациентов с зубной фобией</li>
        <li>сильного рвотного рефлекса при снятии слепков</li>
        <li>длительных процедур — от 30 минут</li>
        <li>детей и подростков (с 3–4 лет)</li>
      </ul>
      <p>Эффект проходит за 5 минут после отключения газа. Можно садиться за руль через 30–40 минут.</p>

      <h2>Внутривенная седация</h2>
      <p>Пациент в сознании, но в полудрёме. Вводится успокоительное через капельницу (мидазолам, пропофол). Воспоминаний о процедуре обычно не остаётся. Требуется анестезиолог и мониторинг.</p>
      <p>Показания: множественная имплантация, объёмная костная пластика, удаление нескольких зубов, панический страх.</p>
      <p>После процедуры нельзя вести машину 24 часа.</p>

      <h2>Наркоз (общая анестезия)</h2>
      <p>Пациент полностью спит, не дышит сам — используется ИВЛ. Применяется только в стационаре или в клинике с лицензией на анестезиологию. В стоматологии — при операциях от 2 часов, при аллергии на местные анестетики, при тяжёлых сопутствующих заболеваниях.</p>
      <p>Плюсы: можно сделать всю работу за один раз. Минусы: требуется обследование (ЭКГ, анализы), восстановление 2–4 часа, нельзя есть и пить 6 часов до процедуры.</p>

      <h2>Что выбрать для протезирования</h2>
      <table>
        <tr><th>Процедура</th><th>Рекомендуемый метод</th></tr>
        <tr><td>Обточка под коронку</td><td>Местная анестезия</td></tr>
        <tr><td>Снятие слепков при рвотном рефлексе</td><td>Седация закисью азота</td></tr>
        <tr><td>Установка 1–2 имплантов</td><td>Местная анестезия</td></tr>
        <tr><td>Установка 4+ имплантов</td><td>Седация или наркоз</td></tr>
        <tr><td>Костная пластика</td><td>Местная анестезия или седация</td></tr>
        <tr><td>Пациент с паническим страхом</td><td>Седация (независимо от объёма)</td></tr>
      </table>

      <h2>Безопасность</h2>
      <p>Седация и наркоз в стоматологии безопасны при соблюдении протокола — обязательный мониторинг (пульс, давление, сатурация), присутствие анестезиолога, предварительное обследование. Осложнения крайне редки — 0.01–0.1%.</p>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Боитесь стоматологов? Расскажу, как сделать протезирование комфортным.</p>
        <a href={`tel:${doctor.phone}`} class="btn">Позвонить: +7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
