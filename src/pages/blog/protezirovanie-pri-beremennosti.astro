---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles.ts';

const slug = 'protezirovanie-pri-beremennosti';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const category = getCategory('semnye-protezy');
const related = getRelatedArticles(slug, 3);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Протезирование зубов при беременности — можно ли, риски, рекомендации",
  "description": "Протезирование зубов при беременности: можно ли ставить коронки и протезы, когда лучше отложить, что делать в экстренных случаях.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-06-21",
  "dateModified": "2026-06-21",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout
  title="Протезирование зубов при беременности — можно ли, риски, рекомендации"
  description="Можно ли делать протезирование во время беременности. Когда можно ставить коронки, какие процедуры безопасны в каждом триместре."
  breadcrumbTitle="Протезирование при беременности"
  doctor={doctor}
  socials={socials}
  datePublished="2026-06-21"
  dateModified="2026-06-21"
>
  <Navbar />
  <main class="container container--w800">
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      <span>/</span>
      <span>Протезирование при беременности</span>
    </nav>

    <article>
      <h1>Протезирование зубов при беременности</h1>
      <div class="meta">21 июня 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead">Беременность — период, когда зубы особенно уязвимы. Гормональная перестройка, токсикоз, изменение состава слюны — всё это повышает риск кариеса и разрушения зубов. Но можно ли ставить коронки или протезы во время беременности? Ответ зависит от срока и типа вмешательства.</p>

      <h2>Когда протезирование безопасно</h2>
      <p>Плановое протезирование лучше отложить до послеродового периода. Но есть исключения: сломанный зуб, выпавшая коронка, острый край разрушенного зуба, травмирующий слизистую. В этих случаях откладывать нельзя — chronic воспаление опаснее самого вмешательства.</p>

      <h2>По триместрам</h2>
      <p><strong>Первый триместр (1-13 недель)</strong> — закладка органов плода. Любые стрессовые воздействия нежелательны. Рекомендуется только экстренная помощь: снятие острой боли, временное восстановление сломанного зуба. Плановое протезирование исключено.</p>
      <p><strong>Второй триместр (14-27 недель)</strong> — наиболее безопасный период. Плацента сформирована, токсикоз обычно проходит, плод защищён. Можно проводить несложные процедуры: лечение кариеса, установку временной коронки, замену выпавшей пломбы. Второй триместр — единственный, когда допустимо плановое ортопедическое лечение.</p>
      <p><strong>Третий триместр (28-40 недель)</strong> — женщине трудно долго сидеть в кресле, нагрузка на позвоночник, риск отёков и повышения давления. Только экстренные вмешательства. Длительное протезирование откладывается до родов.</p>

      <h2>Какие процедуры можно</h2>
      <ul>
        <li>Снятие слепков — безопасно (материалы современные нетоксичные)</li>
        <li>Фиксация временной коронки — да, без анестезии или с местной анестезией без адреналина</li>
        <li>Замена выпавшей постоянной коронки — да, с использованием временного цемента</li>
        <li>Установка съёмного протеза — да, на временном базисе</li>
      </ul>

      <h2>Чего избегать</h2>
      <ul>
        <li>Имплантация — противопоказана (требует хирургического вмешательства, наркоза, антибиотиков)</li>
        <li>Препарирование зубов под коронки без острой необходимости</li>
        <li>Любые процедуры, требующие рентген-контроля (кроме крайней необходимости)</li>
        <li>Обточка живых зубов без анестезии</li>
      </ul>

      <h2>Что делать, если сломался протез или выпала коронка</h2>
      <p>Если протез сломался, коронка выпала или зуб разрушился до острого края — приходите на приём. Временное восстановление я делаю с минимальным вмешательством: временная коронка на цинк-фосфатный цемент, сглаживание острого края, фиксация съёмного протеза мягкой прокладкой. После родов — полноценное восстановление.</p>

      <div class="cta">
        <p>Сломался зуб или выпала коронка при беременности — звоните, решим без риска.</p>
        <a href={`tel:${doctor.phone}`} class="btn">+7 (920) 253-73-17</a>
      </div>
    </article>

    <RelatedArticles articles={related} title="Читайте по теме" />
    <RelatedServices services={getRelatedServices(slug, category?.id)} />
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />
