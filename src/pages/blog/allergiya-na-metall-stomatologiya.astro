---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'allergiya-na-metall-stomatologiya';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Аллергия на металл в стоматологии — симптомы, диагностика, замена",
  "description": "Аллергия на металлокерамику, никель, хром в зубных протезах. Как распознать, чем заменить, современные гипоаллергенные материалы.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-06-15",
  "dateModified": "2026-06-15",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout
  title="Аллергия на металл в стоматологии в Нижнем Новгороде"
  description="Аллергия на металл в зубных протезах — симптомы, диагностика, безметалловые альтернативы. Телефон +7 (920) 253-73-17."
  breadcrumbTitle="Аллергия на металл"
  doctor={doctor}
  socials={socials}
  datePublished="2026-06-15"
  dateModified="2026-06-15"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Аллергия на металл в стоматологии</h1>
      <div class="meta">15 июня 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead"><strong>Коротко:</strong> истинная аллергия на стоматологические сплавы встречается у 5–8% пациентов. Чаще всего реакцию дают никель, кобальт, хром и медь. Современные безметалловые материалы — цирконий и E-max — решают проблему без потери прочности и эстетики.</p>

      <h2>Какие металлы используют в стоматологии</h2>
      <ul>
        <li><strong>Металлокерамика</strong> — сплав никеля и хрома (НХ) или кобальта и хрома (КХС). Самый частый аллерген</li>
        <li><strong>Бюгельные протезы</strong> — кобальт-хромовый сплав (КХС)</li>
        <li><strong>Штифты</strong> — титан, латунь, нержавеющая сталь</li>
        <li><strong>Съёмные протезы</strong> — металлические кламмеры из нержавейки</li>
      </ul>

      <h2>Симптомы аллергии</h2>
      <p>Реакция развивается не сразу, а через 1–6 месяцев после установки конструкции. Симптомы:</p>
      <ul>
        <li>Жжение и покраснение слизистой в месте контакта с металлом</li>
        <li>Отёк десны вокруг коронки</li>
        <li>Металлический привкус во рту</li>
        <li>Стоматит, который не проходит от обычного лечения</li>
        <li>В тяжёлых случаях — сыпь на лице, экзема</li>
      </ul>
      <p>Ключевое отличие аллергии от механического раздражения: симптомы усиливаются со временем, а не проходят после адаптации.</p>

      <h2>Диагностика</h2>
      <ul>
        <li><strong>Аппликационные пробы</strong> (patch test) — золотой стандарт. На кожу спины на 48 часов наклеивают пластинки с разными металлами</li>
        <li><strong>Анализ крови</strong> — MELISA (Memory Lymphocyte Immuno-Stimulation Assay) тест на сенсибилизацию к металлам</li>
        <li>Исключение других причин — кандидоз, травма протезом, плохая гигиена</li>
      </ul>

      <h2>Что делать, если аллергия подтвердилась</h2>
      <p>Единственное решение — заменить металлосодержащую конструкцию на гипоаллергенную.</p>
      <h3>Безметалловые альтернативы</h3>
      <ul>
        <li><strong><a href="/services/cirkonievaya-koronka/">Циркониевые коронки</a></strong> — диоксид циркония, биосовместим, прочнее металла, эстетичен</li>
        <li><strong>Коронки E-max</strong> — прессованная стеклокерамика, высокая эстетика для передних зубов</li>
        <li><strong><a href="/services/nejlonovyj-protez">Нейлоновые протезы</a></strong> — без металла, гибкие, гипоаллергенные</li>
        <li><strong><a href="/services/byugelnyj-zamki/">Бюгель на замках</a></strong> — вместо кламмеров используются аттачмены из полимера</li>
      </ul>

      <h2>Профилактика для аллергиков</h2>
      <ul>
        <li>Перед протезированием сообщите врачу о любой аллергии — бытовой или лекарственной</li>
        <li>При известной аллергии на никель (бижутерия, заклёпки на джинсах) — сразу выбирайте безметалловые конструкции</li>
        <li>Можно сделать аллергопробу до фиксации — врач наклеит небольшой образец сплава на слизистую</li>
      </ul>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Подозреваете аллергию на коронку?</p>
        <a href={`tel:${doctor.phone}`} class="btn">Позвонить: +7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
article { background: white; border-radius: 12px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
.meta { color: #7a9ab8; font-size: 0.9rem; margin-bottom: 1rem; }
.lead { font-size: 1.1rem; color: #5a7a9a; margin-bottom: 2rem; }
h2 { color: #2e6ab3; margin: 2rem 0 1rem; font-size: 1.3rem; }
h3 { color: #1e3a5f; margin: 1.5rem 0 0.75rem; font-size: 1.1rem; }
p { color: #5a7a9a; line-height: 1.7; margin-bottom: 1rem; }
ul { color: #5a7a9a; padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
a { color: #4a90d9; }
.cta { text-align: center; padding: 1.5rem; background: #f8fafc; border-radius: 8px; margin-top: 2rem; }
.cta p { margin-bottom: 1rem; }
.btn { display: inline-block; background: #4a90d9; color: white; padding: 0.75rem 2rem; border-radius: 100px; text-decoration: none; font-weight: 600; }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
