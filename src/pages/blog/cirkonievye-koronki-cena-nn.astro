const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const catId = category ? category.id : null;
const ldArticle = {"@context": "https://schema.org", "@type": "Article", "headline": "Циркониевые коронки: цена в Нижнем Новгороде", "description": "Сколько стоят циркониевые коронки в Нижнем Новгороде. Цены на монолитный и мультислойный цирконий, что входит в стоимость, сравнение с металлокерамикой.", "author": { "@id": "https://ortopednn.ru/#doctor" }, "datePublished": "2026-06-29", "dateModified": "2026-06-29", "mainEntityOfPage": {"@type": "WebPage", "@id": "https://ortopednn.ru/blog/cirkonievye-koronki-cena-nn/"}, "image": "https://ortopednn.ru/og-image.svg", "publisher": { "@id": "https://ortopednn.ru/#clinic" }};
