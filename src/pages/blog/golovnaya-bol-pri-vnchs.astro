const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const catId = category ? category.id : null;
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Головная боль при дисфункции ВНЧС: причины и лечение",
  "description": "Головная боль при дисфункции ВНЧС: как связаны прикус и головные боли, симптомы, диагностика, методы лечения у стоматолога-гнатолога.",
