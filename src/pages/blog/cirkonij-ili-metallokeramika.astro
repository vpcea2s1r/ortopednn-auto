---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'cirkonij-ili-metallokeramika';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Циркониевые или металлокерамические коронки: что лучше",
  "description": "Сравнение циркониевых и металлокерамических коронок: эстетика, прочность, цена, срок службы, кому что подходит.",
  "author": { "@type": "Person", "name": "Никитина Марина Георгиевна", "medicalSpecialty": "Prosthodontics" },
  "datePublished": "2026-05-24",
  "dateModified": "2026-05-24",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@type": "Organization", "name": "ОртопедНН" }
};
---

<BaseLayout 
  title="Циркониевые или металлокерамические коронки: что лучше"
  description="Цирконий или металлокерамика: эстетика, прочность, срок службы, цены. Таблица сравнения. Какой вариант выбрать для передних и жевательных зубов."
  breadcrumbTitle="Цирконий или металлокерамика"
  doctor={doctor}
  socials={socials}
  datePublished="2026-05-24"
  dateModified="2026-05-24"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Циркониевые или металлокерамические коронки: что лучше</h1>
      <div class="meta">24 мая 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead">Для передних зубов — цирконий (эстетика, без синевы десны). Для жевательных — металлокерамика (прочнее, дешевле). Цирконий дороже в 2-3 раза, но служит дольше и выглядит естественнее.</p>

      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Параметр</th><th>Цирконий</th><th>Металлокерамика</th></tr>
        </thead>
        <tbody>
          <tr><td>Эстетика</td><td>Прозрачность как у натурального зуба</td><td>Непрозрачный металл внутри, возможна синева десны</td></tr>
          <tr><td>Прочность</td><td>900-1200 МПа</td><td>Металл прочный, керамика может сколоться</td></tr>
          <tr><td>Цена</td><td>Выше в 2-3 раза</td><td>Ниже</td></tr>
          <tr><td>Срок службы</td><td>15-20 лет</td><td>8-12 лет</td></tr>
          <tr><td>Аллергия</td><td>Гипоаллергенный</td><td>Редко на сплавы металлов</td></tr>
          <tr><td>Толщина</td><td>0.3-0.5 мм</td><td>1.0-1.5 мм (требует большей обточки)</td></tr>
        </tbody>
      </table>
      </div>

      <h2>Чем отличаются</h2>

      <p>Металлокерамика — металлический каркас (кобальт-хром, никель-хром), покрытый керамикой. Проверенный десятилетиями вариант. Цирконий — монолитный диоксид циркония, без металла. Фрезеруется из единого блока на станке CAD/CAM, что гарантирует точное прилегание.</p>

      <p>Исследование <em>Clinical Oral Investigations</em> (2022) показало: выживаемость циркониевых коронок через 10 лет составляет 96%, металлокерамических — 90%. Разница статистически значима, но на практике оба варианта надёжны при качественном изготовлении.</p>
      <p class="translation">Через 10 лет 96% циркониевых и 90% металлокерамических коронок остаются в работе.</p>

      <h2>Когда выбрать цирконий</h2>

      <ul>
        <li><strong>Передние зубы.</strong> Цирконий пропускает свет как натуральная эмаль. Металлокерамика даёт сероватый оттенок у десны.</li>
        <li><strong>Аллергия.</strong> Цирконий гипоаллергенен, подходит пациентам с реакцией на металлы.</li>
        <li><strong>Тонкая десна.</strong> При тонком биотипе через металлокерамику просвечивает тёмный каркас.</li>
      </ul>

      <h2>Когда выбрать металлокерамику</h2>

      <ul>
        <li><strong>Жевательные зубы.</strong> Нагрузка здесь максимальная. Металлокерамика выдерживает её десятилетиями.</li>
        <li><strong>Бюджет.</strong> Цена в 2-3 раза ниже циркония при сопоставимой надёжности.</li>
        <li><strong>Мостовидные протезы.</strong> На металлокерамический мост цена заметно ниже циркониевого.</li>
      </ul>

      <h2>Частая ошибка при выборе</h2>

      <p>Пациенты думают: «раз цирконий лучше, поставлю его на все зубы». На жевательные зубы цирконий тоже подходит, но разница в эстетике там незаметна, а переплата значительная. Оптимальная стратегия: цирконий на переднюю группу (клык до клыка), металлокерамика — на премоляры и моляры.</p>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Поможем подобрать материал под ваш клинический случай.</p>
        <a href={`tel:${doctor.phone}`} class="btn">+7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--color-primary); margin-bottom: 1rem; display: inline-block; }
article { background: white; border-radius: 12px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
h1 { color: var(--color-text); margin-bottom: 0.5rem; font-size: 1.75rem; }
.meta { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }
.lead { font-size: 1.1rem; color: var(--color-text); line-height: 1.7; margin-bottom: 2rem; background: var(--color-bg-alt); padding: 1rem; border-radius: 8px; }
h2 { color: var(--color-primary); margin: 2rem 0 1rem; font-size: 1.3rem; }
p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: 1rem; }
ul { color: var(--color-text-muted); padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
.translation { font-style: italic; color: var(--color-text); background: var(--color-bg-alt); padding: 0.75rem; border-radius: 8px; }
.table-wrap { overflow-x: auto; margin: 1rem 0; }
table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid #e5e7eb; }
th { background: var(--color-bg-alt); font-weight: 600; color: var(--color-text); }
td { color: var(--color-text-muted); }
.cta { text-align: center; padding: 1.5rem; background: var(--color-bg-alt); border-radius: 8px; margin-top: 2rem; }
.cta p { margin-bottom: 1rem; color: var(--color-text); }
.btn { display: inline-block; background: var(--color-primary); color: white; padding: 0.75rem 2rem; border-radius: var(--radius-full); text-decoration: none; font-weight: 600; }
.btn:hover { background: var(--color-primary-hover); }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
