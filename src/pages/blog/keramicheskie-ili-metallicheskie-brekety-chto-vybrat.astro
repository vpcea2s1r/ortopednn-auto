    <tr><td>Металлические самолигирующие</td><td>Низкая</td><td>Максимальная</td><td>Средняя</td><td>Быстрее, меньше посещений</td></tr>
    <tr><td>Керамические лигатурные</td><td>Высокая</td><td>Средняя</td><td>Выше среднего</td><td>Для передних зубов, взрослые пациенты</td></tr>
    <tr><td>Керамические самолигирующие</td><td>Высокая</td><td>Средняя</td><td>Высокая</td><td>Комфорт и эстетика, минимум посещений</td></tr>
