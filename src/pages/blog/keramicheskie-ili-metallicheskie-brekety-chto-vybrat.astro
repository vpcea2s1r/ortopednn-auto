    <tr><td>Прочность</td><td>Максимальная</td><td>Средняя (возможны сколы)</td></tr>
    <tr><td>Срок лечения</td><td>Часто короче на 2–4 месяца</td><td>Стандартный</td></tr>
    <tr><td>Трение дуги</td><td>Минимальное</td><td>Выше, замедляет перемещение</td></tr>
    <tr><td>Уход</td><td>Стандартный</td><td>Ограничения в еде, окрашивание лигатур</td></tr>
    <tr><td>Сложные случаи</td><td>Подходят для любых аномалий</td><td>Ограничены для сложных патологий</td></tr>
    <tr><td>Комфорт</td><td>Стандартный</td><td>Мягче, меньше травмируют слизистую</td></tr>
  </tbody>
</table>
</div>

