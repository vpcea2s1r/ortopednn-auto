const ldArticle = {"image":"https://ortopednn.ru/og-image.svg","datePublished":"2026-06-02","description":"Металлические брекеты прочнее и дешевле, керамические — незаметнее, но дороже. Сравнение по эстетике, цене, сроку лечения.","@type":"Article","dateModified":"2026-06-02","headline":"Керамические или металлические брекеты: что выбрать?","author":{"medicalSpecialty":"Prosthodontics","name":"Никитина М.Г., стоматолог-ортопед","@type":"Person"},"@context":"https://schema.org","mainEntityOfPage":{"@type":"WebPage","@id":"https://ortopednn.ru/blog/keramicheskie-ili-metallicheskie-brekety-chto-vybrat/"},"publisher":{"name":"Ортопед","@type":"Organization"}};
