---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FAQ from '../../components/FAQ.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';

const articles = [
  { slug: 'mostovidnyj-protez-vidy-plyusy-minusy', title: 'Мостовидный протез — виды, плюсы и минусы', date: '2026-05-24', desc: 'Металлокерамика, цирконий, мост на имплантах. Сравнение, сроки, плюсы и минусы.' },
  { slug: 'kak-privyknut-k-semnym-protezam', title: 'Как привыкнуть к съёмным протезам — советы стоматолога-ортопеда', date: '2026-05-24', desc: 'Первая неделя: боль, дикция, еда. Таблица адаптации, когда нужна коррекция.' },
  { slug: 'bolit-zub-pod-koronkoj', title: 'Болит зуб под коронкой — что делать и какие причины', date: '2026-05-23', desc: 'Зуб под коронкой болит при накусывании, ноет или дёргает. Причины, чем снять боль до приёма, когда ждать нельзя.' },
  { slug: 'kak-chistit-semnye-protezy', title: 'Как чистить съёмные протезы — пошаговая инструкция', date: '2026-05-23', desc: 'Чистка протеза: пошаговая инструкция, какие средства подходят, чего нельзя делать. Таблица частоты ухода, сроки замены.' },
  { slug: 'vospalenie-desny-pod-koronkoj', title: 'Воспалилась десна под коронкой — что делать', date: '2026-05-22', desc: 'Покраснела, кровоточит или болит десна вокруг коронки. Причины, домашняя помощь, когда к врачу.' },
  { slug: 'bolno-li-stavit-koronku', title: 'Больно ли ставить коронку на зуб', date: '2026-05-22', desc: 'Разбираем все этапы: укол, обточка, слепки, фиксация. Таблица ощущений. Когда бывает больно и что с этим делать.' },
  { slug: 'kurenie-posle-protezirovaniya', title: 'Можно ли курить после протезирования зубов', date: '2026-05-22', desc: 'Через сколько можно курить после имплантации, коронок и съёмных протезов. Таблица сроков и риски.' },
  { slug: 'posle-ustanovki-koronki', title: 'Через сколько можно есть после установки коронки', date: '2026-05-22', desc: 'Всё зависит от цемента. Разбираем сроки для временных и постоянных коронок, что можно есть в первый день.' },
  { slug: 'nizhnij-protez', title: 'Нижний зубной протез: особенности и фиксация', date: '2026-03-16', desc: 'Протезирование нижней челюсти: виды конструкций, почему плохо держится, имплантация, уход.' },
  { slug: 'verhnij-protez', title: 'Верхний зубной протез: виды, показания и уход', date: '2026-03-15', desc: 'Клинические показания, биосовместимость материалов, адаптация и уход.' },
  { slug: 'care-denture', title: 'Уход за съёмным протезом: полное руководство', date: '2024-03-15', desc: 'Как продлить жизнь протеза и избежать проблем. Проверенные советы.' },
  { slug: 'care-crown', title: 'Уход за коронками: что нужно знать', date: '2024-03-10', desc: 'Правила ухода за циркониевыми и металлокерамическими коронками.' },
  { slug: 'first-visit', title: 'Первый визит к ортопеду: чего ожидать', date: '2024-03-05', desc: 'Как подготовиться к консультации и что спросить у врача.' }
];
---

<BaseLayout 
  title="Блог | Никитина Марина Георгиевна — Стоматолог-ортопед"
  description="Полезные статьи об уходе за зубами, протезировании и стоматологии."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="container">
    <a href="/" class="back">← На главную</a>
    
    <h1>Полезные статьи</h1>
    <p class="intro">Делимся знаниями о протезировании и уходе за зубами.</p>

    <div class="articles">
      {articles.map(article => (
        <a href={`/blog/${article.slug}`} class="article-card">
          <div class="date">{article.date}</div>
          <h2>{article.title}</h2>
          <p>{article.desc}</p>
          <span class="read-more">Читать →</span>
        </a>
      ))}
    </div>

    <FAQ />
  </main>
</BaseLayout>

<style>
.container { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
.intro { color: #5a7a9a; margin-bottom: 2rem; }
.articles { display: grid; gap: 1.5rem; margin-bottom: 3rem; }
.article-card { background: white; border-radius: 12px; padding: 1.5rem; text-decoration: none; display: block; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
.article-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
.date { color: #7a9ab8; font-size: 0.85rem; margin-bottom: 0.5rem; }
.article-card h2 { color: #1e3a5f; font-size: 1.25rem; margin-bottom: 0.5rem; }
.article-card p { color: #5a7a9a; margin-bottom: 1rem; line-height: 1.6; }
.read-more { color: #4a90d9; font-weight: 600; }
</style>