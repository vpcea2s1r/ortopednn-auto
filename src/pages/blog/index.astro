---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FAQ from '../../components/FAQ.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, categories, getArticlesByCategory } from '../../../data/blog-articles.ts';

const uncategorized = articles.filter(a => !a.category);
---

<BaseLayout clientRouter 
  title="Блог о протезировании зубов в Нижнем Новгороде | Никитина М.Г."
  description="Полезные статьи об уходе за зубами, протезировании и стоматологии."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="container container--w800">
    <a href="/" class="back">← На главную</a>
    
    <h1>Полезные статьи</h1>
    <p class="intro">Делимся знаниями о протезировании и уходе за зубами.</p>

    <nav class="categories">
      {categories.map(cat => {
        const count = getArticlesByCategory(cat.id).length;
        return (
          <a href={`/blog/${cat.slug}`} class="category-chip">
            {cat.name}
            <span class="count">{count}</span>
          </a>
        );
      })}
    </nav>

    {categories.map(cat => {
      const catArticles = getArticlesByCategory(cat.id).sort((a, b) => b.date.localeCompare(a.date));
      if (catArticles.length === 0) return null;
      return (
        <section class="category-section">
          <h2 class="category-title">
            <a href={`/blog/${cat.slug}`}>{cat.name}</a>
          </h2>
          <p class="category-desc">{cat.desc}</p>
          <div class="articles">
            {catArticles.slice(0, 5).map(article => (
              <a href={`/blog/${article.slug}`} class="article-card">
                <div class="date">{article.date}</div>
                <h3>{article.title}</h3>
                <p>{article.desc}</p>
                <span class="read-more">Читать →</span>
              </a>
            ))}
          </div>
          {catArticles.length > 5 && (
            <a href={`/blog/${cat.slug}`} class="view-all">Все статьи по теме →</a>
          )}
        </section>
      );
    })}

    {uncategorized.length > 0 && (
      <section class="category-section">
        <h2 class="category-title">Полезная информация</h2>
        <div class="articles">
          {uncategorized.sort((a, b) => b.date.localeCompare(a.date)).map(article => (
            <a href={`/blog/${article.slug}`} class="article-card">
              <div class="date">{article.date}</div>
              <h3>{article.title}</h3>
              <p>{article.desc}</p>
              <span class="read-more">Читать →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <FAQ />
  </main>
</BaseLayout>

<style>

  .back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
  h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
  .intro { color: #5a7a9a; margin-bottom: 2rem; }

  .categories { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem; }
  .category-chip { background: #eef3f8; color: #1e3a5f; padding: 0.5rem 1rem; border-radius: 20px; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: background 0.2s; display: inline-flex; align-items: center; gap: 0.4rem; }
  .category-chip:hover { background: #dce6f0; }
  .category-chip .count { background: #d0dbe8; border-radius: 10px; padding: 0.05rem 0.5rem; font-size: 0.75rem; font-weight: 400; }

  .category-section { margin-bottom: 2.5rem; }
  .category-title { color: #1e3a5f; margin-bottom: 0.25rem; }
  .category-title a { color: #1e3a5f; text-decoration: none; }
  .category-title a:hover { color: #4a90d9; }
  .category-desc { color: #7a9ab8; font-size: 0.85rem; margin-bottom: 1rem; }
  .articles { display: grid; gap: 1rem; margin-bottom: 1rem; }
  .article-card { background: white; border-radius: 12px; padding: 1.2rem 1.5rem; text-decoration: none; display: block; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .article-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
  .date { color: #7a9ab8; font-size: 0.85rem; margin-bottom: 0.4rem; }
  .article-card h3 { color: #1e3a5f; font-size: 1.1rem; margin-bottom: 0.4rem; }
  .article-card p { color: #5a7a9a; margin-bottom: 0.8rem; line-height: 1.5; font-size: 0.9rem; }
  .read-more { color: #4a90d9; font-weight: 600; font-size: 0.9rem; }
  .view-all { color: #4a90d9; font-weight: 500; font-size: 0.9rem; text-decoration: none; display: inline-block; margin-bottom: 0.5rem; }
  .view-all:hover { text-decoration: underline; }
</style>
