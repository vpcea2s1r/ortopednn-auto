---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'osteoporoz-i-implantatsiya';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Остеопороз и имплантация зубов — риски, особенности, альтернативы",
  "description": "Можно ли ставить импланты при остеопорозе. Риски отторжения, подготовка, альтернативные методы протезирования. Что важно знать пациентам с остеопорозом.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-06-15",
  "dateModified": "2026-06-15",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout
  title="Остеопороз и имплантация зубов в Нижнем Новгороде"
  description="Можно ли ставить импланты при остеопорозе. Риски отторжения, подготовка, альтернативы. Запись +7 (920) 253-73-17."
  breadcrumbTitle="Остеопороз и имплантация"
  doctor={doctor}
  socials={socials}
  datePublished="2026-06-15"
  dateModified="2026-06-15"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Остеопороз и имплантация зубов</h1>
      <div class="meta">15 июня 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead"><strong>Короткий ответ:</strong> импланты при остеопорозе ставить можно, но с подготовкой и не всем. Нужна оценка плотности кости, стабилизация заболевания, возможна отсрочка нагрузки. У пациентов с остеопорозом риск отторжения выше на 20–30%. Альтернатива — съёмные протезы.</p>

      <h2>Что такое остеопороз и почему это важно для стоматологии</h2>
      <p>Остеопороз — снижение плотности костной ткани. Кость становится пористой, как губка. Челюстная кость тоже теряет объём. Для имплантации нужна плотная кость, которая выдержит нагрузку и обеспечит остеоинтеграцию — сращение импланта с костью.</p>
      <p>По данным ВОЗ, остеопорозом страдают каждая третья женщина после 50 лет и каждый пятый мужчина старше 60. В стоматологии это означает, что значительная часть пациентов, которым нужно протезирование, потенциально в группе риска.</p>

      <h2>Можно ли ставить импланты при остеопорозе</h2>
      <p>Да, но с оговорками. Международные исследования (<em>Clinical Oral Implants Research</em>, 2020) показывают: выживаемость имплантов у пациентов с остеопорозом — 91–95% против 97–99% у здоровых. Разница есть, но не критическая.</p>
      <p>Ключевые условия:</p>
      <ul>
        <li><strong>Стабильное состояние</strong> — остеопороз должен быть под контролем (лечение, нормальный кальций)</li>
        <li><strong>Достаточный объём кости</strong> — если кости мало, нужна костная пластика</li>
        <li><strong>Бисфосфонаты</strong> — при длительном приёме риск остеонекроза челюсти. Нужна консультация с лечащим врачом</li>
        <li><strong>Отказ от курения</strong> — у курильщиков с остеопорозом риск отторжения в 3 раза выше</li>
      </ul>

      <h2>Подготовка к имплантации при остеопорозе</h2>
      <p>Перед имплантацией пациент с остеопорозом проходит:</p>
      <ul>
        <li>КТ челюсти — оценка плотности и объёма кости</li>
        <li>Анализ крови — кальций, фосфор, витамин D, паратгормон</li>
        <li>Консультация эндокринолога — подтверждение стабильного состояния</li>
        <li>Отмена или замена бисфосфонатов (по согласованию с врачом)</li>
      </ul>

      <h2>Альтернативы имплантам</h2>
      <p>Если имплантация противопоказана, есть другие варианты восстановления зубов:</p>
      <ul>
        <li><strong><a href="/services/byugelnyj-protez">Бюгельные протезы</a></strong> — жёсткий каркас, распределяет нагрузку на оставшиеся зубы и десну</li>
        <li><strong><a href="/services/nejlonovyj-protez">Нейлоновые протезы</a></strong> — мягкие, гипоаллергенные, не давят на кость</li>
        <li><strong><a href="/services/mostovidnyj-protez">Мостовидные протезы</a></strong> — классический вариант при одном-двух отсутствующих зубах</li>
      </ul>

      <h2>Рекомендации для пациентов с остеопорозом</h2>
      <ul>
        <li>Не скрывайте диагноз — врач должен знать обо всех принимаемых препаратах</li>
        <li>Сдайте денситометрию (DXA) — это стандарт оценки плотности кости</li>
        <li>Принимайте кальций и витамин D — для поддержки костной ткани</li>
        <li>После имплантации — регулярные осмотры каждые 6 месяцев</li>
      </ul>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Нужна консультация по протезированию при остеопорозе?</p>
        <a href={`tel:${doctor.phone}`} class="btn">Позвонить: +7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
