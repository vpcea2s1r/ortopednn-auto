---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'skolko-delaetsya-koronka';
const pageUrl = `https://ortopednn.ru/blog/skolko-delaetsya-koronka/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Сколько делается коронка на зуб по времени",
  "description": "Сколько по времени делают коронку на зуб — от слепка до фиксации. Этапы изготовления металлокерамики и циркония.",
  "author": { "@type": "Person", "name": "Никитина Марина Георгиевна", "medicalSpecialty": "Prosthodontics" },
  "datePublished": "2026-01-15",
  "dateModified": "2026-05-16",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@type": "Organization", "name": "ОртопедНН" }
};
---

<BaseLayout 
  title="Сколько делается коронка на зуб по времени | Никитина М.Г."
  description="Сколько по времени делают коронку на зуб — от слепка до фиксации. Этапы изготовления металлокерамики и циркония."
  breadcrumbTitle="Сколько делается коронка"
  doctor={doctor}
  socials={socials}
  datePublished="2026-01-15"
  dateModified="2026-05-16"
>
  <Navbar />
  <main class="container container--w800">
    <article>
      <header class="article-header">
        <h1>Сколько делается коронка</h1>
        <time>15 января 2026</time>
      </header>

      <p class="lead">Полный цикл от первого визита до фиксации коронки занимает 7–14 дней. В некоторых случаях — до 3 недель.</p>
        <section id="этапы-изготовления"><h2>Этапы изготовления</h2>
        <p><strong>1-й визит (40–60 минут):</strong> осмотр, препарирование зуба, снятие оттисков, установка временной коронки.</p>
        <p><strong>Лабораторный этап (7–14 дней):</strong> изготовление каркаса, нанесение керамики, обжиг, глазурование. Для циркониевых коронок — дополнительное время на CAD/CAM моделирование.</p>
        <p><strong>2-й визит (20–30 минут):</strong> примерка, проверка прикуса, фиксация на постоянный цемент.</p>
        <p>Металлокерамика делается 7–10 дней, цирконий — 10–14 дней. Срочное изготовление (3–5 дней) возможно за дополнительную плату.</p></section>
    </article>

    <script type="application/ld+json" set:html={JSON.stringify(ldArticle)}></script>

    {relatedArticles.length > 0 && (
      <RelatedArticles articles={relatedArticles} />
    )}
    <RelatedServices services={getRelatedServices(slug, category?.id)} />
  </main>
</BaseLayout>

<style>
  .article-header { margin-bottom: var(--space-xl); }
  .article-header h1 { font-size: var(--text-3xl); margin-bottom: var(--space-sm); }
  .article-header time { font-size: var(--text-sm); color: var(--color-text-muted); }
  p { line-height: 1.8; margin-bottom: var(--space-md); }
  ul, ol { margin-bottom: var(--space-lg); padding-left: var(--space-lg); }
  li { line-height: 1.7; margin-bottom: var(--space-xs); }
  h2 { font-size: var(--text-2xl); margin: var(--space-xl) 0 var(--space-md); color: var(--color-primary); }
  h2:first-of-type { margin-top: 0; }
  strong { color: var(--color-text); }
</style>