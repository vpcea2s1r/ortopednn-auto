const ldArticle = {"@context": "https://schema.org", "@type": "Article", "headline": "Сколько стоит коронка на зуб в Нижнем Новгороде 2025–2026", "description": "Цены на коронки в Нижнем Новгороде: металлокерамика, цирконий, E-max, пластмасса. Что входит в стоимость, сравнение по материалам, цены 2025–2026.", "author": { "@id": "https://ortopednn.ru/#doctor" }, "datePublished": "2026-06-29", "dateModified": "2026-06-29", "mainEntityOfPage": {"@type": "WebPage", "@id": "https://ortopednn.ru/blog/skolko-stoit-koronka-nn/"}, "image": "https://ortopednn.ru/og-image.svg", "publisher": { "@id": "https://ortopednn.ru/#clinic" }};
