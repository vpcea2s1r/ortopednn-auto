.lead { font-size: 1.1rem; margin-bottom: 2rem; background: var(--color-bg-alt); padding: 1rem; border-radius: 8px; }
h2 { color: var(--color-primary); margin: 2rem 0 1rem; font-size: 1.3rem; }
p, ul { color: var(--color-text-muted); line-height: 1.7; margin-bottom: 1rem; }
ul { padding-left: 1.5rem; }
