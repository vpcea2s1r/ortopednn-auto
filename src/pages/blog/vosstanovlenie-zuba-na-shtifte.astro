---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'vosstanovlenie-zuba-na-shtifte';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Восстановление зуба на штифте: показания, этапы, плюсы и минусы",
  "description": "Восстановление зуба на штифте: когда нужен штифт, этапы установки, виды штифтов. Плюсы и минусы метода.",
  "author": { "@type": "Person", "name": "Никитина Марина Георгиевна", "medicalSpecialty": "Prosthodontics" },
  "datePublished": "2026-05-26",
  "dateModified": "2026-05-26",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@type": "Organization", "name": "ОртопедНН" }
};
---

<BaseLayout 
  title="Восстановление зуба на штифте: показания, этапы, плюсы и минусы | Никитина М.Г."
  description="Восстановление зуба на штифте: показания, виды штифтов (анкерный, стекловолоконный), этапы установки, плюсы и минусы."
  breadcrumbTitle="Восстановление зуба на штифте"
  doctor={doctor}
  socials={socials}
  datePublished="2026-05-26"
  dateModified="2026-05-26"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Восстановление зуба на штифте: показания, этапы, плюсы и минусы</h1>
      <div class="meta">26 мая 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead">Штифт — это стержень, который фиксируется в корневом канале зуба и служит опорой для восстановления коронковой части. Когда от зуба остался только корень, а коронка разрушена — штифт позволяет сохранить зуб.</p>

      <h2>Когда нужен штифт</h2>
      <p>Зуб разрушен более чем на 50%, корень здоров, каналы пролечены. Пломба не держится, а культевая вкладка не подходит из-за тонких стенок зуба. Штифт вкручивается или вклеивается в канал, после чего на него наращивается культя под коронку.</p>

      <h2>Виды штифтов</h2>
      <ul>
        <li><strong>Анкерные (металлические)</strong> — вкручиваются в канал. Прочные, но могут создавать напряжение в корне. Титановые — биосовместимы, стальные — дешевле.</li>
        <li><strong>Стекловолоконные</strong> — эластичные, светопропускающие. Снижают риск перелома корня. Лучший выбор для передних зубов.</li>
        <li><strong>Углеродоволоконные</strong> — прочные и упругие. Используются реже.</li>
        <li><strong>Парапульпарные</strong> — устанавливаются не в канал, а в дентин. Для небольших дефектов.</li>
      </ul>

      <h2>Этапы восстановления</h2>
      <ol>
        <li><strong>Подготовка канала</strong> — распломбировка на 1/2–2/3 длины корня</li>
        <li><strong>Установка штифта</strong> — фиксация на цемент (стекловолокно) или вкручивание (анкерный)</li>
        <li><strong>Формирование культи</strong> — наращивание композитного материала вокруг штифта</li>
        <li><strong>Снятие слепков</strong> — для изготовления коронки</li>
        <li><strong>Фиксация коронки</strong> — постоянная или временная</li>
      </ol>

      <h2>Штифт или культевая вкладка</h2>
      <p>Если зуб разрушен сильно, лучше культевая вкладка — она изготавливается в лаборатории, точно повторяет форму канала и перераспределяет нагрузку равномернее. Штифт — более простой и быстрый вариант.</p>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Зуб разрушен? Возможно, его можно сохранить на штифте. Приходите — оценю состояние.</p>
        <a href={`tel:${doctor.phone}`} class="btn">+7 (920) 253-73-17</a>
      </div>

    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
  main { max-width: 800px; margin: 0 auto; padding: 1.5rem; }
  .back { color: var(--color-primary); text-decoration: none; font-size: 0.9rem; }
  .back:hover { text-decoration: underline; }
  h1 { font-size: 1.8rem; color: var(--color-text); margin-bottom: 0.5rem; }
  .meta { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .lead { background: var(--color-bg-alt); padding: 1rem 1.2rem; border-radius: 8px; font-size: 1.05rem; line-height: 1.6; margin-bottom: 1.5rem; }
  h2 { font-size: 1.35rem; color: var(--color-primary); margin-top: 1.8rem; margin-bottom: 0.8rem; }
  p { line-height: 1.7; color: var(--color-text-muted); margin-bottom: 1rem; }
  ul { padding-left: 1.2rem; margin-bottom: 1.5rem; }
  li { line-height: 1.7; color: var(--color-text-muted); margin-bottom: 0.4rem; }
  ol { padding-left: 1.2rem; margin-bottom: 1.5rem; }
  ol li { line-height: 1.7; color: var(--color-text-muted); margin-bottom: 0.4rem; }
  .cta { background: var(--color-bg-alt); padding: 1.2rem; border-radius: 8px; text-align: center; margin-top: 2rem; }
  .cta p { margin-bottom: 0.8rem; color: var(--color-text); }
  .btn { display: inline-block; background: var(--color-primary); padding: 0.7rem 1.5rem; border-radius: var(--radius-full); text-decoration: none; font-weight: 600; }
  .btn:hover { background: var(--color-primary-hover); }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
