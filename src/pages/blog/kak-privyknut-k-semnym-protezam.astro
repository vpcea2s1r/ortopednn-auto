---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { articles, getCategory, getRelatedArticles } from '../../../data/blog-articles';
import RelatedArticles from '../../components/RelatedArticles.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getRelatedServices } from '../../../data/cross-links';

const slug = 'kak-privyknut-k-semnym-protezam';
const pageUrl = `https://ortopednn.ru/blog/${slug}/`;
const articleData = articles.find(a => a.slug === slug);
const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Как привыкнуть к съёмным протезам — советы стоматолога-ортопеда",
  "description": "Сколько привыкают к съёмным протезам, что нормально в первую неделю, когда нужна коррекция. Таблица сроков адаптации.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-05-24",
  "dateModified": "2026-05-24",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout 
  title="Как привыкнуть к съёмным протезам — советы стоматолога"
  description="Первая неделя с протезом: больно, неудобно, выпадает? Таблица этапов адаптации, когда к врачу, что можно сделать дома."
  breadcrumbTitle="Как привыкнуть к протезам"
  doctor={doctor}
  socials={socials}
  datePublished="2026-05-24"
  dateModified="2026-05-24"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">← К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={`/blog/${category.id}`}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>
    
    <article>
      <h1>Как привыкнуть к съёмным протезам — советы стоматолога-ортопеда</h1>
      <div class="meta">24 мая 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead">Первые 1-2 недели — самые сложные. Дикция нарушена, чувствуется тошнота, протез кажется большим. Это норма. Через месяц большинство пациентов перестают замечать протез. Если боль или натирание не проходят за 3-5 дней — нужна коррекция.</p>

      <h2>Сколько привыкают к съёмным протезам</h2>

      <p>Исследование <em>Journal of Oral Rehabilitation</em> (2021) показало: 78% пациентов полностью адаптируются к съёмным протезам за 4-6 недель. Ещё 15% — за 2-3 месяца. Оставшиеся 7% нуждаются в переделке или фиксации на имплантах.</p>
      <p class="translation">78% пациентов привыкают к протезу за 4-6 недель.</p>

      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Период</th><th>Ощущения</th><th>Что делать</th></tr>
        </thead>
        <tbody>
          <tr><td>1-3 день</td><td>Чувство инородного тела, повышенное слюноотделение, тошнота</td><td>Носить протез постоянно. Сосать леденцы от тошноты. Пить маленькими глотками</td></tr>
          <tr><td>4-7 день</td><td>Натирания, боль при жевании, нарушение дикции</td><td>Мягкая пища. Читать вслух 10 мин в день. Если натирает — записаться на коррекцию</td></tr>
          <tr><td>2-4 неделя</td><td>Протез ощущается меньше, жевать удобнее</td><td>Постепенно возвращать твёрдую пищу. Продолжать гигиену</td></tr>
          <tr><td>1-2 месяц</td><td>Полная адаптация</td><td>Протез — часть тела. Осмотр раз в год</td></tr>
        </tbody>
      </table>
      </div>

      <h2>Почему болит и натирает</h2>

      <p>Съёмный протез опирается на десну, а не на зубы. Даже идеально сделанный протез требует 1-3 коррекций в первые недели — десна «усаживается», меняется рельеф. Это нормально.</p>

      <p>Не терпите боль больше 3-5 дней. Запишитесь на коррекцию — врач подточит натирающий участок. Занимает 10-15 минут. Не подтачивайте протез сами — сломаете.</p>

      <h2>Как восстановить дикцию</h2>

      <ul>
        <li>Читайте вслух 10-15 минут в день</li>
        <li>Проговаривайте скороговорки: «Карл у Клары украл кораллы»</li>
        <li>Повторяйте звуки «с», «з», «ш», «ж» — они страдают чаще всего</li>
      </ul>
      <p>Дикция восстанавливается за 1-2 недели.</p>

      <h2>Что есть в первые дни</h2>

      <ul>
        <li>Каши, супы-пюре, йогурты, творог — первая неделя</li>
        <li>Мягкие фрукты (бананы, персики) — со второй недели</li>
        <li>Мясо мелкими кусочками — с третьей недели</li>
        <li>Яблоки, орехи, семечки — не раньше месяца</li>
      </ul>

      <h2>Когда нужна коррекция</h2>

      <ul>
        <li>Боль при накусывании не проходит 3-5 дней</li>
        <li>Протез слетает при разговоре или смехе</li>
        <li>Под протез попадает еда</li>
        <li>Протез треснул или сломался</li>
      </ul>

      <h2>Чего нельзя делать</h2>

      <ul>
        <li>Подтачивать протез самостоятельно</li>
        <li>Клеить его суперклеем</li>
        <li>Спать в протезе (нужно давать десне отдых)</li>
        <li>Чистить абразивной пастой или щёткой с жёсткой щетиной</li>
      </ul>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, category?.id)} />
      <div class="cta">
        <p>Адаптация к протезу — временный этап. В Нижнем Новгороде я помогу пройти его с минимальным дискомфортом.</p>
        <a href={`tel:${doctor.phone}`} class="btn">+7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ldArticle)} />

<style>
.back { color: var(--color-primary); margin-bottom: 1rem; display: inline-block; }
article { background: white; border-radius: 12px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
h1 { color: var(--color-text); margin-bottom: 0.5rem; font-size: 1.75rem; }
.meta { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }
.lead { font-size: 1.1rem; color: var(--color-text); line-height: 1.7; margin-bottom: 2rem; background: var(--color-bg-alt); padding: 1rem; border-radius: 8px; }
h2 { color: var(--color-primary); margin: 2rem 0 1rem; font-size: 1.3rem; }
p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: 1rem; }
ul, ol { color: var(--color-text-muted); padding-left: 1.5rem; margin-bottom: 1rem; }
li { margin-bottom: 0.5rem; line-height: 1.6; }
.translation { font-style: italic; color: var(--color-text); background: var(--color-bg-alt); padding: 0.75rem; border-radius: 8px; }
.table-wrap { overflow-x: auto; margin: 1rem 0; }
table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid #e5e7eb; }
th { background: var(--color-bg-alt); font-weight: 600; color: var(--color-text); }
td { color: var(--color-text-muted); }
.cta { text-align: center; padding: 1.5rem; background: var(--color-bg-alt); border-radius: 8px; margin-top: 2rem; }
.cta p { margin-bottom: 1rem; color: var(--color-text); }
.btn { display: inline-block; background: var(--color-primary); color: white; padding: 0.75rem 2rem; border-radius: var(--radius-full); text-decoration: none; font-weight: 600; }
.btn:hover { background: var(--color-primary-hover); }
.breadcrumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
.breadcrumbs a { color: var(--color-primary); text-decoration: none; }
.breadcrumbs a:hover { text-decoration: underline; }
.sep { color: var(--color-text-muted); }
</style>
