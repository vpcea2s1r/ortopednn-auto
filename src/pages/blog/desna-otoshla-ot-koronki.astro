const category = articleData?.category ? getCategory(articleData.category) : null;
const relatedArticles = getRelatedArticles(slug);
const catId = category ? category.id : null;
const ldArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Десна отошла от коронки — что делать",
  "description": "Десна отошла от коронки — причины: плохая гигиена, травма, некачественная коронка. Лечение: гигиена, замена коронки, противовоспалительная терапия. Профилактика рецессии десны.",
  "author": { "@id": "https://ortopednn.ru/#doctor" },
  "datePublished": "2026-01-15",
  "dateModified": "2026-05-16",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "image": "https://ortopednn.ru/og-image.svg",
  "publisher": { "@id": "https://ortopednn.ru/#clinic" }
};
---

<BaseLayout 
  title="Десна отошла от коронки — что делать | Никитина М.Г."
  description="Десна отошла от коронки — причины: плохая гигиена, травма, некачественная коронка. Лечение: гигиена, замена коронки, противовоспалительная терапия. Профилактика рецессии десны."
  breadcrumbTitle="Десна отошла от коронки"
  doctor={doctor}
  socials={socials}
  datePublished="2026-01-15"
  dateModified="2026-05-16"
>
  <Navbar />
  <main class="container container--w800">
    <a href="/blog" class="back">К статьям</a>
    <nav class="breadcrumbs">
      <a href="/blog">Блог</a>
      {category && <><span class="sep">›</span><a href={'/blog/' + category.id}>{category.name}</a></>}
      <span class="sep">›</span><span>{articleData?.title}</span>
    </nav>

    <article>
      <h1>Десна отошла от коронки — что делать</h1>
      <div class="meta">15 января 2026 — Никитина М.Г., стоматолог-ортопед</div>

      <p class="lead">Обнажение края коронки и рецессия десны — не только эстетическая проблема. Открытая граница коронки становится местом скопления налёта и бактерий, что ведёт к воспалению и риску потери зуба.</p>

      <h2>Почему десна отходит от коронки</h2>
      <p><strong>Плохая гигиена</strong> — налёт у края коронки вызывает хроническое воспаление, десна опускается. Это самая частая причина.</p>
      <p><strong>Травма краем коронки</strong> — если коронка слишком выступает или имеет острый край, она механически травмирует десну, вызывая её рецессию.</p>
      <p><strong>Некачественная коронка</strong> — плохое краевое прилегание, зазор между коронкой и зубом. В щель попадает пища, начинается воспаление.</p>
      <p><strong>Пародонтит</strong> — системное заболевание десны, при котором десна опускается на всех зубах, в том числе под коронками.</p>
      <p><strong>Бруксизм</strong> — чрезмерная нагрузка на коронку может приводить к хронической травме десны.</p>

      <h2>Симптомы и чем опасно</h2>
      <p>Основные признаки: видимый край коронки, кровоточивость при чистке, покраснение и отёк десны, неприятный запах из кармана, боль при накусывании. В образовавшийся карман попадает пища и бактерии. Начинается воспаление, которое может перейти на корень зуба. Со временем кость вокруг зуба разрушается, и коронка может потерять устойчивость.</p>

      <h2>Диагностика</h2>
      <p>Врач оценивает глубину пародонтального кармана зондом. Норма — 1–3 мм. Если глубина больше 4 мм — это патология. Делается рентгеновский снимок для оценки состояния костной ткани и качества пломбировки каналов. Проверяется краевое прилегание коронки — если есть зазор, коронку нужно менять.</p>

      <h2>Варианты лечения</h2>
      <p>Если коронка качественная, а причина в гигиене — проводится профессиональная гигиена (ультразвук, Air Flow) и курс противовоспалительной терапии. Назначаются полоскания хлоргексидином, аппликации с метрогилом. Через 7–10 дней воспаление стихает.</p>
      <p>Если коронка не прилегает — её заменяют. Старую снимают, зуб препарируют заново, изготавливают новую коронку с правильным краевым прилеганием.</p>
      <p>При глубоком кармане (более 5 мм) может потребоваться лоскутная операция — открытая чистка кармана с иссечением разросшейся ткани.</p>

      <h2>Сравнение методов лечения</h2>
      <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Критерий</th><th>Консервативное лечение (гигиена + терапия)</th><th>Замена коронки</th></tr>
        </thead>
        <tbody>
          <tr><td>Показания</td><td>Качественная коронка, налёт, воспаление</td><td>Некачественная коронка, зазор, скол</td></tr>
          <tr><td>Количество визитов</td><td>2–3 (гигиена + контроль)</td><td>2–3 (снятие, препарирование, фиксация)</td></tr>
          <tr><td>Сохранение коронки</td><td>Да</td><td>Нет</td></tr>
          <tr><td>Эффективность</td><td>Высокая при ранней стадии</td><td>Полное устранение проблемы</td></tr>
          <tr><td>Стоимость</td><td>Низкая</td><td>Средняя/высокая</td></tr>
        </tbody>
      </table>
      </div>

      <h2>Профилактика рецессии десны</h2>
      <p>Тщательная гигиена зоны коронки — используйте ирригатор и зубную нить для очистки границы коронки и десны. Регулярные осмотры каждые 6 месяцев — врач заметит проблему на ранней стадии. Профессиональная чистка раз в год — удаляет налёт в местах, недоступных щётке. Своевременная замена старых коронок каждые 10–15 лет.</p>

      <div class="faq">
        <div class="faq-item">
          <h3>Может ли десна восстановиться сама?</h3>
          <p>Нет. Если десна уже опустилась, сама она не вырастет обратно. Можно остановить процесс и не допустить дальнейшей рецессии. Восстановить объём десны можно только хирургически.</p>
        </div>
        <div class="faq-item">
          <h3>Что будет, если не лечить?</h3>
          <p>Воспаление будет прогрессировать. Бактерии проникнут глубже, начнётся разрушение кости вокруг зуба. Зуб потеряет устойчивость, и коронка может выпасть вместе с зубом.</p>
        </div>
        <div class="faq-item">
          <h3>Больна ли процедура лечения?</h3>
          <p>Профессиональная гигиена и противовоспалительная терапия безболезненны. Замена коронки проводится под местной анестезией.</p>
        </div>
        <div class="faq-item">
          <h3>Можно ли чистить зубы с ирригатором, если десна отошла?</h3>
          <p>Да, ирригатор даже показан — он вымывает остатки пищи из кармана. Используйте минимальный напор, направляя струю под углом к десне.</p>
        </div>
        <div class="faq-item">
          <h3>Помогут ли народные средства?</h3>
          <p>Полоскания ромашкой или корой дуба могут временно снять воспаление, но не устранят причину. При рецессии десны необходима профессиональная диагностика.</p>
        </div>
        <div class="faq-item">
          <h3>Через какое время после лечения проходит воспаление?</h3>
          <p>При консервативном лечении воспаление стихает через 5–7 дней. Полное заживление десны занимает 2–3 недели.</p>
        </div>
        <div class="faq-item">
          <h3>Может ли коронка выпасть, если десна отошла?</h3>
          <p>Да. При нарушении краевого прилегания цемент вымывается, коронка теряет фиксацию и может сместиться или выпасть. Это повод для срочного визита к врачу.</p>
        </div>
      </div>

      <p><em>Автор: Никитина М.Г., стоматолог-ортопед. Статья носит информационный характер, обратитесь к врачу для консультации.</em></p>

      <RelatedArticles articles={relatedArticles} />
      <RelatedServices services={getRelatedServices(slug, catId)} />
      <div class="cta">
        <p>Десна отошла от коронки? Запишитесь на приём — определю причину и назначу лечение.</p>
        <a href={'tel:' + doctor.phone} class="btn">+7 (920) 253-73-17</a>
      </div>
    </article>
  </main>
</BaseLayout>

