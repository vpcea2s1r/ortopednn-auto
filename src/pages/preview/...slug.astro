---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
import { existsSync, readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import type { DraftMeta } from '../../../data/draft-types';

export async function getStaticPaths() {
  const draftsDir = join(process.cwd(), 'data', 'drafts');
  if (!existsSync(draftsDir)) return [];

  return readdirSync(draftsDir)
    .filter(f => f.endsWith('.json') && f !== 'draft-types.ts')
    .map(f => {
      const data: DraftMeta = JSON.parse(readFileSync(join(draftsDir, f), 'utf-8'));
      return { params: { slug: data.slug }, props: { draft: data } };
    });
}

const { draft } = Astro.props;
const pageUrl = `https://ortopednn.ru/preview/${draft.slug}/`;
---

<BaseLayout
  title={`${draft.title} (предпросмотр)`}
  description={draft.description}
  breadcrumbTitle={draft.title}
  doctor={doctor}
  socials={socials}
  noindex={true}
  datePublished={draft.date}
  dateModified={draft.date}
>
  <Navbar />
  <main class="container container--w800">
    <div class="preview-banner">
      <span class="preview-badge">ЧЕРНОВИК</span>
      <span>Предпросмотр. Опубликуйте в Telegram через <a href="https://t.me/ortopednn52_bot">@ortopednn52_bot</a> → /drafts</span>
    </div>

    <article class="preview-article">
      <h1>{draft.title}</h1>
      <time class="preview-date">{draft.date}</time>
      <div set:html={draft.body} />
    </article>

    <div class="preview-actions">
      <button class="btn btn-publish" data-slug={draft.slug}>✅ Опубликовать</button>
      <button class="btn btn-delete" data-slug={draft.slug}>🗑 Удалить</button>
      <p class="preview-fallback">Если кнопки не работают — откройте Telegram, команда <code>/drafts</code></p>
    </div>
  </main>
</BaseLayout>

<script>
  const API = 'http://94.183.155.147:3000';

  async function apiAction(slug, action) {
    try {
      const r = await fetch(`${API}/api/preview/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug })
      });
      const data = await r.json();
      if (r.ok) {
        window.location.href = action === 'publish' ? `/blog/${slug}/` : '/';
      } else {
        alert('Ошибка: ' + (data.error || 'неизвестная'));
      }
    } catch {
      alert('Сервер недоступен. Опубликуйте через Telegram /drafts');
    }
  }

  document.querySelector('.btn-publish')?.addEventListener('click', function() {
    apiAction(this.dataset.slug, 'publish');
  });
  document.querySelector('.btn-delete')?.addEventListener('click', function() {
    if (confirm('Удалить черновик?')) {
      apiAction(this.dataset.slug, 'delete');
    }
  });
</script>

<style>
  .preview-banner {
    display: flex; align-items: center; gap: var(--space-sm);
    background: #fff3cd; border: 1px solid #ffc107; border-radius: var(--radius-md);
    padding: var(--space-sm) var(--space-md); margin-bottom: var(--space-lg);
    font-size: var(--text-sm);
  }
  .preview-banner a { color: var(--color-primary); }
  .preview-badge {
    background: #dc3545; color: white; font-weight: 700; font-size: var(--text-xs);
    padding: 2px 8px; border-radius: var(--radius-sm); letter-spacing: .05em;
  }
  .preview-date {
    display: block; color: var(--color-text-muted); font-size: var(--text-sm);
    margin-bottom: var(--space-lg);
  }
  .preview-article h1 { margin-bottom: var(--space-xs); }
  .preview-article { margin-bottom: var(--space-xl); }
  .preview-actions {
    display: flex; gap: var(--space-sm); flex-wrap: wrap; align-items: center;
    padding-top: var(--space-lg); border-top: 1px solid var(--color-border);
  }
  .btn {
    padding: var(--space-sm) var(--space-lg); border: none; border-radius: var(--radius-md);
    font-size: var(--text-base); font-weight: 600; cursor: pointer;
    transition: opacity var(--transition-normal);
  }
  .btn:hover { opacity: .85; }
  .btn-publish { background: #28a745; color: white; }
  .btn-delete { background: #dc3545; color: white; }
  .preview-fallback {
    width: 100%; font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-sm);
  }
</style>
