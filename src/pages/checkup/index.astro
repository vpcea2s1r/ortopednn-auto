---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
---

<BaseLayout 
  title="Самодиагностика зубов | Никитина М.Г."
  description="Чек-лист для проверки здоровья зубов. Когда пора к стоматологу."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="container">
    <a href="/" class="back">← На главную</a>
    
    <h1>Когда пора к стоматологу?</h1>
    <p class="intro">Простой чек-лист поможет понять, нужен ли вам визит к ортопеду.</p>

    <div class="checklist">
      <h2>Проверьте себя</h2>
      
      <div class="item warning">
        <input type="checkbox" id="q1">
        <label for="q1">Отсутствуют один или несколько зубов</label>
      </div>
      <div class="item warning">
        <input type="checkbox" id="q2">
        <label for="q2">Зубы шатаются или изменили положение</label>
      </div>
      <div class="item">
        <input type="checkbox" id="q3">
        <label for="q3">Затруднёно жевание на определённой стороне</label>
      </div>
      <div class="item">
        <input type="checkbox" id="q4">
        <label for="q4">Боль при накусывании на конкретный зуб</label>
      </div>
      <div class="item">
        <input type="checkbox" id="q5">
        <label for="q5">Старые коронки потемнели или шатаются</label>
      </div>
      <div class="item">
        <input type="checkbox" id="q6">
        <label for="q6">Дёсны кровоточат при чистке</label>
      </div>
      <div class="item info">
        <input type="checkbox" id="q7">
        <label for="q7">Вы носите съёмный протез более 5 лет</label>
      </div>
      <div class="item info">
        <input type="checkbox" id="q8">
        <label for="q8">Протез стал натирать или плохо фиксируется</label>
      </div>
      <div class="item">
        <input type="checkbox" id="q9">
        <label for="q9">Изменился прикус или форма лица</label>
      </div>
      <div class="item">
        <input type="checkbox" id="q10">
        <label for="q10">Челюсть щёлкает или болит при открывании</label>
      </div>
    </div>

    <div class="result" id="result">
      <h3>Результат</h3>
      <p id="result-text">Отметьте пункты, которые относятся к вам.</p>
      <div id="recommendation" class="recommendation-box" style="display:none;"></div>
    </div>

    <div class="info-section">
      <h2>Статистика</h2>
      <div class="stats">
        <div class="stat">
          <div class="number">97%</div>
          <div class="label">Пациенты с потерей более 5 зубов нуждаются в протезировании для восстановления функции.</div>
        </div>
        <div class="stat">
          <div class="number">5-7 лет</div>
          <div class="label">Средний срок службы съёмного протеза (International Journal of Prosthodontics)</div>
        </div>
      </div>
    </div>

    <div class="symptoms">
      <h2>Тревожные симптомы</h2>
      <p>По данным клинических рекомендаций, при обнаружении следующих симптомов требуется незамедлительная консультация стоматолога:</p>
      
      <div class="symptom-grid">
        <div class="symptom">
          <h3>Срочно</h3>
          <ul>
            <li>Острая боль в зубе или челюсти</li>
            <li>Отёк десны или щеки</li>
            <li>Подвижность коронки</li>
          </ul>
        </div>
        <div class="symptom">
          <h3>Планово</h3>
          <ul>
            <li>Дискомфорт при жевании</li>
            <li>Натирание протеза</li>
            <li>Изменение цвета дёсен</li>
          </ul>
        </div>
        <div class="symptom">
          <h3>Профилактика</h3>
          <ul>
            <li>Осмотр раз в год</li>
            <li>Замена протеза после 5-7 лет</li>
            <li>Профессиональная чистка</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="cta">
      <h3>Нужна консультация?</h3>
      <p>Позвоните — разберём вашу ситуацию и составим план лечения.</p>
      <a href={`tel:${doctor.phone}`} class="btn">Позвонить</a>
    </div>
  </main>
</BaseLayout>

<script>
  const checkboxes = document.querySelectorAll('input[type="checkbox"]');
  const resultText = document.getElementById('result-text');
  const recommendation = document.getElementById('recommendation');
  
  checkboxes.forEach(cb => {
    cb.addEventListener('change', updateResult);
  });
  
  function updateResult() {
    const checked = document.querySelectorAll('input[type="checkbox"]:checked').length;
    const warnings = document.querySelectorAll('.item.warning input:checked').length;
    
    if (checked === 0) {
      resultText.textContent = 'Отметьте пункты, которые относятся к вам.';
      recommendation.style.display = 'none';
    } else if (warnings >= 2 || checked >= 5) {
      resultText.textContent = `${checked} отмеченных пунктов`;
      recommendation.innerHTML = '<strong>Рекомендуем записаться на консультацию.</strong> Чем раньше вы обратитесь, тем проще решить проблему.';
      recommendation.style.display = 'block';
    } else if (checked >= 2) {
      resultText.textContent = `${checked} отмеченных пунктов`;
      recommendation.innerHTML = 'Желательно пройти осмотр. Запишитесь на плановую консультацию.';
      recommendation.style.display = 'block';
    } else {
      resultText.textContent = `${checked} отмеченный пункт`;
      recommendation.innerHTML = 'Всё в порядке. Но если что-то беспокоит — звоните.';
      recommendation.style.display = 'block';
    }
  }
</script>

<style>
.container { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
.intro { color: #5a7a9a; margin-bottom: 2rem; font-size: 1.1rem; }
.checklist { background: white; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
.checklist h2 { color: #1e3a5f; margin-bottom: 1rem; }
.item { display: flex; align-items: center; padding: 0.75rem; border-radius: 8px; margin-bottom: 0.5rem; background: #f8fafc; }
.item input { width: 24px; height: 24px; margin-right: 1rem; }
.item label { font-size: 1rem; cursor: pointer; color: #1e3a5f; flex: 1; }
.item.warning { background: #fef3c7; }
.item.info { background: #dbeafe; }
.result { background: white; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; text-align: center; }
.result h3 { color: #1e3a5f; margin-bottom: 1rem; }
#result-text { font-size: 1.1rem; color: #5a7a9a; }
.recommendation-box { margin-top: 1rem; padding: 1rem; background: linear-gradient(135deg, #e8f4fd, #f0f8ff); border-radius: 8px; color: #1e3a5f; font-size: 1rem; }
.info-section { background: white; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
.info-section h2 { color: #1e3a5f; margin-bottom: 1rem; }
.stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.stat { text-align: center; padding: 1rem; background: #f8fafc; border-radius: 8px; }
.stat .number { font-size: 2rem; font-weight: 700; color: #4a90d9; margin-bottom: 0.5rem; }
.stat .label { font-size: 0.85rem; color: #5a7a9a; }
.symptoms { background: white; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
.symptoms h2 { color: #1e3a5f; margin-bottom: 1rem; }
.symptoms p { color: #5a7a9a; margin-bottom: 1rem; font-style: italic; }
.symptom-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.symptom h3 { font-size: 0.9rem; margin-bottom: 0.75rem; }
.symptom ul { list-style: none; padding: 0; }
.symptom li { font-size: 0.9rem; color: #5a7a9a; padding: 0.25rem 0; }
.cta { text-align: center; padding: 2rem; background: linear-gradient(135deg, #e8f4fd, #f0f8ff); border-radius: 12px; }
.cta h3 { color: #1e3a5f; }
.cta p { color: #5a7a9a; margin: 1rem 0; }
.btn { display: inline-block; background: #4a90d9; color: white; padding: 0.75rem 2rem; border-radius: 100px; text-decoration: none; font-weight: 600; }
@media (max-width: 640px) {
  .stats, .symptom-grid { grid-template-columns: 1fr; }
}
</style>