---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout
  title="Полный съёмный протез — цена, виды | Никитина М.Г."
  description="Цена полного съёмного протеза в Нижнем Новгороде. Акриловые, нейлоновые, AcryFree — сравнение стоимости и материалов."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/checkup">Самопроверка</a><span>/</span><span>Полный съёмный протез цена</span></div></nav>

    <article class="content">
      <div class="container">
        <h1>Полный съёмный протез — цена и особенности</h1>
        <p class="lead">При полном отсутствии зубов на одной или обеих челюстях съёмный протез остаётся основным способом восстановления жевательной функции. Современные материалы и методики позволяют сделать конструкцию комфортной и эстетичной.</p>

        <section>
          <h2>Цена полного съёмного протеза</h2>
          <p>Стоимость зависит от материала и сложности изготовления. Акриловый полный протез — от 15 000 ₽. Протез AcryFree — от 41 400 ₽. Нейлоновый — от 41 400 ₽. Иммедиат-протез (временный) — от 12 940 ₽. Полный протез на имплантатах — от 80 000 ₽. Цена включает изготовление в лаборатории, постановку зубов, примерки и фиксацию.</p>
        </section>

        <section>
          <h2>Какой полный протез выбрать</h2>
          <p><strong>Акриловый</strong> — бюджетный вариант. Жёсткий базис, привычная конструкция. Требует привыкания, может натирать. Срок службы 5–7 лет.</p>
          <p><strong>AcryFree</strong> — полужёсткий термопласт без мономера. Комфортнее акрила, гипоаллергенный. Ремонтопригоден. Срок службы 5–7 лет.</p>
          <p><strong>Нейлоновый</strong> — мягкий и гибкий. Не вызывает аллергии, минимальный период адаптации. Сложнее в ремонте. Срок службы 3–5 лет.</p>
          <p><strong>На имплантатах</strong> — фиксируется на 2–4 имплантах. Максимальная стабильность, не снимается без помощи врача. Значительно дороже, но комфорт несравнимо выше.</p>
        </section>

        <section>
          <h2>Как происходит изготовление</h2>
          <p>Процесс включает 5–7 визитов к врачу. Снимаются слепки, изготавливается индивидуальная ложка, определяются прикус и центральное соотношение челюстей, проводится постановка зубов, примерка восковой модели и финальная замена акрилом. Общий срок — 2–4 недели.</p>
        </section>

        <section>
          <h2>Как привыкнуть к полному протезу</h2>
          <p>Период адаптации — от нескольких дней до 3 недель. Рекомендуется не снимать протез на ночь первые 2 недели, начинать с мягкой пищи, читать вслух для восстановления дикции. При натирании — обязательная коррекция у стоматолога, не пытайтесь подтачивать протез самостоятельно.</p>
        </section>

        <section class="cta-section">
          <h2>Нужен полный съёмный протез?</h2>
          <p>Никитина Марина Георгиевна проведёт консультацию и подберёт оптимальный вариант. Бесплатный осмотр.</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="/services/polny-sjemny-protez" class="btn btn--secondary">Подробнее</a>
          </div>
        </section>

        <nav class="related">
          <h3>Читайте также:</h3>
          <ul>
            <li><a href="/checkup/semnyj-protez-cena">Съёмный протез — цены в НН</a></li>
            <li><a href="/checkup/nejlonovyj-protez">Нейлоновый протез — отзывы</a></li>
            <li><a href="/checkup/akrilovyj-protez">Акриловый протез</a></li>
            <li><a href="/checkup/kakoj-protez-vybrat">Какой протез лучше выбрать</a></li>
          </ul>
        </nav>
      </div>
    </article>
  </main>

  <style>
    .page { min-height: 100vh; background: var(--color-bg-alt); }
    .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
    .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
    .breadcrumbs a { color: var(--color-primary); }
    .content { padding: var(--space-3xl) 0; }
    .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); }
    .content h1 { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); }
    .content h2 { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; }
    .content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); }
    .content ul { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
    .content li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.7; }
    .lead { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; }
    .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl); border-radius: var(--radius-xl); margin-top: var(--space-3xl); text-align: center; }
    .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
    .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); }
    .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); }
    .btn--primary { background: white; color: var(--color-primary); }
    .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-decoration: none; }
    .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); }
    .btn--secondary:hover { border-color: white; text-decoration: none; }
    .related { margin-top: var(--space-2xl); padding: var(--space-lg); background: white; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
    .related h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-sm); }
    .related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-sm); }
    .related li { margin: 0; }
    .related a { color: var(--color-primary); font-size: var(--text-sm); }
    @media (max-width: 768px) {
      .content h1 { font-size: var(--text-2xl); }
      .cta-section { padding: var(--space-xl) var(--space-md); }
      .cta-buttons { flex-direction: column; align-items: center; }
    }
  </style>
</BaseLayout>
