---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---
<BaseLayout title="Скрипит протез при жевании — что делать | Никитина М.Г." description="Съёмный протез скрипит при жевании — причины: неправильная посадка, износ материала, деформация. Коррекция у стоматолога." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/checkup">Самопроверка</a><span>/</span><span>Скрипит протез при жевании</span></div></nav>
    <article class="content"><div class="container">
      <h1>Скрипит протез при жевании — что делать</h1>
      <p class="lead">Скрежет или скрип при жевании — сигнал, что протез контактирует с зубами-антагонистами неравномерно или смещается при нагрузке.</p>
      <section><h2>Причины скрипа</h2>
      <p><strong>Неравномерный прикус</strong> — протез соприкасается с зубами на другой челюсти не во всех точках. Возникает точечный контакт, который создаёт скрип. <strong>Смещение протеза</strong> — при слабой фиксации протез двигается при жевании, создавая трение. <strong>Износ материала</strong> — искусственные зубы со временем стираются, меняется угол смыкания. <strong>Деформация базиса</strong> — при неравномерной нагрузке пластмассовый базис может деформироваться.</p></section>
      <section><h2>Что делать</h2>
      <p>Коррекция прикуса — стоматолог подтачивает точки избыточного контакта. Занимает 10–15 минут. Если скрип вызван смещением протеза — перебазировка или замена фиксирующего материала. При значительном износе — замена искусственных зубов или всего протеза.</p></section>
      <section class="cta-section"><h2>Скрипит протез? Исправим.</h2>
      <p>Никитина Марина Георгиевна — быстрая коррекция без боли.</p>
      <div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="/services/korrekciya" class="btn btn--secondary">Коррекция</a></div></section>
      <nav class="related"><h3>Читайте также:</h3><ul><li><a href="/checkup/protez-ploho-derzhitsya">Протез плохо держится</a></li><li><a href="/checkup/protez-tresnul">Протез треснул</a></li></ul></nav>
    </div></article>
  </main>
  <style>.page { min-height: 100vh; background: var(--color-bg-alt); } .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); } .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; } .breadcrumbs a { color: var(--color-primary); } .content { padding: var(--space-3xl) 0; } .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); } .content h1 { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); } .content h2 { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; } .content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); } .lead { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; } .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl); border-radius: var(--radius-xl); margin-top: var(--space-3xl); text-align: center; } .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); } .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); } .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; } .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); } .btn--primary { background: white; color: var(--color-primary); } .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-decoration: none; } .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); } .btn--secondary:hover { border-color: white; text-decoration: none; } .related { margin-top: var(--space-2xl); padding: var(--space-lg); background: white; border-radius: var(--radius-xl); border: 1px solid var(--color-border); } .related h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-sm); } .related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-sm); } .related li { margin: 0; } .related a { color: var(--color-primary); font-size: var(--text-sm); } @media (max-width: 768px) { .content h1 { font-size: var(--text-2xl); } .cta-section { padding: var(--space-xl) var(--space-md); } .cta-buttons { flex-direction: column; align-items: center; } }</style>
</BaseLayout>
