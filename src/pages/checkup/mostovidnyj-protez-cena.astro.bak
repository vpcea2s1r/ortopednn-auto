---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout
  title="Мостовидный протез — цены и виды | Никитина М.Г."
  description="Мостовидные протезы в Нижнем Новгороде — цены от 27 000 ₽ за 3 единицы. Металлокерамика, цирконий, адгезивные мосты."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/checkup">Самопроверка</a><span>/</span><span>Мостовидный протез цена</span></div></nav>

    <article class="content">
      <div class="container">
        <h1>Сколько стоит мостовидный протез</h1>
        <p class="lead">Мостовидный протез (мост) — несъёмная конструкция для замещения одного или нескольких отсутствующих зубов. Фиксируется на соседних опорных зубах. Это альтернатива имплантации, не требующая хирургического вмешательства.</p>

        <section>
          <h2>Цена мостовидного протеза</h2>
          <p>Стоимость зависит от материала и количества единиц. Металлокерамический мост на 3 единицы — от 27 000 ₽. Циркониевый мост — от 65 000–80 000 ₽. Адгезивный мост (на 1 зуб, с минимальной обточкой соседних) — от 10 000–15 000 ₽. Мост на имплантатах рассчитывается индивидуально, включает стоимость имплантов и абатментов. Металлокерамика остаётся самым популярным вариантом для мостов — оптимальное соотношение цены, прочности и эстетики.</p>
        </section>

        <section>
          <h2>Показания</h2>
          <ul>
            <li>Отсутствие одного или нескольких зубов подряд</li>
            <li>Здоровые опорные зубы с обеих сторон дефекта</li>
            <li>Невозможность или нежелание проводить имплантацию</li>
            <li>Достаточная высота опорных зубов для препарирования</li>
          </ul>
        </section>

        <section>
          <h2>Срок службы моста</h2>
          <p>Металлокерамический мост служит 10–15 лет при правильном уходе. Циркониевый — 15–20 лет. Основная причина потери — не износ конструкции, а кариес опорных зубов под коронками. Поэтому гигиена зоны моста — ирригатор, зубная нить, регулярные осмотры — критически важны для долговечности.</p>
        </section>

        <section>
          <h2>Мост или имплантат</h2>
          <p>Имплантат — более физиологичное решение: он замещает и корень зуба, сохраняя объём кости. Мост быстрее и дешевле, но требует обточки соседних здоровых зубов. Если соседние зубы уже имеют коронки или разрушены, мост — рациональный выбор. Если соседние зубы здоровы, предпочтительнее имплантат, чтобы не травмировать здоровые ткани.</p>
        </section>

        <section class="cta-section">
          <h2>Нужна консультация по мосту?</h2>
          <p>Никитина Марина Георгиевна подберёт оптимальный вариант протезирования. Бесплатный осмотр.</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="/services/metallokeramika" class="btn btn--secondary">О металлокерамике</a>
          </div>
        </section>

        <nav class="related">
          <h3>Читайте также:</h3>
          <ul>
            <li><a href="/checkup/koronka-na-zub-cena">Коронка на зуб — цена</a></li>
            <li><a href="/checkup/implantatsiya-cena">Протезирование на имплантах</a></li>
            <li><a href="/checkup/kakoj-protez-vybrat">Какой протез лучше выбрать</a></li>
          </ul>
        </nav>
      </div>
    </article>
  </main>

  <style>
    .page { min-height: 100vh; background: var(--color-bg-alt); }
    .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
    .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
    .breadcrumbs a { color: var(--color-primary); }
    .content { padding: var(--space-3xl) 0; }
    .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); }
    .content h1 { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); }
    .content h2 { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; }
    .content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); }
    .content ul { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
    .content li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.7; }
    .lead { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; }
    .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl); border-radius: var(--radius-xl); margin-top: var(--space-3xl); text-align: center; }
    .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
    .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); }
    .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); }
    .btn--primary { background: white; color: var(--color-primary); }
    .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-decoration: none; }
    .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); }
    .btn--secondary:hover { border-color: white; text-decoration: none; }
    .related { margin-top: var(--space-2xl); padding: var(--space-lg); background: white; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
    .related h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-sm); }
    .related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-sm); }
    .related li { margin: 0; }
    .related a { color: var(--color-primary); font-size: var(--text-sm); }
    @media (max-width: 768px) {
      .content h1 { font-size: var(--text-2xl); }
      .cta-section { padding: var(--space-xl) var(--space-md); }
      .cta-buttons { flex-direction: column; align-items: center; }
    }
  </style>
</BaseLayout>
