---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---
<BaseLayout title="Снятие коронки с зуба — цена | Никитина М.Г." description="Снятие коронки с зуба — цена от 275 ₽. Когда нужно снимать, как проходит процедура, можно ли установить ту же коронку обратно." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/checkup">Самопроверка</a><span>/</span><span>Снятие коронки цена</span></div></nav>
    <article class="content"><div class="container">
      <h1>Снятие коронки с зуба — цена и этапы</h1>
      <p class="lead">Снятие коронки может потребоваться при боли, вторичном кариесе или замене конструкции. Процедура несложная и недорогая.</p>
      <section><h2>Когда нужно снимать коронку</h2>
      <ul><li>Боль под коронкой — необходимо лечение зуба</li><li>Вторичный кариес на границе коронки</li><li>Скол керамики</li><li>Плановое замена старой коронки</li><li>Изменение цвета десны вокруг коронки</li></ul></section>
      <section><h2>Цена снятия коронки</h2>
      <p>Снятие штампованной коронки — 275 ₽. Снятие цельнолитой коронки — 1 000 ₽. Снятие коронки на имплантате — рассчитывается индивидуально. После снятия врач оценивает состояние зуба и принимает решение: лечить и фиксировать заново или изготавливать новую коронку.</p></section>
      <section><h2>Как проходит снятие</h2>
      <p>Врач использует ультразвуковой скалер или специальный коронкосниматель (крючок). Аппарат создаёт вибрацию, нарушающую сцепление цемента, после чего коронка аккуратно снимается. Процедура занимает 10–20 минут. В большинстве случаев анестезия не требуется, так как воздействие идёт на коронку, а не на зуб.</p></section>
      <section><h2>Можно ли поставить ту же коронку обратно</h2>
      <p>Если коронка не повреждена и зуб под ней здоров — да, врач очищает её и фиксирует заново. Если коронка деформирована при снятии или зуб требует лечения — потребуется новая.</p></section>
      <section class="cta-section"><h2>Нужно снять коронку?</h2>
      <p>Никитина Марина Георгиевна — быстрое и аккуратное снятие без повреждения зуба.</p>
      <div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="/services/snatie-shtampovannyh" class="btn btn--secondary">Снятие коронок</a></div></section>
      <nav class="related"><h3>Читайте также:</h3><ul><li><a href="/checkup/bolit-zub-pod-koronkoj">Болит зуб под коронкой</a></li><li><a href="/checkup/vypala-koronka">Выпала коронка</a></li></ul></nav>
    </div></article>
  </main>
  <style>.page { min-height: 100vh; background: var(--color-bg-alt); } .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); } .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; } .breadcrumbs a { color: var(--color-primary); } .content { padding: var(--space-3xl) 0; } .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); } .content h1 { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); } .content h2 { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; } .content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); } .content ul { padding-left: var(--space-lg); margin-bottom: var(--space-md); } .content li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.7; } .lead { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; } .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl); border-radius: var(--radius-xl); margin-top: var(--space-3xl); text-align: center; } .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); } .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); } .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; } .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); } .btn--primary { background: white; color: var(--color-primary); } .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-decoration: none; } .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); } .btn--secondary:hover { border-color: white; text-decoration: none; } .related { margin-top: var(--space-2xl); padding: var(--space-lg); background: white; border-radius: var(--radius-xl); border: 1px solid var(--color-border); } .related h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-sm); } .related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-sm); } .related li { margin: 0; } .related a { color: var(--color-primary); font-size: var(--text-sm); } @media (max-width: 768px) { .content h1 { font-size: var(--text-2xl); } .cta-section { padding: var(--space-xl) var(--space-md); } .cta-buttons { flex-direction: column; align-items: center; } }</style>
</BaseLayout>
