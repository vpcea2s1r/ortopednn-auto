---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---

<BaseLayout
  title="Выпала коронка — что делать? | Никитина М.Г."
  description="Выпала коронка с зуба — причины, первая помощь, когда срочно к врачу. Как временно зафиксировать коронку в домашних условиях."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/checkup">Самопроверка</a><span>/</span><span>Выпала коронка что делать</span></div></nav>

    <article class="content">
      <div class="container">
        <h1>Выпала коронка — что делать</h1>
        <p class="lead">Если коронка отклеилась или выпала вместе со штифтом — не паникуйте. В большинстве случаев её можно установить обратно, если обратиться к стоматологу вовремя.</p>

        <section>
          <h2>Почему коронка может выпасть</h2>
          <p>Основная причина — ослабление фиксирующего цемента. Стеклоиономерные цементы со временем растворяются под воздействием слюны. Другие причины: вторичный кариес под коронкой, слишком большая жевательная нагрузка, неправильный прикус, трещина культи зуба. В среднем около 5–7% коронок требуют повторной фиксации в течение первых 5 лет после установки.</p>
        </section>

        <section>
          <h2>Первая помощь в домашних условиях</h2>
          <ul>
            <li>Сохраните коронку — не теряйте, не грызите</li>
            <li>Осмотрите коронку и зуб под ней: есть ли боль, кровь, видимые повреждения</li>
            <li>Прополощите рот тёплой водой — удалите остатки цемента</li>
            <li>Если коронка чистая и не повреждена — можно надеть её обратно на зуб для временной фиксации (не прикусывать сильно)</li>
            <li>Не используйте суперклей или стоматологический цемент из аптеки — это может повредить зуб и коронку</li>
            <li>Запишитесь к стоматологу в ближайшие 1–2 дня</li>
          </ul>
        </section>

        <section>
          <h2>Чего делать нельзя</h2>
          <p>Не клейте коронку самостоятельно — неправильная фиксация приведёт к нарушению прикуса, воспалению десны и потере зуба. Не пытайтесь сточить край коронки. Не жуйте на стороне выпавшей коронки. Не оставляйте зуб без коронки надолго — соседние зубы могут сместиться, и коронка уже не встанет на место.</p>
        </section>

        <section>
          <h2>Что сделает врач</h2>
          <p>Стоматолог осмотрит зуб и коронку, удалит остатки старого цемента, при необходимости проведёт лечение кариеса и зафиксирует коронку заново. Если коронка повреждена или не подходит по размеру из-за изменения десны, потребуется изготовление новой. Повторная фиксация возможна, если зуб под коронкой здоров.</p>
        </section>

        <section class="cta-section">
          <h2>Выпала коронка? Звоните.</h2>
          <p>Никитина Марина Георгиевна восстановит коронку. Приём в Нижнем Новгороде.</p>
          <div class="cta-buttons">
            <a href="tel:+79202537317" class="btn">Позвонить</a>
            <a href="/services/fiksaciya-fuji" class="btn btn--secondary">Фиксация коронок</a>
          </div>
        </section>

        <nav class="related">
          <h3>Читайте также:</h3>
          <ul>
            <li><a href="/checkup/bolit-zub-pod-koronkoj">Болит зуб под коронкой</a></li>
            <li><a href="/checkup/koronka-na-zub-cena">Сколько стоит коронка</a></li>
            <li><a href="/services/snatie-shtampovannyh">Снятие коронок</a></li>
          </ul>
        </nav>
      </div>
    </article>
  </main>

  <style>
    .page { min-height: 100vh; background: var(--color-bg-alt); }
    .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
    .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
    .breadcrumbs a { color: var(--color-primary); }
    .content { padding: var(--space-3xl) 0; }
    .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); }
    .content h1 { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); }
    .content h2 { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; }
    .content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); }
    .content ul { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
    .content li { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.7; }
    .lead { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; }
    .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl); border-radius: var(--radius-xl); margin-top: var(--space-3xl); text-align: center; }
    .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
    .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); }
    .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); }
    .btn--primary { background: white; color: var(--color-primary); }
    .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-decoration: none; }
    .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); }
    .btn--secondary:hover { border-color: white; text-decoration: none; }
    .related { margin-top: var(--space-2xl); padding: var(--space-lg); background: white; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
    .related h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-sm); }
    .related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-sm); }
    .related li { margin: 0; }
    .related a { color: var(--color-primary); font-size: var(--text-sm); }
    @media (max-width: 768px) {
      .content h1 { font-size: var(--text-2xl); }
      .cta-section { padding: var(--space-xl) var(--space-md); }
      .cta-buttons { flex-direction: column; align-items: center; }
    }
  </style>
</BaseLayout>
