---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
const doctor = { name: 'Никитина Марина Георгиевна', phone: '+79202537317', phoneDisplay: '7 920 253 73 17' };
const socials = [];
---
<BaseLayout title="Больно ли ставить коронку на зуб | Никитина М.Г." description="Больно ли ставить коронку на зуб — вся правда о процедуре. Анестезия, препарирование, фиксация. Что чувствует пациент." doctor={doctor} socials={socials}>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><a href="/checkup">Самопроверка</a><span>/</span><span>Больно ли ставить коронку</span></div></nav>
    <article class="content"><div class="container">
      <h1>Больно ли ставить коронку на зуб</h1>
      <p class="lead">Самый частый вопрос пациентов перед протезированием. Ответ: нет, не больно. Современные анестетики полностью блокируют боль на всех этапах.</p>
      <section><h2>Этапы установки коронки</h2>
      <p><strong>Препарирование (обточка) зуба</strong> — проводится под местной анестезией. Укол десны — единственный момент, где возможен дискомфорт, но он длится 2–3 секунды. Современные карпульные анестетики с артикаином действуют через 1–2 минуты и полностью блокируют чувствительность на 1,5–2 часа. Сам процесс обточки безболезнен — вы чувствуете только вибрацию и нажатие.</p>
      <p><strong>Снятие оттисков</strong> — не больно, возможен дискомфорт от ложки во рту в течение 2–3 минут. Современные силиконовые массы приятнее альгинатных.</p>
      <p><strong>Фиксация коронки</strong> — безболезненна. Коронка надевается на зуб, излишки цемента удаляются.</p></section>
      <section><h2>Что если зуб без нерва</h2>
      <p>Депульпированный (мёртвый) зуб не имеет нервных окончаний, поэтому анестезия при его препарировании не требуется. Но обезболивание всё равно может использоваться для комфортного отведения десны.</p></section>
      <section><h2>Бывает ли боль после</h2>
      <p>В течение 1–3 дней после фиксации возможна лёгкая чувствительность десны в месте инъекции и адаптации к коронке. Это нормально. Если боль сохраняется дольше или усиливается — обратитесь к врачу для проверки прикуса и посадки коронки.</p></section>
      <section class="cta-section"><h2>Боитесь боли? Зря.</h2>
      <p>Никитина Марина Георгиевна работает аккуратно и с анестезией. Приходите — убедитесь сами.</p>
      <div class="cta-buttons"><a href="tel:+79202537317" class="btn">Позвонить</a><a href="/services/metallokeramika" class="btn btn--secondary">О коронках</a></div></section>
      <nav class="related"><h3>Читайте также:</h3><ul><li><a href="/checkup/bolit-zub-pod-koronkoj">Болит зуб под коронкой</a></li><li><a href="/checkup/vypala-koronka">Выпала коронка</a></li></ul></nav>
    </div></article>
  </main>
  <style>.page { min-height: 100vh; background: var(--color-bg-alt); } .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); } .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; } .breadcrumbs a { color: var(--color-primary); } .content { padding: var(--space-3xl) 0; } .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); } .content h1 { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); } .content h2 { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; } .content p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); } .content ul { padding-left: var(--space-lg); margin-bottom: var(--space-md); } .content li { color: var(--color-text-muted); line-height: 1.7; } .lead { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; } .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl); border-radius: var(--radius-xl); margin-top: var(--space-3xl); text-align: center; } .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); } .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); } .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; } .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); } .btn--primary { background: white; color: var(--color-primary); } .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-decoration: none; } .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); } .btn--secondary:hover { border-color: white; text-decoration: none; } .related { margin-top: var(--space-2xl); padding: var(--space-lg); background: white; border-radius: var(--radius-xl); border: 1px solid var(--color-border); } .related h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-sm); } .related ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-sm); } .related li { margin: 0; } .related a { color: var(--color-primary); font-size: var(--text-sm); } @media (max-width: 768px) { .content h1 { font-size: var(--text-2xl); } .cta-section { padding: var(--space-xl) var(--space-md); } .cta-buttons { flex-direction: column; align-items: center; } }</style>
</BaseLayout>
