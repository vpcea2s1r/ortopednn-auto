---
const { variant = 'checkup' } = Astro.props;
---

<section class="cta-section">
  <div class="container">
    <h2>{variant === 'checkup' ? 'Запишитесь на консультацию' : 'Нужна консультация?'}</h2>
    <p>{variant === 'checkup'
      ? 'Позвоните — ответим на все вопросы и подберём удобное время'
      : 'Позвоните — поможем подобрать оптимальное решение для вашего случая'}</p>
    <div class="cta-buttons">
      <a href="tel:+79202537317" class="btn btn--primary">Позвонить</a>
      <a href="https://t.me/nikitina_ortoped" class="btn btn--secondary">Написать в Telegram</a>
    </div>
  </div>
</section>

<style>
  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%); color: white; padding: var(--space-2xl) 0; text-align: center; }
  .cta-section h2 { color: white; font-size: var(--text-2xl); margin-bottom: var(--space-sm); }
  .cta-section p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-lg); }
  .cta-buttons { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); }
  .btn--primary { background: white; color: var(--color-primary); }
  .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
  .btn--secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); }
  .btn--secondary:hover { border-color: white; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md); }
  @media (max-width: 768px) {
    .cta-section { padding: var(--space-xl) var(--space-md); }
    .cta-buttons { flex-direction: column; align-items: center; }
  }
</style>