---
const doctor = Astro.props.doctor;
const photo = doctor.photos?.[0] || doctor.photo || "/images/1.jpg";
---

<section class="why">
  <div class="container">
    <div class="why-content">
      <div class="doctor-info">
        <h2 class="doctor-name">{doctor.name}</h2>
        <p class="doctor-specialty">{doctor.specialty}</p>
        <p class="doctor-experience">{doctor.experience}</p>
        <p class="doctor-address">{doctor.address}</p>
      </div>
      <div class="doctor-photo">
        <img src={photo} alt={doctor.name} width="300" height="300" />
      </div>
    </div>
  </div>
</section>

<style>
.why {
  padding: 80px 0;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
}

.why-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}

@media (max-width: 768px) {
  .why-content {
    grid-template-columns: 1fr;
  }
}

.doctor-info {
  max-width: 500px;
}

.doctor-name {
  font-size: 1.75rem;
  color: #1e293b;
  margin-bottom: 8px;
}

.doctor-specialty {
  font-size: 1.1rem;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 4px;
}

.doctor-experience {
  color: #64748b;
  margin-bottom: 8px;
}

.doctor-address {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
}

.doctor-photo img {
  width: 100%;
  max-width: 300px;
  height: auto;
  border-radius: 24px;
  object-fit: cover;
  box-shadow: 0 20px 40px -8px rgba(0,0,0,0.15);
  display: block;
  margin: 0 auto;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 16px;
}
</style>
