---
const photosArr = JSON.stringify((Astro.props.doctor.photos || []));
---

<section class="why">
  <div class="container">
    <div class="why-content">
      <div class="doctor-info">
        <h2 class="doctor-name">{Astro.props.doctor.name}</h2>
        <p class="doctor-specialty">{Astro.props.doctor.specialty}</p>
        <p class="doctor-experience">{Astro.props.doctor.experience}</p>
        <p class="doctor-address">{Astro.props.doctor.address}</p>
      </div>
      <div class="doctor-photo">
        <img id="doctor-photo" src="/images/1.jpg" alt={Astro.props.doctor.name} width="300" height="420" />
      </div>
    </div>
  </div>
</section>

<script is:inline>
var _pl = {photosArr};
(function() {
  var img = document.getElementById('doctor-photo');
  if (img && _pl && _pl.length) {
    img.src = '/' + _pl[Math.floor(Math.random() * _pl.length)];
  }
})();
</script>

<style>
.why {
  padding: 80px 0;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
}

.why-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}

@media (max-width: 768px) {
  .why-content {
    grid-template-columns: 1fr;
  }
}

.doctor-info {
  max-width: 500px;
}

.doctor-name {
  font-size: 1.75rem;
  color: #1e293b;
  margin-bottom: 8px;
}

.doctor-specialty {
  font-size: 1.1rem;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 4px;
}

.doctor-experience {
  color: #64748b;
  margin-bottom: 8px;
}

.doctor-address {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
}

.doctor-photo img {
  width: 300px;
  height: 420px;
  border-radius: 24px;
  object-fit: cover;
  object-position: center 20%;
  box-shadow: 0 20px 40px -8px rgba(0,0,0,0.15);
  display: block;
  margin: 0 auto;
}

@media (max-width: 400px) {
  .doctor-photo img {
    width: 220px;
    height: 310px;
  }
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 16px;
}
</style>
