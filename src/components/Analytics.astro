---
const { ymId, gaId, cfToken } = Astro.props;
---

<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfToken}"}`}></script>

<script is:inline>
(function(){
  const CONSENT_KEY = 'analytics_consent_v1';
  
  if (localStorage.getItem(CONSENT_KEY) === 'accepted') {
    if ('{ymId}' && !window.ym) {
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,"script","https://mc.yandex.ru/metrika/tag.js","ym");
      ym('{ymId}'.replace('metrika',''), "init", {clickmap:true, webvisor:true});
    }
    if ('{gaId}' && !window.dataLayer) {
      window.dataLayer = [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{gaId}');
      const s = document.createElement('script');
      s.async = true;
      s.src = `https://www.googletagmanager.com/gtag/js?id={gaId}`;
      document.head.appendChild(s);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('cookie-banner')) return;
    
    const b = document.createElement('div');
    b.id = 'cookie-banner';
    b.style.cssText = 'position:fixed;bottom:0;left:0;right:0;background:#fff;padding:1rem;z-index:9999;display:flex;gap:1rem;align-items:center;';
    b.innerHTML = `<p>🍪 Cookie для анализа. <a href="/privacy">Политика</a></p><button id="accept" style="background:#0284c7;color:#fff;border:none;padding:0.5rem 1rem;border-radius:6px;cursor:pointer">Принять</button>`;
    document.body.appendChild(b);
    
    document.getElementById('accept').onclick = () => {
      localStorage.setItem(CONSENT_KEY, 'accepted');
      b.remove();
      location.reload();
    };
  });
})();
</script>