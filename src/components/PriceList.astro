---
import pricing from '../../data/pricing.json';

const doctor = {
  address: "Работаю в компании ООО Улыбка по адресу: Нижний Новгород, ул. Октябрьской Революции, д. 43, оф. 316.",
  phone: "+79202537317"
};
---

<section class="price-section" id="price">
  <div class="container">
    <h2>Цены</h2>
    <p class="subtitle">Фиксированные цены без скрытых платежей</p>
    
    <div class="price-grid">
      {pricing.map(section => (
        <div class="price-block">
          <h3>{section.category}</h3>
          <div class="items">
            {section.items.map(item => (
              <a href={item.link} class="price-item">
                <span class="name">{item.name}</span>
                <span class="price">{item.price}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <p class="note">* Цены указаны ориентировочно. Точную стоимость узнайте на консультации.</p>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Готовы записаться?</h2>
    <p>Позвоните — ответим на все вопросы и подберём удобное время</p>
    <a href={`tel:${doctor.phone}`} class="cta-btn">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Позвонить
    </a>
  </div>
</section>

<style>
.price-section {
  padding: 64px 24px;
  background: #faf5ff;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
}

.price-section h2 {
  text-align: center;
  font-size: 2rem;
  font-weight: 800;
  color: #1e1b4b;
  margin-bottom: 8px;
}

.subtitle {
  text-align: center;
  color: #6b7280;
  margin-bottom: 40px;
}

.price-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.price-block {
  background: white;
  border-radius: 16px;
  padding: 24px;
  border: 1px solid #ede9fe;
}

.price-block h3 {
  font-size: 0.875rem;
  font-weight: 600;
  color: #7c3aed;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #ede9fe;
}

.items {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.2s;
  background: #faf5ff;
}

.price-item:hover {
  background: #ede9fe;
}

.price-item .name {
  color: #1e1b4b;
  font-size: 0.9rem;
}

.price-item .price {
  color: #7c3aed;
  font-weight: 700;
  font-size: 0.9rem;
}

.note {
  text-align: center;
  color: #9ca3af;
  font-size: 0.875rem;
  margin-top: 32px;
}

.cta-section {
  padding: 80px 24px;
  background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%);
  text-align: center;
}

.cta-section h2 {
  color: white;
  font-size: 2rem;
  font-weight: 800;
  margin-bottom: 12px;
}

.cta-section p {
  color: rgba(255,255,255,0.8);
  font-size: 1.125rem;
  margin-bottom: 32px;
}

.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: white;
  color: #7c3aed;
  padding: 16px 40px;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 700;
  font-size: 1.125rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  transition: all 0.3s;
}

.cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.3);
}

@media (max-width: 640px) {
  .price-grid {
    grid-template-columns: 1fr;
  }
}
</style>