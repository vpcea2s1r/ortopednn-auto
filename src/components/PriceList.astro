---
import pricing from '../../data/pricing.json';

const doctorPhone = "+79202537317";
---

<section class="price-section" id="price">
  <header class="price-section__header">
    <h2 class="price-section__title">Цены</h2>
    <p class="price-section__subtitle">Фиксированные цены без скрытых платежей</p>
  </header>
  
  <div class="price-section__grid">
    {pricing.map(section => (
      <div class="price-block">
        <h3 class="price-block__category">{section.category}</h3>
        <div class="price-block__items">
          {section.items.map(item => (
            <a href={item.link} class="price-item">
              <span class="price-item__name">{item.name}</span>
              <span class="price-item__price">{item.price}</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
  
  <p class="price-section__note">* Цены указаны ориентировочно. Точную стоимость узнайте на консультации.</p>
</section>

<section class="cta-section">
  <h2 class="cta-section__title">Готовы записаться?</h2>
  <p class="cta-section__text">Позвоните — ответим на все вопросы и подберём удобное время</p>
  <a href={`tel:${doctorPhone}`} class="cta-section__btn">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    Позвонить
  </a>
</section>

<style>
.price-section {
  padding: var(--space-3xl) 0;
  background: var(--color-bg);
}

.price-section__header {
  text-align: center;
  margin-bottom: var(--space-xl);
}

.price-section__title {
  font-size: var(--text-2xl);
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.price-section__subtitle {
  color: var(--color-text-muted);
}

.price-section__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
}

.price-block {
  background: white;
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  border: 1px solid var(--color-border);
}

.price-block__category {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-sm);
  border-bottom: 1px solid var(--color-border);
}

.price-block__items {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: all var(--transition-fast);
  background: var(--color-bg);
}

.price-item__name {
  color: var(--color-text);
  font-size: var(--text-sm);
  line-height: 1.4;
  flex: 1;
  min-width: 0;
}

.price-item__price {
  color: var(--color-primary);
  font-weight: 700;
  font-size: var(--text-sm);
  white-space: nowrap;
  flex-shrink: 0;
}

.price-item:hover {
  background: var(--color-border);
  text-decoration: none;
}

.price-item__name {
  color: var(--color-text);
  font-size: var(--text-sm);
}

.price-item__price {
  color: var(--color-primary);
  font-weight: 700;
  font-size: var(--text-sm);
}

.price-section__note {
  text-align: center;
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  margin-top: var(--space-xl);
}

.cta-section {
  padding: var(--space-3xl) var(--space-md);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%);
  text-align: center;
}

.cta-section__title {
  color: white;
  font-size: var(--text-2xl);
  font-weight: 800;
  margin-bottom: var(--space-sm);
}

.cta-section__text {
  color: rgba(255,255,255,0.8);
  font-size: var(--text-lg);
  margin-bottom: var(--space-xl);
}

.cta-section__btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-sm);
  background: white;
  color: var(--color-primary);
  padding: var(--space-md) var(--space-xl);
  border-radius: var(--radius-lg);
  text-decoration: none;
  font-weight: 700;
  font-size: var(--text-lg);
  box-shadow: var(--shadow-lg);
  transition: all var(--transition-fast);
}

.cta-section__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.3);
  text-decoration: none;
}

@media (max-width: 640px) {
  .price-section {
    padding: var(--space-xl) 0;
  }
  .price-section__title {
    font-size: var(--text-xl);
  }
  .price-section__grid {
    grid-template-columns: 1fr;
  }
  .cta-section {
    padding: var(--space-xl) var(--space-sm);
  }
  .cta-section__title {
    font-size: var(--text-xl);
  }
}
</style>