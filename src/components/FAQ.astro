---
const faq = [
  { q: "Больно ли обтачивать зубы под коронку?", a: "Работаю с анестезией — вы не почувствуете боли. После — возможна чувствительность на 1-2 дня.", cat: "treatment" },
  { q: "Сколько времени занимает протезирование?", a: "Коронки — 7-14 дней. Съёмные протезы — 2-3 недели. Зависит от сложности.", cat: "treatment" },
  { q: "Какой протез лучше — съёмный или на имплантах?", a: "Импланты комфортнее и долговечнее. Но съёмные подходят, когда имплантация невозможна.", cat: "prosthetics" },
  { q: "Нужно ли обтачивать здоровые зубы?", a: "Стараюсь сохранить здоровые зубы. Обточка нужна только для фиксации коронки.", cat: "treatment" },
  { q: "Как ухаживать за съёмным протезом?", a: "Промывайте после еда, чистите 2 раза в день, храните в воде. Раз в полгода — профчистка.", cat: "care" },
  { q: "Сколько служит циркониевая коронка?", a: "15-20 лет при правильном уходе. Раз в год — осмотр.", cat: "durability" },
  { q: "Что делать, если протез натирает?", a: "Запишитесь на коррекцию. Обычно 1-3 визита. Не подтачивайте сами.", cat: "care" },
  { q: "Как понять, что пора менять коронку?", a: "Боль, отёк, подвижность, изменение цвета десны, запах — повод обратиться.", cat: "care" }
];
---

<div class="faq-container">
  <h2>Частые вопросы</h2>
  {faq.map((item, i) => (
    <details class="faq-item">
      <summary>{item.q}</summary>
      <p>{item.a}</p>
    </details>
  ))}
</div>

<style>
.faq-container { max-width: 800px; margin: 0 auto; }
.faq-container h2 { text-align: center; margin-bottom: 1.5rem; color: #1e3a5f; }
.faq-item { margin-bottom: 0.5rem; border: 1px solid #e0ebf5; border-radius: 8px; overflow: hidden; }
.faq-item summary { padding: 1rem; cursor: pointer; background: white; font-weight: 500; list-style: none; }
.faq-item summary::before { content: "▸ "; }
.faq-item[open] summary::before { content: "▾ "; }
.faq-item p { padding: 1rem; background: #f8fafc; margin: 0; line-height: 1.6; }
</style>