---
const navLinks = [
  { href: "/services", label: "Услуги" },
  { href: "/checkup", label: "Вопросы и ответы" },
  { href: "/about", label: "О враче" },
  { href: "/blog", label: "Блог" },
  { href: "/#location", label: "Контакты" },
];
---

<nav class="navbar" role="navigation" aria-label="Основная навигация">
  <div class="navbar__top">
    <a href="tel:+79202537317" class="navbar__phone">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      +7 920 253-73-17
    </a>
    <button class="navbar__toggle" aria-label="Меню" aria-expanded="false">
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
    </button>
  </div>
  <div class="navbar__bottom" id="navbar-menu">
    <div class="navbar__links">
      {navLinks.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
(function() {
  var toggle = document.querySelector('.navbar__toggle');
  var menu = document.getElementById('navbar-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', !expanded);
      menu.classList.toggle('navbar__bottom--open');
    });
  }
})();
</script>

<style>
.navbar {
  background: white;
  box-shadow: var(--shadow-sm);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}

.navbar__top {
  max-width: 1000px;
  margin: 0 auto;
  padding: var(--space-sm) var(--space-md);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.navbar__phone {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-primary);
  color: white;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  text-decoration: none;
  font-weight: 600;
  font-size: var(--text-sm);
  box-shadow: var(--shadow-md);
  transition: all var(--transition-fast);
  white-space: nowrap;
}

.navbar__phone:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
}

.navbar__toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-xs);
  flex-direction: column;
  gap: 4px;
}

.navbar__toggle-bar {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-text);
  border-radius: 2px;
  transition: transform 0.2s;
}

.navbar__bottom {
  border-top: 1px solid var(--color-border);
}

.navbar__links {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 var(--space-md);
  display: flex;
  gap: 0;
}

.navbar__link {
  color: var(--color-text-muted);
  font-weight: 500;
  text-decoration: none;
  font-size: var(--text-sm);
  padding: var(--space-sm) var(--space-md);
  transition: color var(--transition-fast);
  border-bottom: 2px solid transparent;
}

.navbar__link:hover {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
}

@media (max-width: 768px) {
  .navbar__toggle {
    display: flex;
  }

  .navbar__phone {
    display: none;
  }

  .navbar__bottom {
    display: none;
  }

  .navbar__bottom--open {
    display: block;
  }

  .navbar__links {
    flex-direction: column;
    padding: var(--space-sm) var(--space-md);
  }

  .navbar__link {
    padding: var(--space-sm) 0;
    border-bottom: none;
  }
}
</style>
