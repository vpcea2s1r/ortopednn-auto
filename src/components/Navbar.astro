---
const navLinks = [
  { href: "/services", label: "Услуги" },
  { href: "/blog", label: "Блог" },
  { href: "/materials", label: "Материалы" },
  { href: "/compare", label: "Сравнение" },
  { href: "#price", label: "Цены" },
];
---

<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="logo">Никитина М.Г.</a>
    <div class="nav-links">
      {navLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
.navbar {
  background: white;
  padding: 16px 24px;
  box-shadow: 0 2px 10px rgba(30,58,95,0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo {
  font-weight: 600;
  color: #1e3a5f;
  font-size: 1.125rem;
  text-decoration: none;
}

.nav-links {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.nav-links a {
  color: #4a90d9;
  font-weight: 500;
  transition: color 0.2s;
  text-decoration: none;
}

.nav-links a:hover {
  color: #2e6ab3;
}

@media (max-width: 640px) {
  .nav-links {
    gap: 12px;
    font-size: 0.8rem;
  }
}
</style>