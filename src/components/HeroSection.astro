---
const doctor = Astro.props.doctor;
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">
      <span>Протезирование зубов</span>
    </div>
    <h1>Протезирование зубов в Нижнем Новгороде</h1>
    <p class="subtitle">Коронки, виниры, съёмные и бюгельные протезы. Стоматолог-ортопед Никитина Марина Георгиевна</p>
    
    <div class="hero-stats">
      <div class="stat">
        <span class="num">Протезирование зубов</span>
        <span class="label">металлокерамика, цирконий, виниры</span>
      </div>
      <div class="stat">
        <span class="num">Индивидуальный подход</span>
        <span class="label">к каждому пациенту</span>
      </div>
    </div>
    
    <div class="hero-actions">
      <a href={`tel:${doctor.phone}`} class="btn-primary">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {doctor.phoneDisplay}
      </a>
      <a href="#price" class="btn-secondary">Смотреть цены</a>
    </div>
  </div>
  <div class="hero-decoration">
    <div class="circle circle-1"></div>
    <div class="circle circle-2"></div>
    <div class="circle circle-3"></div>
  </div>
</section>

<style>
.hero {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(135deg, #faf5ff 0%, #f5f3ff 50%, #ede9fe 100%);
  padding: 64px 24px;
  position: relative;
  overflow: hidden;
}

.hero-content {
  max-width: 600px;
  position: relative;
  z-index: 2;
}

.hero-badge {
  display: inline-block;
  background: #7c3aed;
  color: white;
  padding: 8px 20px;
  border-radius: 100px;
  font-size: 0.875rem;
  font-weight: 600;
  margin-bottom: 24px;
}

.hero h1 {
  font-size: 3rem;
  font-weight: 800;
  color: #1e1b4b;
  margin-bottom: 12px;
  line-height: 1.1;
}

.subtitle {
  font-size: 1.125rem;
  color: #6b7280;
  margin-bottom: 32px;
}

.hero-stats {
  display: flex;
  justify-content: center;
  gap: 48px;
  margin-bottom: 40px;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat .num {
  font-size: 2.5rem;
  font-weight: 800;
  color: #7c3aed;
}

.stat .label {
  font-size: 0.875rem;
  color: #6b7280;
  margin-top: 4px;
}

.hero-actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%);
  color: white;
  padding: 14px 28px;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 600;
  font-size: 1rem;
  box-shadow: 0 10px 30px rgba(124, 58, 237, 0.3);
  transition: all 0.3s;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 15px 40px rgba(124, 58, 237, 0.4);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  background: white;
  color: #7c3aed;
  padding: 14px 28px;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 600;
  font-size: 1rem;
  border: 2px solid #e9d5ff;
  transition: all 0.3s;
}

.btn-secondary:hover {
  background: #f5f3ff;
  border-color: #7c3aed;
}

.hero-decoration {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
  opacity: 0.1;
}

.circle-1 {
  width: 400px;
  height: 400px;
  top: -100px;
  right: -100px;
}

.circle-2 {
  width: 300px;
  height: 300px;
  bottom: -50px;
  left: -100px;
}

.circle-3 {
  width: 200px;
  height: 200px;
  top: 50%;
  right: 20%;
}

@media (max-width: 640px) {
  .hero h1 {
    font-size: 2rem;
  }
  .hero-stats {
    gap: 32px;
  }
  .stat .num {
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
  }
  .hero-actions {
    flex-direction: column;
  }
  .btn-primary, .btn-secondary {
    width: 100%;
    justify-content: center;
  }
}
</style>