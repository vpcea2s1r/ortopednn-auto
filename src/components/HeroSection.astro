---
const doctor = Astro.props.doctor;
---

<section class="hero">
  <div class="hero-content">
    <h1>Никитина Марина Георгиевна</h1>
    <p class="subtitle">Стоматолог-ортопед</p>
    <p class="tagline">
      Профессиональное протезирование зубов — восстановление эстетики и функций вашей улыбки
    </p>
    <div class="hero-buttons">
      <a href={`tel:${doctor.phone}`} class="btn-primary">
        {doctor.phoneDisplay}
      </a>
      <a href="#contacts" class="btn-secondary">
        Записаться
      </a>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(180deg, #e8f4fd 0%, #f0f8ff 100%);
  padding: 48px 16px;
}

.hero-content {
  max-width: 800px;
}

.hero h1 {
  font-size: 2.5rem;
  color: #1e3a5f;
  margin-bottom: 8px;
  font-weight: 700;
}

.subtitle {
  font-size: 1.25rem;
  color: #4a90d9;
  font-weight: 500;
  margin-bottom: 16px;
}

.tagline {
  color: #5a7a9a;
  font-size: 1rem;
  max-width: 500px;
  margin: 0 auto 24px;
}

.hero-buttons {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-primary {
  background: linear-gradient(135deg, #4a90d9 0%, #2e6ab3 100%);
  color: white;
  padding: 12px 24px;
  border-radius: 100px;
  text-decoration: none;
  font-weight: 600;
  box-shadow: 0 4px 15px rgba(74, 144, 217, 0.3);
  transition: all 0.3s;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(74, 144, 217, 0.4);
}

.btn-secondary {
  border: 2px solid #2e6ab3;
  color: #2e6ab3;
  padding: 12px 24px;
  border-radius: 100px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-secondary:hover {
  background: #2e6ab3;
  color: white;
}

@media (max-width: 640px) {
  .hero h1 {
    font-size: 1.75rem;
  }
  .hero-buttons {
    flex-direction: column;
    align-items: center;
  }
  .btn-primary, .btn-secondary {
    width: 100%;
    max-width: 280px;
  }
}
</style>