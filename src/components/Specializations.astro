---
const services = [
  { title: "Коронки", desc: "Цирконий, металлокерамика, E-MAX", link: "/services/metallokeramika" },
  { title: "Виниры", desc: "Эстетика улыбки", link: "/services/viniry-emaks" },
  { title: "Съёмные протезы", desc: "Акрил, AcryFree, нейлон", link: "/services/sjemny-protez" },
  { title: "Бюгельные", desc: "На замках и кламмерах", link: "/services/byugelnyj" },
  { title: "Ремонт", desc: "Коррекция, починка", link: "/services/korrekciya" },
];
---

<section class="services-section">
  <div class="container">
    <h2>Услуги</h2>
    <div class="grid">
      {services.map(item => (
        <a href={item.link} class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
          <span class="arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.services-section {
  padding: 64px 24px;
  background: white;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
}

.services-section h2 {
  text-align: center;
  font-size: 0.875rem;
  font-weight: 600;
  color: #7c3aed;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 40px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
}

.card {
  background: #faf5ff;
  border-radius: 16px;
  padding: 24px;
  text-decoration: none;
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  border: 1px solid #ede9fe;
}

.card:hover {
  background: white;
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(124, 58, 237, 0.1);
  border-color: #7c3aed;
}

.card-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.card-icon svg {
  color: white;
}

.card h3 {
  color: #1e1b4b;
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 8px;
}

.card p {
  color: #6b7280;
  font-size: 0.875rem;
  line-height: 1.5;
  margin-bottom: 16px;
}

.arrow {
  color: #7c3aed;
  font-weight: 700;
  font-size: 1.25rem;
  margin-top: auto;
}

.card:hover .arrow {
  transform: translateX(4px);
  display: inline-block;
}

@media (max-width: 640px) {
  .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>