---
const services = [
  { title: "Коронки", desc: "Цирконий, металлокерамика, E-MAX", icon: "🦷", link: "/services/metallokeramika", popular: true },
  { title: "Виниры", desc: "Эстетика улыбки", icon: "✨", link: "/services/viniry-emaks", popular: true },
  { title: "Съёмные протезы", desc: "Акрил, AcryFree, нейлон", icon: "🫄", link: "/services/sjemny-protez" },
  { title: "Бюгельные", desc: "На замках и кламмерах", icon: "🔩", link: "/services/byugelnyj" },
  { title: "Ремонт", desc: "Коррекция, починка", icon: "🔧", link: "/services/korrekciya" },
];
---

<section class="services-section">
  <div class="container">
    <h2>Основные услуги</h2>
    <div class="grid">
      {services.map(item => (
        <a href={item.link} class={`card ${item.popular ? 'popular' : ''}`}>
          <span class="icon">{item.icon}</span>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
          {item.popular && <span class="badge-popular">Популярное</span>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.services-section {
  padding: 48px 0;
  background: white;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 16px;
}

.services-section h2 {
  text-align: center;
  font-size: 1.5rem;
  color: #1e3a5f;
  margin-bottom: 24px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
}

.card {
  background: white;
  border-radius: 12px;
  padding: 24px 16px;
  text-align: center;
  text-decoration: none;
  transition: all 0.3s;
  box-shadow: 0 4px 20px rgba(30, 58, 95, 0.08);
  border: 2px solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 30px rgba(30, 58, 95, 0.15);
  border-color: #4a90d9;
}

.card.popular {
  border-color: #22c55e;
}

.card .icon {
  font-size: 2rem;
  margin-bottom: 8px;
}

.card h3 {
  color: #1e3a5f;
  font-size: 1rem;
  margin-bottom: 4px;
}

.card p {
  color: #5a7a9a;
  font-size: 0.8rem;
}

.badge-popular {
  position: absolute;
  top: -8px;
  right: -8px;
  background: #22c55e;
  color: white;
  font-size: 0.65rem;
  padding: 2px 8px;
  border-radius: 100px;
  font-weight: 600;
}

@media (max-width: 640px) {
  .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>